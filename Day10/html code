    /* ── theme variables ── */
    :root {
      --bg:       #f8f7ff;
      --surface:  #ffffff;
      --text:     #1e1b4b;
      --muted:    #6b7280;
      --border:   rgba(139,92,246,.18);
    }
    .dark {
      --bg:       #0d0b1a;
      --surface:  #13112a;
      --text:     #e9e6ff;
      --muted:    #9ca3af;
      --border:   rgba(139,92,246,.25);
    }

    body {
      background: var(--bg);
      color: var(--text);
      transition: background .4s, color .4s;
    }

    /* ── gradient text ── */
    .grad { background: linear-gradient(135deg,#8b5cf6,#14b8a6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    /* ── animated gradient bg ── */
    .grad-bg { background: linear-gradient(270deg,#8b5cf6,#14b8a6,#6d28d9,#0d9488); background-size: 400% 400%; animation: gradient 8s ease infinite; }

    /* ── glass card ── */
    .glass {
      background: var(--surface);
      border: 1px solid var(--border);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      transition: background .4s, border .4s, transform .3s, box-shadow .3s;
    }
    .glass:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(139,92,246,.18); }

    /* ── typing cursor ── */
    .cursor::after { content: '|'; animation: blink 1s step-end infinite; color: #8b5cf6; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    /* ── skill bar ── */
    .skill-bar { height: 6px; border-radius: 9999px; background: rgba(139,92,246,.15); overflow: hidden; }
    .skill-fill { height: 100%; border-radius: 9999px; background: linear-gradient(90deg,#8b5cf6,#14b8a6); width: 0; transition: width 1.2s cubic-bezier(.4,0,.2,1); }

    /* ── scroll reveal ── */
    .reveal { opacity: 0; transform: translateY(36px); transition: opacity .7s ease, transform .7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── nav glass ── */
    nav { background: rgba(255,255,255,.72); border-bottom: 1px solid rgba(139,92,246,.12); backdrop-filter: blur(14px); }
    .dark nav { background: rgba(13,11,26,.78); }

    /* ── active nav link ── */
    .nav-link { position: relative; }
    .nav-link::after { content:''; position:absolute; bottom:-2px; left:0; width:0; height:2px; background:linear-gradient(90deg,#8b5cf6,#14b8a6); border-radius:9999px; transition:width .3s; }
    .nav-link.active::after, .nav-link:hover::after { width: 100%; }

    /* ── blob ── */
    .blob { position:absolute; border-radius:50%; filter:blur(80px); opacity:.18; animation: float 8s ease-in-out infinite; pointer-events:none; }

    /* ── toggle switch ── */
    .toggle-track { width:48px; height:26px; border-radius:9999px; background:linear-gradient(135deg,#8b5cf6,#14b8a6); position:relative; cursor:pointer; transition:background .3s; }
    .toggle-thumb { width:20px; height:20px; border-radius:50%; background:#fff; position:absolute; top:3px; left:3px; transition:transform .3s; box-shadow:0 2px 6px rgba(0,0,0,.25); }
    .dark .toggle-thumb { transform:translateX(22px); }

    /* ── back-to-top ── */
    #btt { opacity:0; pointer-events:none; transition:opacity .3s; }
    #btt.show { opacity:1; pointer-events:auto; }

    /* ── contact form ── */
    .form-input {
      width:100%; padding:.75rem 1rem; border-radius:.75rem;
      background:var(--surface); border:1px solid var(--border);
      color:var(--text); outline:none;
      transition: border-color .3s, box-shadow .3s, background .4s;
    }
    .form-input:focus { border-color:#8b5cf6; box-shadow:0 0 0 3px rgba(139,92,246,.2); }

    /* ── tag pill ── */
    .tag { display:inline-block; padding:.2rem .75rem; border-radius:9999px; font-size:.72rem; font-weight:500;
           background:rgba(139,92,246,.12); color:#8b5cf6; border:1px solid rgba(139,92,246,.25); }

    /* ── section heading underline ── */
    .section-title { display:inline-block; position:relative; }
    .section-title::after { content:''; position:absolute; bottom:-8px; left:0; width:60%; height:3px; border-radius:9999px; background:linear-gradient(90deg,#8b5cf6,#14b8a6); }

    /* ── footer gradient line ── */
    .footer-line { height:2px; background:linear-gradient(90deg,transparent,#8b5cf6,#14b8a6,transparent); }

    /* ── hero orb ── */
    .orb { width:320px; height:320px; border-radius:50%;
           background:conic-gradient(from 200deg,#8b5cf6,#14b8a6,#6d28d9,#8b5cf6);
           animation: float 7s ease-in-out infinite; position:relative; }
    .orb::after { content:''; position:absolute; inset:12px; border-radius:50%;
                  background:var(--bg); transition:background .4s; }

    /* ── mobile menu ── */
