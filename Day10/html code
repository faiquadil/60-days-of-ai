<!-- ════════════════════════════ SCRIPTS ═════════════════════════════ -->
<script>
// ── Data ──────────────────────────────────────────────────────────────
const SKILLS = [
  { name: 'Python',            pct: 88 },
  { name: 'Data Analysis',     pct: 85 },
  { name: 'SQL',               pct: 80 },
  { name: 'Machine Learning',  pct: 72 },
  { name: 'Data Visualization',pct: 82 },
  { name: 'Statistics',        pct: 75 },
  { name: 'HTML/CSS/JS',       pct: 78 },
];

const TOOLS = ['Jupyter Notebook','VS Code','Power BI','Git','GitHub','Excel','Google Colab','Pandas','Matplotlib','Chart.js'];

const SOFT  = ['Communication','Leadership','Teamwork','Problem Solving','Time Management','Critical Thinking'];

const PROJECTS = [
  {
    emoji: '📊',
    name: 'HR Data Analysis Dashboard',
    desc: 'Analyzed employee data to identify workforce trends, performance insights, and attrition patterns using visual analytics.',
    tech: ['Python','Pandas','Matplotlib','Jupyter'],
    color: 'purple',
  },
  {
    emoji: '🥗',
    name: 'NutriScope Nutrition Tracker',
    desc: 'Built a nutrition tracking web application for monitoring dietary intake and visualizing health metrics interactively.',
    tech: ['HTML','CSS','JavaScript','Chart.js'],
    color: 'teal',
  },
  {
    emoji: '🎓',
    name: 'Student Performance Analytics',
    desc: 'Developed visual reports and dashboards to analyze student attendance and academic performance trends.',
    tech: ['Python','Pandas','Power BI'],
    color: 'purple',
  },
];

const ACHIEVEMENTS = [
  { icon: '🤖', title: 'AI & Data Analytics Projects', desc: 'Completed multiple end-to-end projects leveraging Python and Power BI to derive actionable data insights.' },
  { icon: '🏆', title: 'AI Learning Challenges', desc: 'Active participant in AI learning challenges and portfolio-building programs focused on real-world applications.' },
  { icon: '💻', title: 'GitHub Portfolio', desc: 'Built and documented real-world data analysis projects on GitHub, showcasing reproducible, well-structured code.' },
  { icon: '🚀', title: 'Generative AI Growth', desc: 'Consistently advancing skills in Generative AI and Data Science through hands-on practice and continuous learning.' },
];

// ── Inject Skill Bars ──────────────────────────────────────────────
const sbContainer = document.getElementById('skill-bars');
SKILLS.forEach(s => {
  sbContainer.innerHTML += `
    <div>
      <div class="flex justify-between text-sm mb-1">
        <span class="font-medium text-[var(--text)]">${s.name}</span>
        <span class="text-[var(--muted)]">${s.pct}%</span>
      </div>
      <div class="skill-bar"><div class="skill-fill" data-width="${s.pct}"></div></div>
    </div>`;
});

// ── Inject Tool Tags ───────────────────────────────────────────────
const ttContainer = document.getElementById('tools-tags');
TOOLS.forEach(t => { ttContainer.innerHTML += `<span class="tag">${t}</span>`; });

// ── Inject Soft Tags ──────────────────────────────────────────────
const stContainer = document.getElementById('soft-tags');
SOFT.forEach(s => {
  stContainer.innerHTML += `<span class="tag" style="background:rgba(20,184,166,.1);color:#14b8a6;border-color:rgba(20,184,166,.25)">${s}</span>`;
});

// ── Inject Project Cards ───────────────────────────────────────────
const pg = document.getElementById('projects-grid');
PROJECTS.forEach((p, i) => {
  const accent = p.color === 'teal' ? '#14b8a6' : '#8b5cf6';
  const tagStyle = p.color === 'teal'
    ? 'background:rgba(20,184,166,.1);color:#14b8a6;border-color:rgba(20,184,166,.25)'
    : '';
  pg.innerHTML += `
    <div class="reveal glass rounded-3xl p-7 flex flex-col gap-4" style="transition-delay:${i*0.1}s">
      <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl" style="background:${accent}18">${p.emoji}</div>
      <h3 class="font-bold text-base">${p.name}</h3>
      <p class="text-sm text-[var(--muted)] leading-relaxed flex-1">${p.desc}</p>
      <div class="flex flex-wrap gap-2 mt-auto pt-2 border-t border-[var(--border)]">
        ${p.tech.map(t => `<span class="tag" style="${tagStyle}">${t}</span>`).join('')}
      </div>
    </div>`;
});

// ── Inject Achievement Cards ───────────────────────────────────────
const ag = document.getElementById('achievements-grid');
ACHIEVEMENTS.forEach((a, i) => {
  ag.innerHTML += `
    <div class="reveal glass rounded-3xl p-7 flex gap-5 items-start" style="transition-delay:${i*0.1}s">
      <span class="text-3xl flex-shrink-0 mt-1">${a.icon}</span>
      <div>
        <h3 class="font-bold text-base mb-1">${a.title}</h3>
        <p class="text-sm text-[var(--muted)] leading-relaxed">${a.desc}</p>
      </div>
    </div>`;
});

// ── Typing Animation ───────────────────────────────────────────────
const phrases = [
  'Data Analytics Enthusiast',
  'GenAI Learner',
  'Python Developer',
  'ML Explorer',
  'Problem Solver',
];
let pi = 0, ci = 0, deleting = false;
const el = document.getElementById('typing-text');

function type() {
  const word = phrases[pi];
  if (!deleting) {
    el.textContent = word.slice(0, ++ci);
    if (ci === word.length) { deleting = true; setTimeout(type, 1800); return; }
  } else {
    el.textContent = word.slice(0, --ci);
    if (ci === 0) { deleting = false; pi = (pi + 1) % phrases.length; }
  }
  setTimeout(type, deleting ? 60 : 90);
}
type();

// ── Dark / Light Toggle ────────────────────────────────────────────
const html = document.documentElement;
const stored = localStorage.getItem('theme');
if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
  html.classList.add('dark');
}

document.getElementById('theme-toggle').addEventListener('click', () => {
  html.classList.toggle('dark');
  localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
});

// ── Mobile Menu ────────────────────────────────────────────────────
const hamburger = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobile-menu');
hamburger.addEventListener('click', () => mobileMenu.classList.toggle('open'));
mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobileMenu.classList.remove('open')));

// ── Back to Top ────────────────────────────────────────────────────
const btt = document.getElementById('btt');
window.addEventListener('scroll', () => {
  btt.classList.toggle('show', window.scrollY > 400);
});

// ── Scroll Reveal ──────────────────────────────────────────────────
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      // animate skill bars when in view
      entry.target.querySelectorAll('.skill-fill').forEach(bar => {
        bar.style.width = bar.dataset.width + '%';
      });
    }
  });
}, { threshold: 0.12 });

revealEls.forEach(el => observer.observe(el));

// Also trigger skill bar animation when the skills section enters view
const skillSection = document.getElementById('skills');
const skillObserver = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) {
    document.querySelectorAll('.skill-fill').forEach(bar => {
      bar.style.width = bar.dataset.width + '%';
    });
  }
}, { threshold: 0.2 });
skillObserver.observe(skillSection);

// ── Active Nav Highlighting ────────────────────────────────────────
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('#nav-links .nav-link');

window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(sec => {
    if (window.scrollY >= sec.offsetTop - 120) current = sec.id;
  });
  navLinks.forEach(link => {
    link.classList.toggle('active', link.getAttribute('href') === '#' + current);
  });
});

// ── Contact Form ───────────────────────────────────────────────────
function handleForm(e) {
  e.preventDefault();
  const btn = document.getElementById('form-btn');
  const msg = document.getElementById('form-msg');
  btn.textContent = 'Sending…';
  btn.disabled = true;
  setTimeout(() => {
    btn.textContent = 'Send Message →';
    btn.disabled = false;
    msg.classList.remove('hidden');
    e.target.reset();
    setTimeout(() => msg.classList.add('hidden'), 4000);
  }, 1200);
}
</script>
</body>
</html>
