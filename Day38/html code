/* =====================================================================
   TYPING ENGINE
   ===================================================================== */
const textDisplay = document.getElementById("textDisplay");
const hiddenInput = document.getElementById("hiddenInput");
const startOverlay = document.getElementById("startOverlay");
const pauseOverlay = document.getElementById("pauseOverlay");
const stageEl = document.getElementById("stage");

function renderText(){
  textDisplay.innerHTML = "";
  const chars = state.text.split("");
  let lineStarts = [0];
  chars.forEach((ch,i)=>{ if(ch==="\n") lineStarts.push(i+1); });

  chars.forEach((ch, i)=>{
    const span = document.createElement("span");
    span.className = "ch";
    span.dataset.i = i;
    span.textContent = ch === "\n" ? "↵\n" : (ch === " " ? "\u00A0" : ch);
    textDisplay.appendChild(span);
  });
  updateFocusVisibility();
}

function updateFocusVisibility(){
  if(state.mode !== "focus") return;
  const spans = textDisplay.children;
  const idx = state.typed.length;
  // find current line boundaries
  let lineStart = 0, lineEnd = state.text.length;
  for(let i=0;i<state.text.length;i++){
    if(state.text[i]==="\n"){
      if(i < idx) lineStart = i+1;
      else { lineEnd = i; break; }
    }
  }
  for(let i=0;i<spans.length;i++){
    spans[i].classList.toggle("ln-hidden", i<lineStart || i>lineEnd);
  }
}

function startSession(){
  if(state.finished) resetSession(false);
  if(state.running) return;
  state.running = true;
  state.paused = false;
  state.startTs = Date.now();
  state.totalPausedMs = 0;
  startOverlay.classList.add("hidden");
  document.getElementById("liveStats").classList.add("show");
  document.getElementById("selectorPanel").style.pointerEvents = "none";
  document.getElementById("selectorPanel").style.opacity = "0.5";
  hiddenInput.focus();
  if(state.mode === "time"){
    state.timerHandle = setInterval(tick, 100);
  } else {
    state.timerHandle = setInterval(tick, 100);
  }
  beep(660,0.05,0.04);
}

function tick(){
  if(!state.running || state.paused) return;
  updateLiveStats();
  if(state.mode === "time"){
    const elapsed = (Date.now()-state.startTs-state.totalPausedMs)/1000;
    if(elapsed >= state.timeOption){
      finishSession();
    }
  }
}

function togglePause(){
  if(!state.running || state.finished) return;
  state.paused = !state.paused;
  pauseOverlay.classList.toggle("hidden", !state.paused);
  if(state.paused){
    state.pausedAt = Date.now();
    document.getElementById("pauseBtn").textContent = "▶ Resume";
  } else {
    state.totalPausedMs += Date.now()-state.pausedAt;
    document.getElementById("pauseBtn").innerHTML = '⏸ Pause <span class="kbd">Esc</span>';
    hiddenInput.focus();
  }
}

function resetSession(keepOverlay){
  clearInterval(state.timerHandle);
  state.running = false;
  state.paused = false;
  state.finished = false;
  state.startTs = null;
  state.totalPausedMs = 0;
  state.typed = [];
  state.extra = [];
  state.correctCount = 0;
  state.incorrectCount = 0;
  state.missedCount = 0;
  state.mistakeEvents = 0;
  state.currentStreak = 0;
  state.bestStreak = 0;
  state.wpmHistory = [];
  state.errorLog = {};
  state.rhythmLog = [];
  state.lastKeyTs = null;
  state.text = generateText();
  renderText();
  document.getElementById("liveStats").classList.remove("show");
  document.getElementById("results").classList.remove("show");
  document.getElementById("progressBar").style.width = "0%";
  document.getElementById("selectorPanel").style.pointerEvents = "auto";
  document.getElementById("selectorPanel").style.opacity = "1";
  pauseOverlay.classList.add("hidden");
  startOverlay.classList.remove("hidden");
  document.getElementById("overlaySub").textContent =
    capitalize(state.category==="programming"?state.progLang:state.category) + " · " + capitalize(state.mode) +
    (state.mode==="time" ? " · "+state.timeOption+"s" : state.mode==="words" ? " · "+state.wordOption+" words" : "");
  hiddenInput.value = "";
  updateCurrentCursor();
}
function capitalize(s){ return s.charAt(0).toUpperCase()+s.slice(1); }

function updateCurrentCursor(){
  [...textDisplay.children].forEach(c=>c.classList.remove("current"));
  const idx = state.typed.length;
  if(textDisplay.children[idx]) textDisplay.children[idx].classList.add("current");
}

hiddenInput.addEventListener("keydown", handleKeydown);
stageEl.addEventListener("click", ()=>{
  if(!state.running && !state.finished) startSession();
  hiddenInput.focus();
});

function handleKeydown(e){
  if(e.key === "Escape"){ e.preventDefault(); if(state.running) togglePause(); return; }
  if(e.ctrlKey && e.key === "Enter"){ e.preventDefault(); resetSession(true); return; }
  if(!state.running && e.key === "Enter"){ e.preventDefault(); startSession(); return; }
  if(!state.running || state.paused || state.finished) { e.preventDefault(); return; }

  if(e.key === "Backspace"){
    e.preventDefault();
    if(state.extra.length > 0){ state.extra.pop(); }
    else if(state.typed.length > 0){
      const removed = state.typed.pop();
      const span = textDisplay.children[state.typed.length];
      if(span){ span.classList.remove("correct","incorrect"); }
    }
    updateCurrentCursor();
    updateFocusVisibility();
    updateLiveStats();
    return;
  }
  if(e.key.length !== 1 && e.key !== "Enter" && e.key !== "Tab") return;
  e.preventDefault();

  const now = Date.now();
  if(state.lastKeyTs){ state.rhythmLog.push(now-state.lastKeyTs); }
  state.lastKeyTs = now;

  let inputChar = e.key === "Enter" ? "\n" : (e.key === "Tab" ? "\t" : e.key);
  const idx = state.typed.length;

  if(idx < state.text.length){
    const expected = state.text[idx];
    const isCorrect = inputChar === expected || (inputChar==="\n" && expected==="\n");
    state.typed.push(inputChar);
    const span = textDisplay.children[idx];
    if(isCorrect){
      span.classList.add("correct");
      state.correctCount++;
      state.currentStreak++;
      state.bestStreak = Math.max(state.bestStreak, state.currentStreak);
      beep(880, 0.03, 0.02);
    } else {
      span.classList.add("incorrect");
      state.incorrectCount++;
      state.mistakeEvents++;
      state.currentStreak = 0;
      state.errorLog[expected] = (state.errorLog[expected]||0)+1;
      beep(220, 0.08, 0.035);
    }
  } else {
    // extra characters (only relevant for word/quote/custom modes)
    state.extra.push(inputChar);
    state.mistakeEvents++;
    beep(220, 0.08, 0.035);
  }

  updateCurrentCursor();
  updateFocusVisibility();
  updateLiveStats();

  const doneByLength = state.typed.length >= state.text.length && state.extra.length===0 && state.mode !== "time" && state.mode !== "zen";
  if(doneByLength){
    finishSession();
  }
}

function computeElapsedSeconds(){
  if(!state.startTs) return 0;
  const endTs = state.paused ? state.pausedAt : Date.now();
  return Math.max(0.001, (endTs - state.startTs - state.totalPausedMs)/1000);
}

function computeStats(){
  const elapsed = computeElapsedSeconds();
  const minutes = elapsed/60;
  const correct = state.correctCount;
  const incorrect = state.incorrectCount;
  const typedTotal = correct + incorrect + state.extra.length;
  // Standard: WPM based on correct chars / 5, net of errors
  const grossWords = typedTotal/5;
  const netWords = Math.max(0, (correct - incorrect)/5);
  const rawWpm = minutes > 0 ? grossWords/minutes : 0;
  const wpm = minutes > 0 ? netWords/minutes : 0;
  const cpm = minutes > 0 ? (correct)/minutes : 0;
  const accuracy = typedTotal>0 ? (correct/typedTotal)*100 : 100;
  // clamp to sane bounds
  return {
    elapsed,
    wpm: clampNum(wpm, 0, 400),
    rawWpm: clampNum(rawWpm, 0, 400),
    cpm: clampNum(cpm, 0, 2000),
    accuracy: clampNum(accuracy, 0, 100)
  };
}
function clampNum(v,min,max){ if(!isFinite(v)||isNaN(v)) return 0; return Math.max(min, Math.min(max, v)); }

function updateLiveStats(){
  const st = computeStats();
  document.getElementById("s_wpm").textContent = Math.round(st.wpm);
  document.getElementById("s_raw").textContent = Math.round(st.rawWpm);
  document.getElementById("s_cpm").textContent = Math.round(st.cpm);
  document.getElementById("s_acc").textContent = st.accuracy.toFixed(0)+"%";
  document.getElementById("s_time").textContent = st.elapsed.toFixed(0)+"s";
  document.getElementById("s_mistakes").textContent = state.mistakeEvents;
  document.getElementById("s_streak").textContent = state.currentStreak;

  const total = state.text.length;
  const done = Math.min(state.typed.length, total);
  const pct = total>0 ? (done/total)*100 : 0;
  document.getElementById("s_pct").textContent = pct.toFixed(0)+"%";
  document.getElementById("progressBar").style.width = pct+"%";

  const remainEl = document.getElementById("s_remain");
  const remainLbl = document.getElementById("s_remainLbl");
  if(state.mode === "time"){
    remainLbl.textContent = "Time Left";
    remainEl.textContent = Math.max(0, Math.ceil(state.timeOption - st.elapsed))+"s";
  } else if(state.mode === "zen"){
    remainLbl.textContent = "Mode";
    remainEl.textContent = "∞";
  } else {
    remainLbl.textContent = "Words Left";
    const wordsTotal = state.text.split(" ").length;
    const wordsDone = state.text.slice(0,done).split(" ").length;
    remainEl.textContent = Math.max(0, wordsTotal-wordsDone);
  }

  // record wpm history every ~1s
  const lastT = state.wpmHistory.length ? state.wpmHistory[state.wpmHistory.length-1].t : -1;
  if(Math.floor(st.elapsed) !== lastT){
    state.wpmHistory.push({t:Math.floor(st.elapsed), wpm: st.wpm, raw: st.rawWpm, acc: st.accuracy});
  }
}

/* =====================================================================
   FINISH + ANALYTICS
   ===================================================================== */
function finishSession(){
  clearInterval(state.timerHandle);
  state.running = false;
  state.finished = true;
  document.getElementById("selectorPanel").style.pointerEvents = "auto";
  document.getElementById("selectorPanel").style.opacity = "1";
  const st = computeStats();
  const missed = Math.max(0, state.text.length - state.typed.length);
  state.missedCount = missed;
  beep(990,0.12,0.05);
  setTimeout(()=>beep(1320,0.16,0.05), 90);

  const consistency = computeConsistency();
  const session = {
    date: new Date().toISOString(),
    category: state.category,
    mode: state.mode,
    wpm: Math.round(st.wpm),
    rawWpm: Math.round(st.rawWpm),
    accuracy: +st.accuracy.toFixed(1),
    consistency: +consistency.toFixed(1),
    duration: +st.elapsed.toFixed(1),
    correct: state.correctCount,
    incorrect: state.incorrectCount,
    extra: state.extra.length,
    missed: missed,
    mistakes: state.mistakeEvents,
    bestStreak: state.bestStreak,
    detail: (state.mode==="programming"?state.progLang:state.category)+" / "+state.mode
  };

  const history = loadHistory();
  history.push(session);
  saveHistory(history);

  renderResults(session, history);
  document.getElementById("results").classList.add("show");
  document.getElementById("historyPanel").classList.remove("show");
}

function computeConsistency(){
  const speeds = state.wpmHistory.map(h=>h.wpm).filter(v=>v>0);
  if(speeds.length < 2) return 100;
  const mean = speeds.reduce((a,b)=>a+b,0)/speeds.length;
  const variance = speeds.reduce((a,b)=>a+(b-mean)*(b-mean),0)/speeds.length;
  const sd = Math.sqrt(variance);
  const cv = mean>0 ? sd/mean : 0;
  return clampNum(100 - cv*100, 0, 100);
}

function loadHistory(){
  try{ return JSON.parse(localStorage.getItem("tss_history")) || []; }catch(e){ return []; }
}
function saveHistory(h){
  localStorage.setItem("tss_history", JSON.stringify(h.slice(-200)));
}

function getPersonalBests(history){
  const best = {wpm:0, accuracy:0, streak:0};
  history.forEach(s=>{
    if(s.wpm > best.wpm) best.wpm = s.wpm;
    if(s.accuracy > best.accuracy) best.accuracy = s.accuracy;
    if(s.bestStreak > best.streak) best.streak = s.bestStreak;
  });
  return best;
}

function estimatePercentile(wpm){
  // rough normal-ish distribution centered at 45 wpm, sd 18
  const mean=45, sd=18;
  const z = (wpm-mean)/sd;
  const p = 0.5*(1+erf(z/Math.sqrt(2)));
  return clampNum(p*100, 1, 99.5);
}
function erf(x){
  const sign = x<0?-1:1; x=Math.abs(x);
  const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;
  const t=1/(1+p*x);
  const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);
  return sign*y;
}

function computeBadges(session, history){
  const badges = [];
  if(session.wpm >= 80) badges.push("⚡ Speed Demon");
  if(session.accuracy >= 99) badges.push("🎯 Precision");
  if(session.accuracy === 100) badges.push("💯 Flawless");
  if(session.consistency >= 85) badges.push("🌊 Steady Hands");
  if(session.bestStreak >= 50) badges.push("🔥 Streak Master");
  if(history.length === 1) badges.push("🌱 First Session");
  if(history.length >= 10) badges.push("📈 Dedicated");
  if(history.length >= 50) badges.push("🏆 Veteran");
  const pb = getPersonalBests(history.slice(0,-1));
  if(session.wpm > pb.wpm && history.length>1) badges.push("🥇 New Best WPM");
  if(badges.length===0) badges.push("✅ Session Complete");
  return badges;
}

function buildSummary(session, history){
  const parts = [];
  if(session.accuracy >= 97) parts.push("Your accuracy was excellent — very few slips.");
  else if(session.accuracy >= 90) parts.push("Solid accuracy, with some room to tighten up precision.");
  else parts.push("Accuracy dipped this round — slowing down slightly could help.");

  if(session.consistency >= 80) parts.push("Your pace stayed remarkably steady throughout.");
  else parts.push("Your speed varied noticeably across the session — try to find a steady rhythm.");

  const topErrors = Object.entries(state.errorLog).sort((a,b)=>b[1]-a[1]).slice(0,3).map(e=>`"${e[0]==="\n"?"↵":e[0]}"`);
  if(topErrors.length){
    parts.push(`Most mistyped characters: ${topErrors.join(", ")}.`);
  }

  const pb = getPersonalBests(history);
  if(session.wpm >= pb.wpm){
    parts.push(`This is a new personal best at <b>${session.wpm} WPM</b>.`);
  } else {
    parts.push(`Your personal best remains <b>${pb.wpm} WPM</b> — ${pb.wpm-session.wpm} away.`);
  }

  return parts.join(" ");
}

/* ---- Canvas graphs (no external libs) ---- */
function drawLineGraph(canvas, series, opts){
  const ctx = canvas.getContext("2d");
  const dpr = window.devicePixelRatio || 1;
  const w = canvas.clientWidth, h = canvas.clientHeight;
  canvas.width = w*dpr; canvas.height = h*dpr;
  ctx.scale(dpr,dpr);
  ctx.clearRect(0,0,w,h);
  const pad = 24;
  const maxV = Math.max(1, ...series.map(p=>p.v)) * 1.15;
  const minV = 0;
  const stepX = series.length>1 ? (w-pad*2)/(series.length-1) : 0;

  ctx.strokeStyle = opts.grid || "rgba(255,255,255,0.06)";
  ctx.lineWidth = 1;
  for(let i=0;i<=4;i++){
    const y = pad + (h-pad*2)*(i/4);
    ctx.beginPath(); ctx.moveTo(pad,y); ctx.lineTo(w-pad,y); ctx.stroke();
  }

  if(series.length < 2){ return; }
  ctx.beginPath();
  series.forEach((p,i)=>{
    const x = pad + i*stepX;
    const y = h-pad - ((p.v-minV)/(maxV-minV))*(h-pad*2);
    if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
  });
  ctx.strokeStyle = opts.color || "#d4a24c";
  ctx.lineWidth = 2.5;
  ctx.lineJoin = "round";
  ctx.stroke();

  // fill under
  ctx.lineTo(pad+(series.length-1)*stepX, h-pad);
  ctx.lineTo(pad, h-pad);
  ctx.closePath();
  const grad = ctx.createLinearGradient(0,0,0,h);
  grad.addColorStop(0, (opts.color||"#d4a24c")+"33");
  grad.addColorStop(1, (opts.color||"#d4a24c")+"00");
  ctx.fillStyle = grad;
  ctx.fill();
}

function renderResults(session, history){
  const root = document.getElementById("results");
  root.innerHTML = "";
  const pb = getPersonalBests(history);
  const percentile = estimatePercentile(session.wpm);
  const badges = computeBadges(session, history);

  // Hero stats
  const hero = document.createElement("div");
  hero.className = "hero-stats";
  const heroData = [
    ["WPM", session.wpm, session.wpm>=pb.wpm ? "New personal best" : "PB "+pb.wpm],
    ["Raw WPM", session.rawWpm, "before error correction"],
    ["Accuracy", session.accuracy+"%", ""],
    ["Consistency", session.consistency+"%", ""],
    ["Percentile", "Top "+(100-percentile).toFixed(0)+"%", "est. among typists"],
  ];
  heroData.forEach(([lbl,val,sub])=>{
    const card = document.createElement("div");
    card.className = "hero-card";
    card.innerHTML = `<div class="big">${val}</div><div class="lbl">${lbl}</div><div class="sub">${sub}</div>`;
    hero.appendChild(card);
  });
  root.appendChild(hero);

  const grid = document.createElement("div");
  grid.className = "panel-grid";

  // WPM graph panel
  const p1 = document.createElement("div");
  p1.className = "panel";
  p1.innerHTML = `<h3>WPM Progress</h3><canvas id="wpmCanvas" height="160"></canvas>`;
  grid.appendChild(p1);

  // Char breakdown + badges panel
  const p2 = document.createElement("div");
  p2.className = "panel";
  p2.innerHTML = `
    <h3>Character Breakdown</h3>
    <div class="charbreak">
      <div class="cb correct">Correct <span class="n">${session.correct}</span></div>
      <div class="cb incorrect">Incorrect <span class="n">${session.incorrect}</span></div>
      <div class="cb extra">Extra <span class="n">${session.extra}</span></div>
      <div class="cb missed">Missed <span class="n">${session.missed}</span></div>
    </div>
    <h3 style="margin-top:18px;">Achievements</h3>
    <div class="badgerow">${badges.map(b=>`<div class="badge">${b}</div>`).join("")}</div>
  `;
  grid.appendChild(p2);
  root.appendChild(grid);

  const grid2 = document.createElement("div");
  grid2.className = "panel-grid";

  // Accuracy graph
  const p3 = document.createElement("div");
  p3.className = "panel";
  p3.innerHTML = `<h3>Accuracy Over Time</h3><canvas id="accCanvas" height="160"></canvas>`;
  grid2.appendChild(p3);

  // Error heatmap
  const p4 = document.createElement("div");
  p4.className = "panel";
  const errEntries = Object.entries(state.errorLog).sort((a,b)=>b[1]-a[1]);
  const maxErr = errEntries.length ? errEntries[0][1] : 1;
  p4.innerHTML = `<h3>Error Heatmap</h3><div class="heatmap" id="heatmapWrap"></div>`;
  grid2.appendChild(p4);
  root.appendChild(grid2);

  // Summary panel
  const p5 = document.createElement("div");
  p5.className = "panel";
  p5.innerHTML = `<h3>Performance Summary</h3><div class="summary-text">${buildSummary(session, history)}</div>`;
  root.appendChild(p5);

  // Action buttons
  const actions = document.createElement("div");
  actions.className = "stage-actions";
  actions.innerHTML = `
    <button class="btn primary" id="tryAgainBtn">↻ Try Again</button>
    <button class="btn" id="viewHistoryBtn">📊 View History</button>
  `;
  root.appendChild(actions);

  requestAnimationFrame(()=>{
    drawLineGraph(document.getElementById("wpmCanvas"),
      state.wpmHistory.map(h=>({v:h.wpm})), {color: getComputedStyle(document.body).getPropertyValue('--accent').trim() || "#d4a24c"});
    drawLineGraph(document.getElementById("accCanvas"),
      state.wpmHistory.map(h=>({v:h.acc})), {color:"#7fb069"});

    const wrap = document.getElementById("heatmapWrap");
    if(errEntries.length===0){
      wrap.innerHTML = '<div style="color:var(--paper-dim); font-size:13px;">No mistakes recorded — clean run!</div>';
    } else {
      errEntries.slice(0,24).forEach(([ch,count])=>{
        const intensity = count/maxErr;
        const cell = document.createElement("div");
        cell.className = "heatcell";
        const col = `color-mix(in srgb, var(--bad) ${Math.round(30+intensity*70)}%, var(--ink-2))`;
        cell.style.background = col;
        cell.textContent = ch==="\n" ? "↵" : ch;
        cell.title = count+" mistakes";
        wrap.appendChild(cell);
      });
    }
  });

  document.getElementById("tryAgainBtn").addEventListener("click", ()=> resetSession(true));
  document.getElementById("viewHistoryBtn").addEventListener("click", ()=>{
    root.classList.remove("show");
    document.getElementById("historyPanel").classList.add("show");
    renderHistoryTable();
  });
}

function renderHistoryTable(){
  const history = loadHistory().slice().reverse();
  const table = document.getElementById("historyTable");
  if(history.length === 0){
    table.innerHTML = `<tr><td style="padding:20px; color:var(--paper-dim);">No sessions yet — complete a typing test to see it here.</td></tr>`;
    return;
  }
  const pb = getPersonalBests(history);
  let html = `<tr><th>Date</th><th>Mode</th><th>WPM</th><th>Raw</th><th>Accuracy</th><th>Consistency</th><th>Duration</th></tr>`;
  history.slice(0,30).forEach(s=>{
    const d = new Date(s.date);
    const isPB = s.wpm === pb.wpm;
    html += `<tr><td>${d.toLocaleDateString()} ${d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</td>
      <td>${s.detail}</td>
      <td>${s.wpm}${isPB?'<span class="pb-tag">PB</span>':''}</td>
      <td>${s.rawWpm}</td>
      <td>${s.accuracy}%</td>
      <td>${s.consistency}%</td>
      <td>${s.duration}s</td></tr>`;
  });
  table.innerHTML = html;
}

/* =====================================================================
   GLOBAL KEYBOARD SHORTCUTS
   ===================================================================== */
document.addEventListener("keydown", e=>{
  if(e.ctrlKey && e.key.toLowerCase()==="m"){ e.preventDefault(); toggleSound(); return; }
  if(e.ctrlKey && e.key.toLowerCase()==="d"){ e.preventDefault(); toggleTheme(); return; }
  if(e.ctrlKey && /^[1-6]$/.test(e.key)){
    e.preventDefault();
    const idx = +e.key - 1;
    if(CATEGORIES[idx]) setCategory(CATEGORIES[idx].id);
    return;
  }
  if(document.activeElement !== hiddenInput && e.key==="Enter" && !state.running){
    if(document.activeElement && document.activeElement.tagName==="TEXTAREA") return;
    startSession();
  }
});

document.getElementById("restartBtn").addEventListener("click", ()=> resetSession(true));
document.getElementById("pauseBtn").addEventListener("click", togglePause);
document.getElementById("newTextBtn").addEventListener("click", ()=>{ state.text = generateText(); renderText(); resetSessionSoft(); });
function resetSessionSoft(){
  state.typed=[]; state.extra=[]; state.correctCount=0; state.incorrectCount=0;
  state.currentStreak=0; state.mistakeEvents=0; state.wpmHistory=[]; state.errorLog={};
  updateCurrentCursor();
}

document.getElementById("customInput").addEventListener("input", ()=>{
  if(state.mode==="custom" && !state.running){ state.text = generateText(); renderText(); }
});

/* Stage focus mode styling */
function applyFocusModeClass(){
  stageEl.classList.toggle("focus-mode", state.mode==="focus");
}
const origSetMode = setMode;
setMode = function(id){ origSetMode(id); applyFocusModeClass(); };
[...modeRow.children].forEach(chip=>{
  chip.addEventListener("click", applyFocusModeClass);
});

/* =====================================================================
   INIT
   ===================================================================== */
resetSession(true);
applyFocusModeClass();

})();
</script>
