<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Typing Speed Studio</title>
<style>
:root{
  --ink-0:#12141c;
  --ink-1:#181b26;
  --ink-2:#1f2330;
  --ink-3:#2a2f40;
  --hairline:rgba(232,230,225,0.08);
  --paper:#e8e6e1;
  --paper-dim:#9a9ba3;
  --brass:#d4a24c;
  --brass-dim:#8a743f;
  --good:#7fb069;
  --bad:#e0555a;
  --accent:var(--brass);
  --accent-dim:var(--brass-dim);
  --font-ui: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", Roboto, sans-serif;
  --font-mono: "SFMono-Regular", ui-monospace, "Cascadia Code", Consolas, "Liberation Mono", Menlo, monospace;
  --radius:10px;
  --shadow: 0 20px 60px rgba(0,0,0,0.35);
}
[data-theme="light"]{
  --ink-0:#f3f1ea;
  --ink-1:#ffffff;
  --ink-2:#ece9e0;
  --ink-3:#ddd8ca;
  --hairline:rgba(20,20,20,0.08);
  --paper:#1c1c1a;
  --paper-dim:#6b6a63;
  --shadow: 0 20px 60px rgba(30,25,10,0.12);
}
[data-accent="clay"]{ --accent:#c1694f; --accent-dim:#8a4a37; }
[data-accent="teal"]{ --accent:#5aa9a3; --accent-dim:#3d7570; }
[data-accent="violet"]{ --accent:#9d7fd6; --accent-dim:#6c569a; }
[data-accent="brass"]{ --accent:#d4a24c; --accent-dim:#8a743f; }

*{box-sizing:border-box; margin:0; padding:0;}
html,body{height:100%;}
body{
  background:
    radial-gradient(1200px 700px at 15% -10%, color-mix(in srgb, var(--accent) 7%, transparent), transparent 60%),
    var(--ink-0);
  color:var(--paper);
  font-family:var(--font-ui);
  min-height:100vh;
  transition:background .4s ease, color .4s ease;
  overflow-x:hidden;
}
::selection{ background:var(--accent); color:var(--ink-0); }

.app{ max-width:1180px; margin:0 auto; padding:28px 24px 80px; }

/* ---------- Top bar ---------- */
.topbar{
  display:flex; align-items:center; justify-content:space-between;
  gap:16px; flex-wrap:wrap; margin-bottom:26px;
}
.brand{ display:flex; align-items:baseline; gap:10px; }
.brand .mark{
  font-family:var(--font-mono); font-weight:700; font-size:13px;
  letter-spacing:.14em; color:var(--ink-0); background:var(--accent);
  padding:4px 8px; border-radius:5px;
}
.brand h1{
  font-size:20px; font-weight:600; letter-spacing:-0.01em; color:var(--paper);
}
.brand .sub{ font-size:12px; color:var(--paper-dim); letter-spacing:.02em; }

.topcontrols{ display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
.iconbtn{
  width:38px; height:38px; border-radius:9px; border:1px solid var(--hairline);
  background:var(--ink-1); color:var(--paper-dim); cursor:pointer;
  display:flex; align-items:center; justify-content:center; font-size:15px;
  transition:all .15s ease;
}
.iconbtn:hover{ color:var(--paper); border-color:var(--accent); transform:translateY(-1px); }
.iconbtn.active{ color:var(--accent); border-color:var(--accent); }

.popover{
  position:absolute; top:56px; right:24px; background:var(--ink-1);
  border:1px solid var(--hairline); border-radius:var(--radius); padding:16px;
  box-shadow:var(--shadow); z-index:50; min-width:220px; display:none;
}
.popover.open{ display:block; animation:pop-in .18s ease; }
@keyframes pop-in{ from{opacity:0; transform:translateY(-6px);} to{opacity:1; transform:translateY(0);} }
.popover h4{ font-size:11px; text-transform:uppercase; letter-spacing:.1em; color:var(--paper-dim); margin-bottom:10px; }
.swatchrow{ display:flex; gap:8px; margin-bottom:14px; }
.swatch{ width:26px; height:26px; border-radius:50%; cursor:pointer; border:2px solid transparent; }
.swatch.active{ border-color:var(--paper); }
.rangewrap{ display:flex; align-items:center; gap:10px; font-size:13px; color:var(--paper-dim); }
.rangewrap input[type=range]{ flex:1; accent-color:var(--accent); }

/* ---------- Category + Mode selectors ---------- */
.selectors{ display:flex; flex-direction:column; gap:14px; margin-bottom:22px; }
.chiprow{ display:flex; flex-wrap:wrap; gap:8px; }
.chip{
  padding:7px 14px; border-radius:20px; border:1px solid var(--hairline);
  background:var(--ink-1); color:var(--paper-dim); font-size:13px; cursor:pointer;
  transition:all .15s ease; font-weight:500; white-space:nowrap;
}
.chip:hover{ color:var(--paper); border-color:var(--accent-dim); }
.chip.active{ background:var(--accent); color:var(--ink-0); border-color:var(--accent); font-weight:600; }

.subbar{ display:flex; align-items:center; gap:18px; flex-wrap:wrap; }
.subgroup{ display:flex; align-items:center; gap:8px; }
.subgroup .lbl{ font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--paper-dim); margin-right:4px;}
.pill{
  padding:5px 11px; border-radius:7px; font-size:13px; cursor:pointer; color:var(--paper-dim);
  border:1px solid transparent; font-family:var(--font-mono); transition:all .15s ease;
}
.pill:hover{ color:var(--paper); }
.pill.active{ color:var(--accent); border-color:var(--accent-dim); background:color-mix(in srgb, var(--accent) 12%, transparent); }

select.dropdown{
  background:var(--ink-1); color:var(--paper); border:1px solid var(--hairline);
  border-radius:7px; padding:6px 10px; font-size:13px; font-family:var(--font-mono); cursor:pointer;
}
textarea#customInput{
  width:100%; min-height:80px; background:var(--ink-1); color:var(--paper);
  border:1px solid var(--hairline); border-radius:8px; padding:10px 12px;
  font-family:var(--font-mono); font-size:14px; resize:vertical; display:none;
}
textarea#customInput.show{ display:block; }

/* ---------- Live Stats Bar ---------- */
.statsbar{
  display:flex; gap:28px; align-items:center; justify-content:center;
  padding:14px 10px; margin-bottom:18px; flex-wrap:wrap;
  opacity:0; height:0; overflow:hidden; transition:opacity .3s ease;
}
.statsbar.show{ opacity:1; height:auto; overflow:visible; }
.statitem{ text-align:center; min-width:64px; }
.statitem .val{ font-family:var(--font-mono); font-size:26px; font-weight:700; color:var(--accent); line-height:1; }
.statitem .lbl{ font-size:10px; text-transform:uppercase; letter-spacing:.09em; color:var(--paper-dim); margin-top:4px; }

.progresswrap{ height:3px; background:var(--ink-2); border-radius:2px; margin-bottom:26px; overflow:hidden; }
.progressbar{ height:100%; width:0%; background:linear-gradient(90deg, var(--accent-dim), var(--accent)); transition:width .15s linear; }

/* ---------- Typing Stage ---------- */
.stage{
  position:relative; background:var(--ink-1); border:1px solid var(--hairline);
  border-radius:16px; padding:40px 36px; box-shadow:var(--shadow);
  min-height:220px; display:flex; align-items:center; justify-content:center;
}
.stage.focus-mode .textdisplay{ }
.textdisplay{
  font-family:var(--font-mono); font-size:22px; line-height:1.9; letter-spacing:.01em;
  color:var(--paper-dim); max-width:900px; width:100%;
  user-select:none; position:relative; white-space:pre-wrap; word-break:break-word;
}
[data-monofont="serif"] .textdisplay{ font-family: Georgia, "Times New Roman", serif; }
/* Untyped / remaining text: always rendered, always visible */
.textdisplay .ch{ position:relative; transition:color .1s ease, background .1s ease; border-radius:2px; color:var(--paper-dim); opacity:1; display:inline; }
.textdisplay .ch.correct{ color:var(--good); }
.textdisplay .ch.incorrect{ color:var(--bad); background:color-mix(in srgb, var(--bad) 16%, transparent); }
.textdisplay .ch.extra{ color:var(--bad); text-decoration:underline; opacity:.7; }
.textdisplay .ch.current{
  color:var(--paper);
  background:color-mix(in srgb, var(--accent) 28%, transparent);
  box-shadow:0 0 0 1px var(--accent);
}
.textdisplay .ch.current::before{
  content:''; position:absolute; left:-1px; top:2px; bottom:2px; width:2px;
  background:var(--accent); animation:blink 1s step-end infinite;
}
@keyframes blink{ 50%{ opacity:0.15; } }
.textdisplay .ln-hidden{ display:none; }
.stage-overlay{
  position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
  flex-direction:column; gap:14px; background:color-mix(in srgb, var(--ink-1) 88%, transparent);
  backdrop-filter:blur(3px); border-radius:16px; z-index:5;
}
.stage-overlay.hidden{ display:none; }
.overlay-title{ font-size:19px; font-weight:600; color:var(--paper); }
.overlay-sub{ font-size:13px; color:var(--paper-dim); }
#hiddenInput{ position:absolute; opacity:0; pointer-events:none; width:1px; height:1px; }

.stage-actions{ display:flex; gap:10px; justify-content:center; margin-top:20px; flex-wrap:wrap; }
.btn{
  padding:10px 20px; border-radius:9px; border:1px solid var(--hairline);
  background:var(--ink-1); color:var(--paper); font-size:13px; cursor:pointer;
  font-weight:600; display:flex; align-items:center; gap:7px; transition:all .15s ease;
}
.btn:hover{ border-color:var(--accent); transform:translateY(-1px); }
.btn.primary{ background:var(--accent); color:var(--ink-0); border-color:var(--accent); }
.btn .kbd{ font-family:var(--font-mono); font-size:10px; background:rgba(0,0,0,0.25); padding:2px 5px; border-radius:4px; opacity:.8;}
[data-theme="light"] .btn .kbd{ background:rgba(0,0,0,0.08); }

/* ---------- Results / Dashboard ---------- */
.results{ display:none; flex-direction:column; gap:20px; animation:fade-up .4s ease; }
.results.show{ display:flex; }
@keyframes fade-up{ from{opacity:0; transform:translateY(14px);} to{opacity:1; transform:translateY(0);} }

.hero-stats{ display:grid; grid-template-columns:repeat(5,1fr); gap:14px; }
@media(max-width:800px){ .hero-stats{ grid-template-columns:repeat(2,1fr);} }
.hero-card{
  background:var(--ink-1); border:1px solid var(--hairline); border-radius:14px;
  padding:20px 18px; text-align:center;
}
.hero-card .big{ font-family:var(--font-mono); font-size:36px; font-weight:700; color:var(--accent); line-height:1;}
.hero-card .lbl{ font-size:11px; text-transform:uppercase; color:var(--paper-dim); letter-spacing:.08em; margin-top:8px;}
.hero-card .sub{ font-size:11px; color:var(--paper-dim); margin-top:2px; }

.panel-grid{ display:grid; grid-template-columns:1.3fr 1fr; gap:16px; }
@media(max-width:900px){ .panel-grid{ grid-template-columns:1fr; } }
.panel{
  background:var(--ink-1); border:1px solid var(--hairline); border-radius:14px;
  padding:20px;
}
.panel h3{ font-size:13px; text-transform:uppercase; letter-spacing:.08em; color:var(--paper-dim); margin-bottom:14px; }
canvas{ width:100%; display:block; }

.charbreak{ display:flex; gap:16px; flex-wrap:wrap; margin-top:8px;}
.charbreak .cb{ font-family:var(--font-mono); font-size:14px; }
.cb .n{ font-weight:700; }
.cb.correct .n{ color:var(--good); }
.cb.incorrect .n{ color:var(--bad); }
.cb.extra .n{ color:var(--accent); }
.cb.missed .n{ color:var(--paper-dim); }

.heatmap{ display:flex; flex-wrap:wrap; gap:4px; margin-top:10px; }
.heatcell{
  width:26px; height:26px; border-radius:5px; display:flex; align-items:center; justify-content:center;
  font-family:var(--font-mono); font-size:10px; font-weight:700; color:var(--ink-0);
}

.badgerow{ display:flex; flex-wrap:wrap; gap:10px; margin-top:6px; }
.badge{
  display:flex; align-items:center; gap:6px; padding:7px 12px; border-radius:20px;
  background:color-mix(in srgb, var(--accent) 14%, transparent); border:1px solid var(--accent-dim);
  font-size:12px; font-weight:600; color:var(--accent);
}

.summary-text{ font-size:14px; line-height:1.7; color:var(--paper); }
.summary-text b{ color:var(--accent); }

.history-table{ width:100%; border-collapse:collapse; font-size:13px; }
.history-table th{ text-align:left; color:var(--paper-dim); font-weight:600; padding:8px 10px; border-bottom:1px solid var(--hairline); font-size:11px; text-transform:uppercase; letter-spacing:.05em;}
.history-table td{ padding:9px 10px; border-bottom:1px solid var(--hairline); font-family:var(--font-mono); }
.history-table tr:hover td{ background:var(--ink-2); }
.pb-tag{ font-size:10px; background:var(--accent); color:var(--ink-0); padding:1px 6px; border-radius:6px; margin-left:6px; font-weight:700;}

footer.credits{ text-align:center; margin-top:40px; font-size:12px; color:var(--paper-dim); }
footer.credits kbd{ font-family:var(--font-mono); background:var(--ink-2); padding:2px 6px; border-radius:4px; }

@media (max-width:640px){
  .textdisplay{ font-size:18px; line-height:1.7; }
  .hero-stats{ grid-template-columns:repeat(2,1fr); }
  .stage{ padding:26px 18px; }
}
@media (prefers-reduced-motion: reduce){
  *{ animation:none !important; transition:none !important; }
}
</style>
</head>
<body data-theme="dark" data-accent="brass" data-monofont="mono">
<div class="app">

  <div class="topbar">
    <div class="brand">
      <span class="mark">TSS</span>
      <div>
        <h1>Typing Speed Studio</h1>
        <div class="sub">Adaptive practice across seven disciplines</div>
      </div>
    </div>
    <div class="topcontrols" style="position:relative;">
      <button class="iconbtn" id="soundBtn" title="Toggle sound (Ctrl+M)">🔊</button>
      <button class="iconbtn" id="themeBtn" title="Toggle theme (Ctrl+D)">🌙</button>
      <button class="iconbtn" id="settingsBtn" title="Appearance">🎨</button>
      <button class="iconbtn" id="historyBtn" title="Session history">📊</button>
      <div class="popover" id="settingsPop">
        <h4>Accent color</h4>
        <div class="swatchrow" id="accentRow"></div>
        <h4>Font size</h4>
        <div class="rangewrap">
          <span>A</span><input type="range" id="fontSizeRange" min="14" max="32" value="22"><span>A</span>
        </div>
      </div>
    </div>
  </div>

  <div class="selectors" id="selectorPanel">
    <div>
      <div class="chiprow" id="categoryRow"></div>
    </div>
    <div class="subbar">
      <div class="subgroup">
        <span class="lbl">Mode</span>
        <div class="chiprow" id="modeRow"></div>
      </div>
    </div>
    <div class="subbar" id="modeOptionsRow"></div>
    <textarea id="customInput" placeholder="Paste or type your own practice text here, then press Start..."></textarea>
  </div>

  <div class="statsbar" id="liveStats">
    <div class="statitem"><div class="val" id="s_wpm">0</div><div class="lbl">WPM</div></div>
    <div class="statitem"><div class="val" id="s_raw">0</div><div class="lbl">Raw WPM</div></div>
    <div class="statitem"><div class="val" id="s_cpm">0</div><div class="lbl">CPM</div></div>
    <div class="statitem"><div class="val" id="s_acc">100%</div><div class="lbl">Accuracy</div></div>
    <div class="statitem"><div class="val" id="s_time">0s</div><div class="lbl">Elapsed</div></div>
    <div class="statitem"><div class="val" id="s_mistakes">0</div><div class="lbl">Mistakes</div></div>
    <div class="statitem"><div class="val" id="s_streak">0</div><div class="lbl">Streak</div></div>
    <div class="statitem"><div class="val" id="s_pct">0%</div><div class="lbl">Complete</div></div>
    <div class="statitem"><div class="val" id="s_remain">-</div><div class="lbl" id="s_remainLbl">Remaining</div></div>
  </div>
  <div class="progresswrap"><div class="progressbar" id="progressBar"></div></div>

  <div class="stage" id="stage">
    <input id="hiddenInput" autocomplete="off" autocapitalize="off" spellcheck="false">
    <div class="textdisplay" id="textDisplay"></div>
    <div class="stage-overlay" id="startOverlay">
      <div class="overlay-title">Click here or press <span style="color:var(--accent)">Enter</span> to begin</div>
      <div class="overlay-sub" id="overlaySub">General · Time · 30s</div>
    </div>
    <div class="stage-overlay hidden" id="pauseOverlay">
      <div class="overlay-title">Paused</div>
      <div class="overlay-sub">Press Esc to resume</div>
    </div>
  </div>

  <div class="stage-actions">
    <button class="btn primary" id="restartBtn">↻ Restart <span class="kbd">Ctrl+Enter</span></button>
    <button class="btn" id="pauseBtn">⏸ Pause <span class="kbd">Esc</span></button>
    <button class="btn" id="newTextBtn">🔀 New Passage</button>
  </div>

  <div class="results" id="results"></div>

  <div class="results" id="historyPanel">
    <div class="panel">
      <h3>Session History</h3>
      <div style="overflow-x:auto;">
        <table class="history-table" id="historyTable"></table>
      </div>
    </div>
  </div>

  <footer class="credits">
    Shortcuts: <kbd>Enter</kbd> start · <kbd>Ctrl+Enter</kbd> restart · <kbd>Esc</kbd> pause/resume · <kbd>Ctrl+M</kbd> mute · <kbd>Ctrl+D</kbd> theme · <kbd>Ctrl+1..7</kbd> category
  </footer>
</div>

<script>
(function(){
"use strict";

/* =====================================================================
   CONTENT LIBRARY — passages per category, dynamically composed
   ===================================================================== */
const WORDBANK = {
  general: "the quick brown fox jumps over lazy dog while morning light spills across quiet fields and a gentle breeze moves through tall grass every traveler pauses here to rest before continuing along the winding path toward distant hills where rivers bend and villages sleep under a pale autumn sky the world keeps turning slowly stories unfold in small moments kindness matters more than speed patience builds character time reveals truth simple habits create lasting change".split(" "),
  academic: "hypothesis empirical variable correlation methodology analysis framework paradigm synthesis discourse cognition inference literature theoretical qualitative quantitative peer reviewed citation abstract conclusion evidence significant sample population statistical distribution variance regression causation phenomenon interdisciplinary scholarship rigorous replicate validity reliability construct baseline longitudinal ethics institutional review board".split(" "),
  business: "quarterly revenue projections indicate steady growth across all regional markets stakeholders reviewed the proposal and approved additional budget for the upcoming fiscal year our team will finalize the merger agreement pending board approval please circulate the updated deck before the client presentation on Thursday morning leadership emphasized transparency accountability and long term strategic alignment across every department".split(" "),
  medical: "patient presented with elevated blood pressure and mild tachycardia physician recommended immediate diagnostic imaging to rule out underlying cardiac complications nursing staff administered prescribed medication according to protocol laboratory results confirmed normal glucose levels and stable renal function follow up appointment scheduled to monitor symptoms and adjust treatment plan accordingly clinical assessment continues".split(" "),
  legal: "the plaintiff hereby alleges breach of contract pursuant to the terms outlined in section four of the aforementioned agreement counsel for the defendant filed a motion to dismiss citing insufficient evidence the court shall render judgment after reviewing all submitted exhibits and testimony jurisdiction remains with the district court pending appeal the parties agree to binding arbitration".split(" "),
  creative: "beneath a sky stitched with fading starlight the old lighthouse keeper watched the tide retreat like a slow held breath he remembered her laughter carried on salt wind and wondered if memory was simply the sea returning what it once borrowed the lantern flickered casting long shadows across weathered stone as silence gathered like dust upon forgotten letters".split(" ")
};

const QUOTES = [
  "The only way to do great work is to love what you do.",
  "In the middle of difficulty lies opportunity.",
  "Simplicity is the ultimate sophistication.",
  "The journey of a thousand miles begins with a single step.",
  "What we think, we become.",
  "Not everything that is faced can be changed, but nothing can be changed until it is faced.",
  "The best way to predict the future is to invent it.",
  "Whether you think you can or you think you can't, you're right.",
  "Success is not final, failure is not fatal: it is the courage to continue that counts.",
  "It always seems impossible until it is done."
];

const CODE_SNIPPETS = {
  javascript: [
"function debounce(fn, delay) {\n  let timer = null;\n  return function(...args) {\n    clearTimeout(timer);\n    timer = setTimeout(() => fn.apply(this, args), delay);\n  };\n}",
"const users = data.filter(u => u.active).map(u => ({ id: u.id, name: u.name }));\nconsole.log(users.length);"
  ],
  python: [
"def fibonacci(n):\n    a, b = 0, 1\n    for _ in range(n):\n        a, b = b, a + b\n    return a\n\nprint(fibonacci(10))",
"class Stack:\n    def __init__(self):\n        self.items = []\n    def push(self, item):\n        self.items.append(item)\n    def pop(self):\n        return self.items.pop()"
  ],
  html: [
"<section class=\"card\">\n  <h2>Welcome</h2>\n  <p>This is a sample paragraph inside a card component.</p>\n  <button type=\"button\">Continue</button>\n</section>"
  ],
  css: [
".button {\n  display: inline-flex;\n  align-items: center;\n  padding: 10px 20px;\n  border-radius: 8px;\n  background: var(--accent);\n  transition: transform 0.2s ease;\n}\n.button:hover {\n  transform: translateY(-2px);\n}"
  ],
  java: [
"public class Calculator {\n    public int add(int a, int b) {\n        return a + b;\n    }\n    public static void main(String[] args) {\n        Calculator c = new Calculator();\n        System.out.println(c.add(4, 5));\n    }\n}"
  ],
  cpp: [
"#include <iostream>\nusing namespace std;\n\nint factorial(int n) {\n    return n <= 1 ? 1 : n * factorial(n - 1);\n}\n\nint main() {\n    cout << factorial(6) << endl;\n    return 0;\n}"
  ],
  sql: [
"SELECT customers.name, SUM(orders.total) AS revenue\nFROM customers\nJOIN orders ON orders.customer_id = customers.id\nWHERE orders.created_at >= '2026-01-01'\nGROUP BY customers.name\nORDER BY revenue DESC\nLIMIT 10;"
  ]
};

/* =====================================================================
   STATE
   ===================================================================== */
const state = {
  category: "general",
  mode: "time",
  timeOption: 30,
  wordOption: 25,
  progLang: "javascript",
  running: false,
  paused: false,
  finished: false,
  startTs: null,
  pausedAt: null,
  totalPausedMs: 0,
  text: "",
  typed: [],       // array of typed chars aligned to text index, or 'extra' entries appended
  extra: [],       // characters typed beyond text length
  correctCount: 0,
  incorrectCount: 0,
  missedCount: 0,
  mistakeEvents: 0,
  currentStreak: 0,
  bestStreak: 0,
  wpmHistory: [],   // {t, wpm, raw}
  errorLog: {},     // char -> count of mistakes
  rhythmLog: [],    // ms between keystrokes
  lastKeyTs: null,
  timerHandle: null,
  soundOn: true,
  theme: "dark",
  accent: "brass",
  fontSize: 22,
};

const AudioCtx = window.AudioContext || window.webkitAudioContext;
let actx = null;
function beep(freq, dur, vol){
  if(!state.soundOn) return;
  try{
    if(!actx) actx = new AudioCtx();
    const o = actx.createOscillator();
    const g = actx.createGain();
    o.frequency.value = freq;
    o.type = "sine";
    g.gain.value = vol || 0.05;
    o.connect(g); g.connect(actx.destination);
    o.start();
    g.gain.exponentialRampToValueAtTime(0.0001, actx.currentTime + (dur||0.05));
    o.stop(actx.currentTime + (dur||0.06));
  }catch(e){}
}

/* =====================================================================
   TEXT GENERATION
   ===================================================================== */
function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

function generateWordText(category, count){
  const bank = WORDBANK[category] || WORDBANK.general;
  let words = [];
  while(words.length < count){
    words = words.concat(shuffle(bank));
  }
  words = words.slice(0, count);
  // Capitalize first word, add periods every ~10-14 words for readability
  let out = [];
  let sinceCap = 0;
  for(let i=0;i<words.length;i++){
    let w = words[i];
    if(i===0 || sinceCap === 0) w = w.charAt(0).toUpperCase()+w.slice(1);
    out.push(w);
    sinceCap++;
    if(sinceCap >= (9 + Math.floor(Math.random()*5)) && i < words.length-1){
      out[out.length-1] += ".";
      sinceCap = 0;
    }
  }
  let joined = out.join(" ");
  if(!/[.!?]$/.test(joined)) joined += ".";
  return joined;
}

function estimateWordsForSeconds(seconds){
  // assume ~45 wpm baseline generation length, generous buffer
  return Math.max(20, Math.round(seconds * 1.1));
}

function generateText(){
  const cat = state.category;
  if(state.mode === "quote"){
    return QUOTES[Math.floor(Math.random()*QUOTES.length)];
  }
  if(state.mode === "programming"){
    const snippets = CODE_SNIPPETS[state.progLang] || CODE_SNIPPETS.javascript;
    return snippets[Math.floor(Math.random()*snippets.length)];
  }
  if(state.mode === "custom"){
    return document.getElementById("customInput").value.trim() || "Type your custom text in the box above, then press Start.";
  }
  if(state.mode === "words"){
    return generateWordText(cat, state.wordOption);
  }
  if(state.mode === "time"){
    return generateWordText(cat, estimateWordsForSeconds(state.timeOption + 20));
  }
  if(state.mode === "zen"){
    return generateWordText(cat, 60);
  }
  if(state.mode === "focus"){
    return generateWordText(cat, 40);
  }
  return generateWordText(cat, 30);
}

