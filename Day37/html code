    primary:'pm',
    reasoning:"Product manager owns deciding whether and how to respond strategically, rather than reacting impulsively to match a competitor feature-for-feature.",
    flow:['mkt','sales','ux','pm'],
    flowNote:"Marketing and sales relay what customers are actually asking for, UX explores what a thoughtful version could look like, and product manager decides the real response — which may or may not mean building the same thing."
  },
];

function sample(arr, n){
  const copy = arr.slice();
  const out = [];
  for(let i=0;i<n && copy.length;i++){
    const idx = Math.floor(Math.random()*copy.length);
    out.push(copy.splice(idx,1)[0]);
  }
  return out;
}

/* ---------------- STATE ---------------- */
const state = {
  stage:1,        // 1,2,3
  qIndex:0,       // question within stage
  s1: sample(STAGE1,3),
  s2: sample(STAGE2,3),
  s3: sample(STAGE3,3),
  results:{ownership:[], routing:[], collab:[]},
  scores:{ownership:0, delegation:0, collaboration:0, workflow:0},
  maxScores:{ownership:3, delegation:3, collaboration:3, workflow:3}
};

const app = document.getElementById('app');

/* ---------------- HEADER / PROGRESS ---------------- */
function totalQuestionsDone(){
  return state.results.ownership.length + state.results.routing.length + state.results.collab.length;
}
function renderShell(innerHtml){
  const totalDone = totalQuestionsDone();
  const pct = Math.min(100, (totalDone/9)*100);
  app.innerHTML = `
    <div class="header">
      <div class="brand"><span class="dot"></span> TASK COMPASS · TECH COMPANY</div>
      <h1 class="title">Task Compass</h1>
      <p class="subtitle">Learn how work flows through real organizations.</p>
    </div>
    <div class="progress-wrap">
      <div class="progress-stages">
        <div class="stage-chip ${state.stage===1?'active':(state.stage>1?'done':'')}">1 · Who Owns This?</div>
        <div class="stage-chip ${state.stage===2?'active':(state.stage>2?'done':'')}">2 · Task Routing</div>
        <div class="stage-chip ${state.stage===3?'active':''}">3 · Collaboration</div>
      </div>
      <div class="progress-bar-track"><div class="progress-bar-fill" style="width:${pct}%"></div></div>
    </div>
    <div class="panel">${innerHtml}</div>
  `;
}

/* ---------------- STAGE 1: OWNERSHIP ---------------- */
let dragRoleId = null;

function renderStage1(){
  const q = state.s1[state.qIndex];
  const roleCards = ROLES.map(r => `
    <div class="role-card ${r.cls}" draggable="true" data-role="${r.id}" ondragstart="TC.onRoleDragStart(event)" ondragend="TC.onRoleDragEnd(event)" onclick="TC.pickRoleClick('${r.id}')">
      <span class="emoji">${r.emoji}</span>${r.name}
    </div>
  `).join('');

  renderShell(`
    <div class="stage-instructions">Stage 1 · <b>Who Owns This?</b> — Question ${state.qIndex+1} of 3. Drag (or tap) the role that should <b>primarily own</b> this task into the slot below.</div>
    <div class="ticket">
      <div class="ticket-id">TICKET #${1000+state.qIndex}</div>
      <div class="ticket-title">${q.title}</div>
      <div class="ticket-desc">${q.desc}</div>
      <span class="ticket-tag">${q.tag}</span>
    </div>
    <div class="slot-row">
      <div class="drop-slot" id="ownerSlot" ondragover="TC.onSlotDragOver(event)" ondragleave="TC.onSlotDragLeave(event)" ondrop="TC.onSlotDrop(event)">
        Drop the owning role here
      </div>
    </div>
    <div class="roles-grid" id="rolesGrid">${roleCards}</div>
    <div id="revealArea"></div>
    <div class="btn-row">
      <button class="btn btn-primary" id="submitBtn" disabled onclick="TC.submitStage1()">Submit Ownership</button>
      <button class="btn btn-ghost" id="nextBtn" style="display:none" onclick="TC.nextStage1()">Continue →</button>
    </div>
  `);
}

function pickRoleClick(id){
  if(document.getElementById('submitBtn') && document.getElementById('submitBtn').disabled === false && document.getElementById('ownerSlot').classList.contains('filled')) return;
  fillOwnerSlot(id);
}
function onRoleDragStart(e){
  dragRoleId = e.target.closest('.role-card').dataset.role;
  e.target.closest('.role-card').classList.add('dragging');
}
function onRoleDragEnd(e){
  e.target.closest('.role-card').classList.remove('dragging');
}
function onSlotDragOver(e){ e.preventDefault(); e.currentTarget.classList.add('drag-over'); }
function onSlotDragLeave(e){ e.currentTarget.classList.remove('drag-over'); }
function onSlotDrop(e){
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  if(dragRoleId) fillOwnerSlot(dragRoleId);
}
function fillOwnerSlot(id){
  const slot = document.getElementById('ownerSlot');
  const r = role(id);
  slot.classList.add('filled');
  slot.innerHTML = `<div class="filled-card">${r.emoji} <strong>${r.name}</strong></div>`;
  slot.dataset.chosen = id;
  document.getElementById('submitBtn').disabled = false;
}

function submitStage1(){
  const slot = document.getElementById('ownerSlot');
  const chosen = slot.dataset.chosen;
  if(!chosen) return;
  const q = state.s1[state.qIndex];
  const correct = chosen === q.owner;
  state.results.ownership.push({correct, id:q.id});
  state.scores.ownership += correct ? 1 : 0;

  const assistNames = q.assist.map(id => role(id).emoji + ' ' + role(id).name).join(', ');
  const ownerRole = role(q.owner);
  const chosenRole = role(chosen);

  const revealHtml = `
    <div class="reveal">
      <h3>✓ Primary Owner: ${ownerRole.emoji} ${ownerRole.name}</h3>
      <p>${q.why}</p>
      <p><strong>You chose:</strong> ${chosenRole.emoji} ${chosenRole.name} ${correct ? '— a solid match for this task.' : '— a reasonable instinct, but here is the primary owner and the reasoning.'}</p>
      <p><strong>Who may assist:</strong></p>
      <div class="assist-list">${q.assist.map(id=>`<span class="assist-chip">${role(id).emoji} ${role(id).name}</span>`).join('')}</div>
      <p>${q.assistWhy}</p>
    </div>
  `;
  document.getElementById('revealArea').innerHTML = revealHtml;
  document.getElementById('submitBtn').style.display = 'none';
  document.getElementById('nextBtn').style.display = 'inline-block';
  document.querySelectorAll('#rolesGrid .role-card').forEach(c => c.setAttribute('draggable','false'));
}

function nextStage1(){
  if(state.qIndex < state.s1.length - 1){
    state.qIndex++;
    renderStage1();
  } else {
    state.stage = 2;
    state.qIndex = 0;
    renderStage2();
  }
}

/* ---------------- STAGE 2: ROUTING ---------------- */
let currentOrder = [];
let dragRoleId2 = null;

function renderStage2(){
  const q = state.s2[state.qIndex];
  currentOrder = [];
  const roleCards = ROLES.map(r => `
    <div class="role-card ${r.cls}" data-role="${r.id}" draggable="true" ondragstart="TC.onRole2DragStart(event)" ondragend="TC.onRole2DragEnd(event)" onclick="TC.addToTrack('${r.id}')">
      <span class="emoji">${r.emoji}</span>${r.name}
    </div>
  `).join('');

  renderShell(`
    <div class="stage-instructions">Stage 2 · <b>Task Routing</b> — Question ${state.qIndex+1} of 3. Build the workflow by dragging (or tapping) role cards into order. This task may need 3–5 steps.</div>
    <div class="ticket">
      <div class="ticket-id">TICKET #${2000+state.qIndex}</div>
      <div class="ticket-title">${q.title}</div>
      <div class="ticket-desc">${q.desc}</div>
      <span class="ticket-tag">${q.tag}</span>
    </div>
    <div class="routing-track" id="track" ondragover="TC.onTrackDragOver(event)" ondragleave="TC.onTrackDragLeave(event)" ondrop="TC.onTrackDrop(event)">
      <span style="color:var(--text-low);font-size:13px;" id="trackPlaceholder">Drop roles here in the order work should flow →</span>
    </div>
    <div class="roles-grid" id="rolesGrid2">${roleCards}</div>
    <div id="revealArea"></div>
    <div class="btn-row">
      <button class="btn btn-ghost" onclick="TC.clearTrack()">Clear</button>
      <button class="btn btn-primary" id="submitBtn2" disabled onclick="TC.submitStage2()">Submit Workflow</button>
      <button class="btn btn-ghost" id="nextBtn2" style="display:none" onclick="TC.nextStage2()">Continue →</button>
    </div>
  `);
}

function onRole2DragStart(e){
  dragRoleId2 = e.target.closest('.role-card').dataset.role;
}
function onRole2DragEnd(e){}
function onTrackDragOver(e){ e.preventDefault(); document.getElementById('track').classList.add('drag-over'); }
function onTrackDragLeave(e){ document.getElementById('track').classList.remove('drag-over'); }
function onTrackDrop(e){
  e.preventDefault();
  document.getElementById('track').classList.remove('drag-over');
  if(dragRoleId2) addToTrack(dragRoleId2);
}
function addToTrack(id){
  if(currentOrder.length >= 5) return;
  currentOrder.push(id);
  renderTrack();
}
function removeFromTrack(idx){
  currentOrder.splice(idx,1);
  renderTrack();
}
function clearTrack(){
  currentOrder = [];
  renderTrack();
}
function renderTrack(){
  const track = document.getElementById('track');
  if(currentOrder.length === 0){
    track.innerHTML = `<span style="color:var(--text-low);font-size:13px;">Drop roles here in the order work should flow →</span>`;
  } else {
    track.innerHTML = currentOrder.map((id, i) => {
      const r = role(id);
      return `<div class="lane-step">
        ${i>0 ? '<span class="arrow">→</span>' : ''}
        <div class="lane-card">${r.emoji} ${r.name} <span class="lane-remove" onclick="TC.removeFromTrack(${i})">✕</span></div>
      </div>`;
    }).join('');
  }
  document.getElementById('submitBtn2').disabled = currentOrder.length < 2;
}

function submitStage2(){
  const q = state.s2[state.qIndex];
  const correct = JSON.stringify(currentOrder) === JSON.stringify(q.correctOrder);
  // partial credit concept: check if same set regardless of order for delegation scoring
  const sameSet = currentOrder.slice().sort().join(',') === q.correctOrder.slice().sort().join(',');
  state.results.routing.push({correct, sameSet, id:q.id});
  state.scores.workflow += correct ? 1 : (sameSet ? 0.5 : 0);

  document.getElementById('submitBtn2').style.display = 'none';
  document.getElementById('nextBtn2').style.display = 'inline-block';
  document.querySelectorAll('#rolesGrid2 .role-card').forEach(c => c.setAttribute('draggable','false'));

  const correctFlow = q.correctOrder.map(id => role(id));
  let flowHtml = `<div class="flow-anim" id="flowAnim">`;
  correctFlow.forEach((r,i) => {
    if(i>0) flowHtml += `<span class="flow-arrow" style="animation-delay:${i*0.25-0.1}s">→</span>`;
    flowHtml += `<div class="flow-node" style="animation-delay:${i*0.25}s">${r.emoji} ${r.name}</div>`;
  });
  flowHtml += `</div>`;

  const revealHtml = `
    <div class="reveal order-reveal">
      <h3>${correct ? '✓ That matches a common real-world flow' : '↻ Here is a commonly used flow for this task'}</h3>
      ${flowHtml}
      <p>${q.reasoning}</p>
    </div>
  `;
  document.getElementById('revealArea').innerHTML = revealHtml;
  requestAnimationFrame(()=>{
    document.querySelectorAll('#flowAnim .flow-node, #flowAnim .flow-arrow').forEach(el => el.classList.add('show'));
  });
}

function nextStage2(){
  if(state.qIndex < state.s2.length - 1){
    state.qIndex++;
    renderStage2();
  } else {
    state.stage = 3;
    state.qIndex = 0;
    renderStage3();
  }
}

/* ---------------- STAGE 3: COLLABORATION ---------------- */
let picked3 = [];

function renderStage3(){
  const q = state.s3[state.qIndex];
  picked3 = [];
  const cards = ROLES.map(r => `
    <div class="multi-card" data-role="${r.id}" onclick="TC.togglePick3('${r.id}')">
      <span class="emoji">${r.emoji}</span>${r.name}
    </div>
  `).join('');

  renderShell(`
    <div class="stage-instructions">Stage 3 · <b>Collaboration Challenge</b> — Question ${state.qIndex+1} of 3. Select up to <b>4</b> roles or departments that should be involved in responding to this situation.</div>
    <div class="ticket">
      <div class="ticket-id">SITUATION #${3000+state.qIndex}</div>
      <div class="ticket-title">${q.title}</div>
      <div class="ticket-desc">${q.desc}</div>
      <span class="ticket-tag">${q.tag}</span>
    </div>
    <div class="multi-grid" id="multiGrid">${cards}</div>
    <div class="pick-counter" id="pickCounter">0 / 4 selected</div>
    <div id="revealArea"></div>
    <div class="btn-row">
      <button class="btn btn-primary" id="submitBtn3" disabled onclick="TC.submitStage3()">Submit Response Plan</button>
      <button class="btn btn-ghost" id="nextBtn3" style="display:none" onclick="TC.nextStage3()">Continue →</button>
    </div>
  `);
}

function togglePick3(id){
  const card = document.querySelector(`#multiGrid .multi-card[data-role="${id}"]`);
  if(picked3.includes(id)){
    picked3 = picked3.filter(x=>x!==id);
    card.classList.remove('picked');
  } else {
    if(picked3.length >= 4) return;
    picked3.push(id);
    card.classList.add('picked');
  }
  document.getElementById('pickCounter').textContent = `${picked3.length} / 4 selected`;
  document.getElementById('submitBtn3').disabled = picked3.length < 2;
}

function submitStage3(){
  const q = state.s3[state.qIndex];
  const overlap = picked3.filter(id => q.correctSet.includes(id)).length;
  const hasPrimary = picked3.includes(q.primary);
  const collabScore = overlap / q.correctSet.length; // 0..1
  state.results.collab.push({overlap, total:q.correctSet.length, hasPrimary, pickedCount:picked3.length, id:q.id});
  state.scores.collaboration += collabScore;
  state.scores.ownership += hasPrimary ? 0 : 0; // no change; ownership scored in stage1
  // over-assignment tracking: if player picked 4 always vs actual need
  state.scores.delegation += (picked3.length <= q.correctSet.length + 1) ? 1 : 0.4;

  document.querySelectorAll('#multiGrid .multi-card').forEach(c => c.style.pointerEvents='none');
  document.getElementById('submitBtn3').style.display = 'none';
  document.getElementById('nextBtn3').style.display = 'inline-block';

  let flowHtml = `<div class="flow-anim" id="flowAnim3">`;
  q.flow.forEach((id,i)=>{
    const r = role(id);
    if(i>0) flowHtml += `<span class="flow-arrow" style="animation-delay:${i*0.25-0.1}s">→</span>`;
    flowHtml += `<div class="flow-node" style="animation-delay:${i*0.25}s">${r.emoji} ${r.name}</div>`;
  });
  flowHtml += `</div>`;

  const revealHtml = `
    <div class="reveal collab-reveal">
      <h3>★ Primary Owner: ${role(q.primary).emoji} ${role(q.primary).name}</h3>
      <p>${q.reasoning}</p>
      <p><strong>Supporting teams commonly involved:</strong></p>
      <div class="assist-list">${q.correctSet.map(id=>`<span class="assist-chip">${role(id).emoji} ${role(id).name}</span>`).join('')}</div>
      <p><strong>Possible communication flow:</strong></p>
      ${flowHtml}
      <p>${q.flowNote}</p>
    </div>
  `;
  document.getElementById('revealArea').innerHTML = revealHtml;
  requestAnimationFrame(()=>{
    document.querySelectorAll('#flowAnim3 .flow-node, #flowAnim3 .flow-arrow').forEach(el => el.classList.add('show'));
  });
}

function nextStage3(){
  if(state.qIndex < state.s3.length - 1){
    state.qIndex++;
    renderStage3();
  } else {
    renderResults();
  }
}

/* ---------------- RESULTS ---------------- */
function renderResults(){
  // normalize scores to /3 style categories already tracked; cap at max
  const s = state.scores;
  const ownershipPct = Math.round((s.ownership/3)*100);
  const workflowPct = Math.round((s.workflow/3)*100);
  const collabPct = Math.round((s.collaboration/3)*100);
  const delegationPct = Math.round((s.delegation/3)*100);

  // Build reflection text based on patterns
  const overAssigned = state.results.collab.filter(r => r.pickedCount >= 4).length;
  const underAssigned = state.results.collab.filter(r => r.pickedCount <= 2 && r.overlap < r.total).length;
  const ownershipCorrect = state.results.ownership.filter(r=>r.correct).length;
  const routingCorrect = state.results.routing.filter(r=>r.correct).length;

  let wellText = "You showed a clear sense of ownership — identifying who should be primarily responsible for a task, even when the reasoning was more subtle than a job title suggests.";
  if(routingCorrect >= 2){
    wellText += " Your workflow sequencing also tracked closely with how these tasks commonly move through a real organization.";
  }

  let overAssignText = overAssigned >= 2
    ? "In the collaboration scenarios, you tended to loop in the maximum number of people even when a smaller, more focused group might have moved faster. This is a common and often safe instinct, but it's worth noticing when it happens."
    : "You generally selected a focused set of collaborators rather than defaulting to involving everyone, which tends to keep response times faster.";

  let underCollabText = underAssigned >= 2
    ? "A few of the larger, messier situations may have benefited from looping in one or two more teams than you selected — complex problems often touch more corners of an organization than they first appear to."
    : "You picked up well on situations that needed more than one team, rather than assigning them to a single owner.";

  const insight = "Many real workplace problems are solved by teams rather than individuals, and the 'owner' of a task is often the person who coordinates others rather than the person who does all the work themselves.";

  renderShell(`
    <div class="celebrate">🧭</div>
    <h2 style="text-align:center;margin-top:0;">Compass Reading Complete</h2>
    <p style="text-align:center;color:var(--text-mid);">Here's what your choices reveal about how you see organizational work.</p>

    <canvas id="radar" width="360" height="360"></canvas>

    <div class="score-grid">
      <div class="score-card"><div class="label">Ownership</div><div class="val">${ownershipPct}%</div></div>
      <div class="score-card"><div class="label">Delegation</div><div class="val">${delegationPct}%</div></div>
      <div class="score-card"><div class="label">Collaboration</div><div class="val">${collabPct}%</div></div>
      <div class="score-card"><div class="label">Workflow Thinking</div><div class="val">${workflowPct}%</div></div>
    </div>

    <div class="reflection-block">
      <h4>💡 What you understood well</h4>
      <p>${wellText}</p>
    </div>
    <div class="reflection-block">
      <h4>⚖️ Where you tended to over-assign responsibility</h4>
      <p>${overAssignText}</p>
    </div>
    <div class="reflection-block">
      <h4>🤝 Where you underestimated collaboration</h4>
      <p>${underCollabText}</p>
    </div>
    <div class="reflection-block">
      <h4>🌐 One insight about how organizations actually work</h4>
      <p>${insight}</p>
    </div>

    <div class="btn-row">
      <button class="btn btn-primary" onclick="TC.restart()">Play Again</button>
    </div>
  `);

  drawRadar([ownershipPct, delegationPct, collabPct, workflowPct], ['Ownership','Delegation','Collaboration','Workflow']);
}

function drawRadar(values, labels){
  const canvas = document.getElementById('radar');
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  const cx = canvas.width/2, cy = canvas.height/2;
  const radius = 120;
  const n = values.length;

  ctx.clearRect(0,0,canvas.width,canvas.height);

  // rings
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  for(let ring=1; ring<=4; ring++){
    ctx.beginPath();
    for(let i=0;i<=n;i++){
      const angle = (Math.PI*2*i/n) - Math.PI/2;
      const r = radius*(ring/4);
      const x = cx + r*Math.cos(angle);
      const y = cy + r*Math.sin(angle);
      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.stroke();
  }

  // axes + labels
  ctx.strokeStyle = 'rgba(255,255,255,0.12)';
  ctx.fillStyle = '#9aa5b8';
  ctx.font = '12px Segoe UI, sans-serif';
  ctx.textAlign = 'center';
  for(let i=0;i<n;i++){
    const angle = (Math.PI*2*i/n) - Math.PI/2;
    const x = cx + radius*Math.cos(angle);
    const y = cy + radius*Math.sin(angle);
    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.lineTo(x,y);
    ctx.stroke();
    const lx = cx + (radius+26)*Math.cos(angle);
    const ly = cy + (radius+26)*Math.sin(angle);
    ctx.fillText(labels[i], lx, ly);
  }

  // data polygon
  ctx.beginPath();
  for(let i=0;i<n;i++){
    const angle = (Math.PI*2*i/n) - Math.PI/2;
    const r = radius*(values[i]/100);
    const x = cx + r*Math.cos(angle);
    const y = cy + r*Math.sin(angle);
    if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
  }
  ctx.closePath();
  const grad = ctx.createLinearGradient(0,0,canvas.width,canvas.height);
  grad.addColorStop(0,'rgba(91,157,255,0.35)');
  grad.addColorStop(1,'rgba(126,231,135,0.35)');
  ctx.fillStyle = grad;
  ctx.fill();
  ctx.strokeStyle = '#7ee787';
  ctx.lineWidth = 2;
  ctx.stroke();

  // points
  ctx.fillStyle = '#eef1f7';
  for(let i=0;i<n;i++){
    const angle = (Math.PI*2*i/n) - Math.PI/2;
    const r = radius*(values[i]/100);
    const x = cx + r*Math.cos(angle);
    const y = cy + r*Math.sin(angle);
    ctx.beginPath();
    ctx.arc(x,y,3.5,0,Math.PI*2);
    ctx.fill();
  }
}

function restart(){
  state.stage = 1;
  state.qIndex = 0;
  state.s1 = sample(STAGE1,3);
  state.s2 = sample(STAGE2,3);
  state.s3 = sample(STAGE3,3);
  state.results = {ownership:[], routing:[], collab:[]};
  state.scores = {ownership:0, delegation:0, collaboration:0, workflow:0};
  renderStage1();
}

/* expose to global for inline handlers */
window.TC = {
  onRoleDragStart, onRoleDragEnd, onSlotDragOver, onSlotDragLeave, onSlotDrop, pickRoleClick,
  submitStage1, nextStage1,
  onRole2DragStart, onRole2DragEnd, onTrackDragOver, onTrackDragLeave, onTrackDrop, addToTrack, removeFromTrack, clearTrack,
  submitStage2, nextStage2,
  togglePick3, submitStage3, nextStage3,
  restart
};

renderStage1();
})();
