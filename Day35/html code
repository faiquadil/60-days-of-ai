    optimizedOutput:"A specific diagnosis (e.g. missing index causing a full table scan on a filtered column), a CREATE INDEX statement targeting that column, a rewritten query if needed, and a brief explanation of the expected performance improvement.",
    principle:"Giving concrete performance data, schema context, and engine name lets the model give a targeted fix instead of generic optimization platitudes."
  }
];

/* ============================================================
   STATE
   ============================================================ */
let STATE = {
  domain:null, difficulty:null,
  scenarios:[], currentIndex:0,
  score:0, moves:0, wrongPlacements:0, hintsUsed:0,
  startTime:null, scenarioStartTime:null,
  perScenario:[], // {correctPlacements, wrongPlacements, hintsUsed, timeMs, optimBonus}
  dragData:null
};

const app = document.getElementById('app');

function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

function toast(msg, kind){
  kind = kind || 'info';
  const wrap = document.getElementById('toast-wrap');
  const el = document.createElement('div');
  el.className = 'toast ' + kind;
  el.textContent = msg;
  wrap.appendChild(el);
  setTimeout(()=>el.remove(), 3000);
}

function floatingScore(x,y,text,color){
  const el = document.createElement('div');
  el.className='floating-score';
  el.style.left = x+'px';
  el.style.top = y+'px';
  el.style.color = color || '#2cb67d';
  el.textContent = text;
  document.body.appendChild(el);
  setTimeout(()=>el.remove(), 1000);
}

/* ============================================================
   RENDER: SETUP SCREEN (already answered in chat, but keep UI
   consistent — since domain/difficulty given, jump to confirm)
   ============================================================ */
function renderSetup(){
  STATE.domain = "Software & Code Generation";
  STATE.difficulty = "Advanced";
  app.innerHTML = `
    <div class="header">
      <h1>🧩 Prompt Puzzle</h1>
      <p>Master AI Prompting Through Play</p>
    </div>
    <div class="card setup-grid">
      <h2 style="text-align:center;">Ready to play?</h2>
      <p style="text-align:center; color:var(--sub);">Domain: <b style="color:#fff">${STATE.domain}</b> &nbsp;|&nbsp; Difficulty: <b style="color:#fff">${STATE.difficulty}</b></p>
      <button class="btn-primary" id="startBtn">🚀 Start Puzzle Challenge</button>
    </div>
  `;
  document.getElementById('startBtn').addEventListener('click', startGame);
}

function startGame(){
  STATE.scenarios = shuffle(SCENARIOS);
  STATE.currentIndex = 0;
  STATE.score = 0;
  STATE.moves = 0;
  STATE.wrongPlacements = 0;
  STATE.hintsUsed = 0;
  STATE.startTime = Date.now();
  STATE.perScenario = [];
  renderScenario();
}

/* ============================================================
   TOP BAR / PROGRESS
   ============================================================ */
function renderTopBar(){
  const elapsed = Math.floor((Date.now() - STATE.startTime)/1000);
  const pct = Math.round((STATE.currentIndex / STATE.scenarios.length)*100);
  return `
    <div class="topbar">
      <div class="stat-pills">
        <div class="pill">🏆 Score: <b id="scorePill">${STATE.score}</b></div>
        <div class="pill">🧩 Scenario: <b>${STATE.currentIndex+1}/${STATE.scenarios.length}</b></div>
        <div class="pill">⏱ Time: <b id="timePill">${elapsed}s</b></div>
        <div class="pill">❌ Wrong: <b>${STATE.wrongPlacements}</b></div>
        <div class="pill">💡 Hints: <b>${STATE.hintsUsed}</b></div>
      </div>
      <button class="btn-secondary" id="quitBtn">🏁 End & See Report</button>
    </div>
    <div class="progress-wrap"><div class="progress-bar" style="width:${pct}%"></div></div>
  `;
}

function attachTopBarEvents(){
  const q = document.getElementById('quitBtn');
  if(q) q.addEventListener('click', ()=>renderReport());
}

/* ============================================================
   SCENARIO ROUTER
   ============================================================ */
function renderScenario(){
  if(STATE.currentIndex >= STATE.scenarios.length){
    renderReport();
    return;
  }
  STATE.scenarioStartTime = Date.now();
  const sc = STATE.scenarios[STATE.currentIndex];
  if(sc.type === 'build') renderBuild(sc);
  else if(sc.type === 'clean') renderClean(sc);
  else if(sc.type === 'choose') renderChoose(sc);
}

function typeBadge(type){
  if(type==='build') return `<span class="type-badge type-build">🧱 Build the Prompt</span>`;
  if(type==='clean') return `<span class="type-badge type-clean">🧹 Clean the Prompt</span>`;
  return `<span class="type-badge type-choose">✅ Choose the Best Prompt</span>`;
}

/* ============================================================
   CHALLENGE 1: BUILD THE PROMPT (drag correct blocks into zone)
   ============================================================ */
function renderBuild(sc){
  const blocks = shuffle([...sc.correctBlocks, ...sc.distractorBlocks]).map((text,i)=>({
    id:'blk_'+i, text, correct: sc.correctBlocks.includes(text)
  }));

  app.innerHTML = `
    <div class="header"><h1>🧩 Prompt Puzzle</h1><p>Master AI Prompting Through Play</p></div>
    ${renderTopBar()}
    <div class="card">
      ${typeBadge(sc.type)}
      <div class="scenario-title">${sc.title}</div>
      <div class="scenario-sub">Drag the CORRECT prompt blocks into the "Your Prompt" zone. Avoid distractors.</div>
      <div class="desired-box"><b>🎯 Desired Output:</b> ${sc.desired}</div>
      <div class="zones">
        <div class="zone" id="poolZone">
          <h4>📦 Available Blocks</h4>
          <div id="poolBlocks"></div>
        </div>
        <div class="zone" id="targetZone">
          <h4>✅ Your Prompt</h4>
          <div id="targetBlocks"></div>
        </div>
      </div>
      <div class="actions-row">
        <div class="actions-left">
          <button class="btn-secondary" id="hintBtn">💡 Hint</button>
        </div>
        <div class="actions-right">
          <button class="btn-primary" id="submitBtn" style="width:auto; margin:0;" disabled>Submit Prompt</button>
        </div>
      </div>
      <div id="feedbackArea"></div>
    </div>
  `;
  attachTopBarEvents();

  const poolEl = document.getElementById('poolBlocks');
  const targetEl = document.getElementById('targetBlocks');
  const targetZone = document.getElementById('targetZone');
  const poolZone = document.getElementById('poolZone');

  function makeBlockEl(b){
    const el = document.createElement('div');
    el.className = 'block';
    el.draggable = true;
    el.dataset.id = b.id;
    el.textContent = b.text;
    el.addEventListener('dragstart', (e)=>{
      el.classList.add('dragging');
      STATE.dragData = b.id;
      e.dataTransfer.effectAllowed = 'move';
    });
    el.addEventListener('dragend', ()=> el.classList.remove('dragging'));
    return el;
  }

  blocks.forEach(b=> poolEl.appendChild(makeBlockEl(b)));

  function setupDropzone(zone, container, isTarget){
    zone.addEventListener('dragover', (e)=>{ e.preventDefault(); zone.classList.add('drop-hover'); });
    zone.addEventListener('dragleave', ()=> zone.classList.remove('drop-hover'));
    zone.addEventListener('drop', (e)=>{
      e.preventDefault();
      zone.classList.remove('drop-hover');
      const id = STATE.dragData;
      if(!id) return;
      const el = document.querySelector(`.block[data-id="${id}"]`);
      if(!el) return;
      container.appendChild(el);
      STATE.moves++;
      if(isTarget){
        const b = blocks.find(x=>x.id===id);
        if(b.correct){
          el.classList.add('correct-flash');
          bumpScore(10, el);
        } else {
          el.classList.add('wrong-flash');
          STATE.wrongPlacements++;
          bumpScore(-5, el, true);
          toast('That block doesn\'t belong in an optimized prompt', 'bad');
        }
      }
      updateSubmitState();
    });
  }
  setupDropzone(targetZone, targetEl, true);
  setupDropzone(poolZone, poolEl, false);

  function updateSubmitState(){
    document.getElementById('submitBtn').disabled = targetEl.children.length === 0;
  }

  document.getElementById('hintBtn').addEventListener('click', ()=>{
    STATE.hintsUsed++;
    const remainingCorrect = sc.correctBlocks.find(txt=>{
      return ![...targetEl.children].some(c=>c.textContent===txt);
    });
    const area = document.getElementById('feedbackArea');
    area.innerHTML = `<div class="hint-text">💡 Try including: "${remainingCorrect ? remainingCorrect.slice(0,60)+'…' : 'You have all correct blocks — submit!'}"</div>`;
    toast('Hint used (-3 pts)', 'info');
    STATE.score = Math.max(0, STATE.score - 3);
    refreshScorePill();
  });

  document.getElementById('submitBtn').addEventListener('click', ()=>{
    const placed = [...targetEl.children].map(c=>c.textContent);
    const correctCount = placed.filter(t=>sc.correctBlocks.includes(t)).length;
    const wrongCount = placed.filter(t=>!sc.correctBlocks.includes(t)).length;
    const missed = sc.correctBlocks.length - correctCount;
    const accuracy = Math.round((correctCount / sc.correctBlocks.length)*100);
    const optimBonus = (wrongCount===0 && missed===0) ? 25 : 0;
    if(optimBonus) bumpScore(optimBonus, document.getElementById('submitBtn'));

    const timeMs = Date.now() - STATE.scenarioStartTime;
    STATE.perScenario.push({
      title:sc.title, accuracy, correctCount, wrongCount, missed,
      hints:0, timeMs, optimBonus, principle:sc.principle
    });

    showBuildFeedback(sc, accuracy, wrongCount, missed, optimBonus);
  });
}

function showBuildFeedback(sc, accuracy, wrongCount, missed, optimBonus){
  const area = document.getElementById('feedbackArea');
  const good = accuracy >= 80;
  area.innerHTML = `
    <div class="feedback-box ${good?'':'bad'}">
      <h5>${good ? '✅ Great prompt construction!' : '⚠️ Needs refinement'}</h5>
      <p>Accuracy: <b>${accuracy}%</b> · Wrong blocks: <b>${wrongCount}</b> · Missed: <b>${missed}</b> ${optimBonus? '· <b>+25 Optimization Bonus!</b>':''}</p>
      <p style="margin-top:8px;"><b>Optimized Prompt:</b><br>${sc.optimizedPrompt}</p>
      <p style="margin-top:8px;"><b>Resulting Output:</b> ${sc.optimizedOutput}</p>
      <div class="principle">📘 Principle: ${sc.principle}</div>
      <button class="btn-primary" id="nextBtn" style="margin-top:14px;">Next Scenario →</button>
    </div>
