/* ============================================================
   SCORE HELPERS
   ============================================================ */
function bumpScore(delta, el, isBad){
  STATE.score = Math.max(0, STATE.score + delta);
  refreshScorePill();
  if(el){
    const rect = el.getBoundingClientRect();
    floatingScore(rect.left + rect.width/2, rect.top, (delta>=0?'+':'')+delta, isBad? '#ff5470' : '#2cb67d');
  }
  toast((delta>=0? '✨ +':'⚠️ ')+delta+' pts', delta>=0?'good':'bad');
}
function refreshScorePill(){
  const p = document.getElementById('scorePill');
  if(p) p.textContent = STATE.score;
}

/* live timer refresh */
setInterval(()=>{
  const t = document.getElementById('timePill');
  if(t && STATE.startTime){
    t.textContent = Math.floor((Date.now()-STATE.startTime)/1000)+'s';
  }
}, 1000);

/* ============================================================
   FINAL REPORT
   ============================================================ */
function renderReport(){
  const totalTimeSec = Math.floor((Date.now() - STATE.startTime)/1000);
  const results = STATE.perScenario;
  const avgAccuracy = results.length ? Math.round(results.reduce((a,r)=>a+r.accuracy,0)/results.length) : 0;
  const totalOptimBonus = results.reduce((a,r)=>a+r.optimBonus,0);

  let rating, rank, ratingColor;
  if(STATE.score >= 220){ rating='Legendary Prompt Architect'; rank='S'; }
  else if(STATE.score >= 160){ rating='Expert Prompt Engineer'; rank='A'; }
  else if(STATE.score >= 100){ rating='Skilled Prompt Crafter'; rank='B'; }
  else if(STATE.score >= 50){ rating='Developing Prompter'; rank='C'; }
  else { rating='Novice Prompter'; rank='D'; }

  // Prompt DNA: derive pseudo-traits from performance
  const clarity = Math.min(100, avgAccuracy);
  const precision = Math.min(100, Math.max(0, 100 - STATE.wrongPlacements*8));
  const efficiency = Math.min(100, Math.max(0, 100 - STATE.hintsUsed*10 - Math.floor(totalTimeSec/10)));
  const structure = Math.min(100, Math.round((totalOptimBonus/ (results.length*25||1))*100));
  const restraint = Math.min(100, Math.max(0, 100 - STATE.moves));

  const dna = [
    {label:'Clarity', value:clarity, color:'#7f5af0'},
    {label:'Precision', value:precision, color:'#2cb67d'},
    {label:'Efficiency', value:efficiency, color:'#ffb84d'},
    {label:'Structure', value:structure, color:'#ff5470'},
    {label:'Restraint', value:restraint, color:'#5ac8fa'}
  ];

  const weakestScenario = results.slice().sort((a,b)=>a.accuracy-b.accuracy)[0];
  const bestExample = STATE.scenarios.find(s=>s.title === (weakestScenario && weakestScenario.title)) || STATE.scenarios[0];

  const nextMilestonePts = STATE.score < 50 ? 50 : STATE.score < 100 ? 100 : STATE.score < 160 ? 160 : STATE.score < 220 ? 220 : STATE.score + 50;

  let feedback = "";
  if(avgAccuracy >= 85) feedback = "You consistently identify the exact structural elements a prompt needs — role, constraints, and output format — without over-loading it.";
  else if(avgAccuracy >= 60) feedback = "You're finding the right components most of the time, but occasionally include unnecessary or vague fragments. Focus on precision over volume.";
  else feedback = "Focus on the core recipe: assign a role, state the concrete task, add key constraints, and specify the output format — nothing more.";

  app.innerHTML = `
    <div class="header"><h1>🧩 Prompt Performance Report</h1><p>Master AI Prompting Through Play</p></div>
    <div class="card report-grid">
      <div>
        <div class="big-score">${STATE.score}</div>
        <div class="rank-badge">Rank ${rank} — ${rating}</div>
        <ul class="metrics-list">
          <li><span>Average Accuracy</span><b>${avgAccuracy}%</b></li>
          <li><span>Total Time</span><b>${totalTimeSec}s</b></li>
          <li><span>Total Moves</span><b>${STATE.moves}</b></li>
          <li><span>Wrong Placements</span><b>${STATE.wrongPlacements}</b></li>
          <li><span>Hints Used</span><b>${STATE.hintsUsed}</b></li>
          <li><span>Optimization Bonus</span><b>+${totalOptimBonus}</b></li>
          <li><span>Next Milestone</span><b>${nextMilestonePts} pts</b></li>
        </ul>
        <div class="feedback-box">
          <h5>📣 Personalized Feedback</h5>
          <p>${feedback}</p>
        </div>
      </div>
      <div>
        <h5 style="margin-bottom:6px;">🧬 Prompt DNA</h5>
        <div class="dna-bars" id="dnaBars">
          ${dna.map(d=>`
            <div class="dna-row">
              <div class="dna-label">${d.label}</div>
              <div class="dna-track"><div class="dna-fill" style="background:${d.color};" data-target="${d.value}"></div></div>
              <div style="width:34px; text-align:right;">${d.value}%</div>
            </div>
          `).join('')}
        </div>
        <div class="final-prompt-box">
<b>🏁 Final Optimized Prompt Example</b>
(from: ${bestExample.title})

${bestExample.optimizedPrompt}
        </div>
      </div>
    </div>
    <div class="card" style="margin-top:20px; text-align:center;">
      <button class="btn-primary" id="replayBtn" style="max-width:340px;">🔁 Replay with New Scenarios</button>
    </div>
  `;

  setTimeout(()=>{
    document.querySelectorAll('.dna-fill').forEach(el=>{
      el.style.width = el.dataset.target + '%';
    });
  }, 100);

  document.getElementById('replayBtn').addEventListener('click', ()=>{
    startGame();
  });
}

/* ============================================================
   INIT
   ============================================================ */
renderSetup();

})();
</script>
</body>
</html>
