}

/* ============================================================
   CHALLENGE 2: CLEAN THE PROMPT
   ============================================================ */
function renderClean(sc){
  // Break messy prompt into fragments (split by commas/and/but roughly)
  const rawFragments = sc.messyPrompt.split(/,(?![^\(]*\))/).map(s=>s.trim()).filter(Boolean);
  const fragments = rawFragments.map((text,i)=>{
    const isNoise = sc.removedParts.some(rp => textOverlap(text, rp));
    return {id:'frag_'+i, text, keep: !isNoise};
  });

  app.innerHTML = `
    <div class="header"><h1>🧩 Prompt Puzzle</h1><p>Master AI Prompting Through Play</p></div>
    ${renderTopBar()}
    <div class="card">
      ${typeBadge(sc.type)}
      <div class="scenario-title">${sc.title}</div>
      <div class="scenario-sub">This prompt is messy. Drag the fragments to KEEP into the clean zone; leave noise in the trash zone.</div>
      <div class="desired-box"><b>🎯 Desired Output:</b> ${sc.desired}</div>
      <div class="zones">
        <div class="zone" id="poolZone">
          <h4>🗒️ Messy Fragments</h4>
          <div id="poolBlocks"></div>
        </div>
        <div class="zone" id="targetZone">
          <h4>✨ Clean Prompt Zone</h4>
          <div id="targetBlocks"></div>
        </div>
      </div>
      <div class="actions-row">
        <div class="actions-left"><button class="btn-secondary" id="hintBtn">💡 Hint</button></div>
        <div class="actions-right"><button class="btn-primary" id="submitBtn" style="width:auto; margin:0;" disabled>Submit Cleaned Prompt</button></div>
      </div>
      <div id="feedbackArea"></div>
    </div>
  `;
  attachTopBarEvents();

  const poolEl = document.getElementById('poolBlocks');
  const targetEl = document.getElementById('targetBlocks');
  const targetZone = document.getElementById('targetZone');
  const poolZone = document.getElementById('poolZone');

  function makeBlockEl(f){
    const el = document.createElement('div');
    el.className = 'block';
    el.draggable = true;
    el.dataset.id = f.id;
    el.textContent = f.text;
    el.addEventListener('dragstart', (e)=>{ el.classList.add('dragging'); STATE.dragData = f.id; });
    el.addEventListener('dragend', ()=> el.classList.remove('dragging'));
    return el;
  }
  shuffle(fragments).forEach(f=> poolEl.appendChild(makeBlockEl(f)));

  function setupDropzone(zone, container, isTarget){
    zone.addEventListener('dragover', (e)=>{ e.preventDefault(); zone.classList.add('drop-hover'); });
    zone.addEventListener('dragleave', ()=> zone.classList.remove('drop-hover'));
    zone.addEventListener('drop', (e)=>{
      e.preventDefault();
      zone.classList.remove('drop-hover');
      const id = STATE.dragData;
      if(!id) return;
      const el = document.querySelector(`.block[data-id="${id}"]`);
      if(!el) return;
      container.appendChild(el);
      STATE.moves++;
      if(isTarget){
        const f = fragments.find(x=>x.id===id);
        if(f.keep){ el.classList.add('correct-flash'); bumpScore(8, el); }
        else {
          el.classList.add('wrong-flash');
          STATE.wrongPlacements++;
          bumpScore(-5, el, true);
          toast('That\'s noise — doesn\'t belong in a clean prompt', 'bad');
        }
      }
      document.getElementById('submitBtn').disabled = targetEl.children.length===0;
    });
  }
  setupDropzone(targetZone, targetEl, true);
  setupDropzone(poolZone, poolEl, false);

  document.getElementById('hintBtn').addEventListener('click', ()=>{
    STATE.hintsUsed++;
    const area = document.getElementById('feedbackArea');
    area.innerHTML = `<div class="hint-text">💡 Focus on fragments describing the concrete technical task — ignore tone, jokes, and off-topic asks.</div>`;
    toast('Hint used (-3 pts)', 'info');
    STATE.score = Math.max(0, STATE.score - 3);
    refreshScorePill();
  });

  document.getElementById('submitBtn').addEventListener('click', ()=>{
    const placed = [...targetEl.children].map(c=>c.textContent);
    const keptFragIds = fragments.filter(f=>f.keep);
    const correctCount = placed.filter(t=> keptFragIds.some(f=>f.text===t)).length;
    const wrongCount = placed.filter(t=> !keptFragIds.some(f=>f.text===t)).length;
    const missed = keptFragIds.length - correctCount;
    const accuracy = Math.round((correctCount / Math.max(1,keptFragIds.length))*100);
    const optimBonus = (wrongCount===0 && missed===0) ? 25 : 0;
    if(optimBonus) bumpScore(optimBonus, document.getElementById('submitBtn'));

    const timeMs = Date.now() - STATE.scenarioStartTime;
    STATE.perScenario.push({title:sc.title, accuracy, correctCount, wrongCount, missed, hints:0, timeMs, optimBonus, principle:sc.principle});

    showCleanFeedback(sc, accuracy, wrongCount, missed, optimBonus);
  });
}

function textOverlap(fragment, noiseDescription){
  // heuristic matching: check keyword overlap
  const f = fragment.toLowerCase();
  const keywords = noiseDescription.toLowerCase().match(/[a-z]{4,}/g) || [];
  let hits = 0;
  keywords.forEach(k=>{ if(f.includes(k)) hits++; });
  return hits >= 1 && (
    f.includes('pizza') || f.includes('emoji') || f.includes('poem') ||
    f.includes('favorite color') || f.includes('idk') || f.includes('nice and polite') ||
    f.includes("don't care") || f.includes("don't worry") || f.includes('whatever') ||
    f.includes('any database') || f.includes('anything really') || f.includes('hey so') ||
    f.includes('honestly formatting')
  );
}

