  { name: "Fashion Apparel", products: "seasonal clothing lines", icon: "👕" },
  { name: "Cosmetics", products: "skincare & beauty products", icon: "💄" },
  { name: "Auto Parts", products: "replacement car components", icon: "🔧" },
];

const COUNTRY_SETS = [
  ["USA", "Canada", "Mexico"],
  ["Germany", "France", "Italy", "Spain"],
  ["India", "Japan", "South Korea"],
  ["UK", "Netherlands", "Sweden"],
  ["Brazil", "Argentina"],
  ["Australia", "New Zealand"],
  ["USA", "UK", "Germany", "Japan", "Australia"],
];

const DEMAND_LEVELS = [
  { level: "Low & Steady", desc: "predictable orders, little seasonality" },
  { level: "Moderate & Growing", desc: "steady growth quarter over quarter" },
  { level: "High & Volatile", desc: "big spikes around holidays and trends" },
  { level: "Very High & Seasonal", desc: "extreme peaks during specific seasons" },
];

function randOf(arr){ return arr[Math.floor(Math.random()*arr.length)]; }

function generateCompany(){
  const industry = randOf(INDUSTRIES);
  const countries = randOf(COUNTRY_SETS);
  const demand = randOf(DEMAND_LEVELS);
  const names = ["Northstar", "Vertex", "Meridian", "Bluewave", "Solace", "Ironclad", "Lumen", "Cobalt", "Everline", "Horizon"];
  const suffix = ["Co.", "Industries", "Group", "Goods", "Corp.", "Labs"];
  const name = `${randOf(names)} ${randOf(suffix)}`;
  return { name, industry, countries, demand };
}

/* ---------------- METRICS ENGINE ---------------- */
// All metrics 0-100 scale. Higher is always "better" for display purposes.

