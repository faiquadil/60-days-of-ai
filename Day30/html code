}

function DecisionStep({ stepKey, decision, onChoose, choice }) {
  const [preview, setPreview] = useState(null);
  const selected = choice ? decision.options.find(o => o.key === choice.key) : null;

  return (
    <div className="card">
      <div className="pill">{decision.icon} {decision.title}</div>
      <h2>{decision.question}</h2>
      <p>{decision.why}</p>
      <div className="options-grid">
        {decision.options.map(opt => (
          <div
            key={opt.key}
            className={"option" + (choice && choice.key === opt.key ? " selected" : "")}
            onClick={() => onChoose(stepKey, opt)}
            onMouseEnter={() => setPreview(opt.key)}
            onMouseLeave={() => setPreview(null)}
          >
            {choice && choice.key === opt.key && <span className="badge-choice">SELECTED</span>}
            <span className="icon">{opt.icon}</span>
            <h3>{opt.label}</h3>
            <p>{opt.desc}</p>
            <div className="tag-row">
              {opt.tags.map((t, i) => <span key={i} className={"tag " + t.cls}>{t.t}</span>)}
            </div>
          </div>
        ))}
      </div>
      {selected && (
        <div className="explain-box">
          <div className="why"><strong>Why this matters:</strong> {selected.explain}</div>
        </div>
      )}
    </div>
  );
}

function Dashboard({ company, decisions, metrics, onRestart }) {
  const overall = useMemo(() => {
    const vals = Object.values(metrics).map(clamp);
    const avg = vals.reduce((a,b) => a+b, 0) / vals.length;
    return Math.round(avg);
  }, [metrics]);

  const sorted = useMemo(() => {
    return Object.entries(metrics)
      .map(([k,v]) => ({ key:k, value: clamp(v), label: METRIC_META[k].label }))
      .sort((a,b) => b.value - a.value);
  }, [metrics]);

  const strengths = sorted.filter(m => m.value >= 60).slice(0,3);
  const weaknesses = sorted.filter(m => m.value < 55).sort((a,b)=>a.value-b.value).slice(0,3);

  const biggestRisk = useMemo(() => {
    const lowest = sorted[sorted.length - 1];
    const risks = {
      cost: "Your cost efficiency is low, meaning your margins are thin. A single price war or input cost spike could push you into losses.",
      speed: "Slow delivery speeds risk losing customers to faster competitors, especially in e-commerce where speed drives loyalty.",
      risk: "Your supply chain has weak risk control — a single disruption (natural disaster, strike, or supplier failure) could halt operations.",
      satisfaction: "Low customer satisfaction can lead to churn, negative reviews, and declining repeat purchases.",
      sustainability: "Poor sustainability performance can trigger regulatory penalties and damage your brand with eco-conscious consumers.",
    };
    return { metric: lowest.label, text: risks[lowest.key] };
  }, [sorted]);

  const improvements = useMemo(() => {
    const tips = [];
    if (decisions.suppliers && decisions.suppliers.key === "single") {
      tips.push("Add a backup supplier in a different region to reduce supplier concentration risk.");
    }
    if (decisions.factory && decisions.factory.key === "offshore") {
      tips.push("Consider nearshoring part of your production to cut delivery times and reduce customs exposure.");
    }
    if (decisions.warehouse && decisions.warehouse.key === "centralized") {
      tips.push("Add a regional warehouse near your fastest-growing market to speed up deliveries.");
    }
    if (decisions.transport && (decisions.transport.key === "sea" || decisions.transport.key === "air")) {
      tips.push("Blend transport modes — use sea/rail for bulk stock and air only for urgent restocks — to balance cost and speed.");
    }
    if (decisions.inventory && decisions.inventory.key === "low") {
      tips.push("Increase safety stock slightly for your top-selling products to avoid stockouts during demand spikes.");
    }
    if (decisions.inventory && decisions.inventory.key === "high") {
      tips.push("Use demand forecasting to trim excess inventory and free up working capital.");
    }
    tips.push("Regularly audit your supply chain map to spot new risks as your business grows.");
    tips.push("Invest in real-time tracking software to improve visibility across suppliers, warehouses, and shipments.");
    // dedupe and take 3
    return [...new Set(tips)].slice(0,3);
  }, [decisions]);

  return (
    <div>
      <div className="card score-hero">
        <div className="pill">Final Report</div>
        <div className="score-ring" style={{"--pct": overall}}>
          <div className="score-num">{overall}</div>
        </div>
        <div className="score-label">Overall Supply Chain Score (out of 100)</div>
        <p style={{maxWidth:560, margin:"14px auto 0"}}>
          This score reflects how well {company.name}'s supply chain balances cost, speed, risk,
          customer satisfaction, and sustainability — the five pillars every real-world supply chain
          manager has to juggle at once.
        </p>
      </div>

      <div className="card">
        <h2>📊 Final Metrics</h2>
        <MetricsBar metrics={metrics} />
      </div>

      <div className="dash-grid">
        <div className="card list-card">
          <h2>💪 Strengths</h2>
          {strengths.length === 0 ? <p>No standout strengths yet — every metric is currently in the average-to-weak range.</p> : (
            <ul>
              {strengths.map(s => <li key={s.key}><strong style={{color:"var(--good)"}}>{s.label}</strong> — scoring {s.value}/100, this is a real competitive advantage worth protecting.</li>)}
            </ul>
          )}
        </div>
        <div className="card list-card">
          <h2>⚠️ Weaknesses</h2>
          {weaknesses.length === 0 ? <p>No major weaknesses — your supply chain is well balanced!</p> : (
            <ul>
              {weaknesses.map(w => <li key={w.key}><strong style={{color:"var(--bad)"}}>{w.label}</strong> — scoring {w.value}/100, this area needs attention before it becomes a bigger problem.</li>)}
            </ul>
          )}
        </div>
      </div>

      <div className="card">
        <h2>🚨 Biggest Risk</h2>
        <div className="risk-box">
          <p style={{marginBottom:0, color:"#f0c9ce"}}>
            <strong style={{color:"var(--bad)"}}>{biggestRisk.metric}:</strong> {biggestRisk.text}
          </p>
        </div>
      </div>

      <div className="card">
        <h2>🛠️ Three Practical Improvements</h2>
        <div className="improve-box">
          <ul style={{margin:0, paddingLeft:18}}>
            {improvements.map((imp, i) => (
              <li key={i} style={{marginBottom: i === improvements.length-1 ? 0 : 10, color:"#c8f2e0"}}>{imp}</li>
            ))}
          </ul>
        </div>
      </div>

      <div className="card">
        <h2>📝 Your Decisions Summary</h2>
        <div className="company-grid">
          {STEP_ORDER.map(key => {
            const dec = decisions[key];
            const meta = DECISIONS[key];
            if (!dec) return null;
            return (
              <div className="company-stat" key={key}>
                <div className="label">{meta.title}</div>
                <div className="value">{dec.icon} {dec.label}</div>
              </div>
            );
          })}
        </div>
      </div>

      <div className="card center">
        <h2>Want to try a different strategy?</h2>
        <p>Every company and every decision path produces a different outcome. Replay to test new strategies and see how your score changes.</p>
        <button className="btn" onClick={onRestart}>🔁 Replay with a New Company</button>
      </div>
    </div>
  );
}

/* ---------------- ROOT APP ---------------- */

function App() {
  const [phase, setPhase] = useState("welcome"); // welcome -> intro -> steps -> dashboard
  const [company, setCompany] = useState(null);
  const [stepIndex, setStepIndex] = useState(0);
  const [decisions, setDecisions] = useState({});
  const [metrics, setMetrics] = useState(BASE_METRICS);

  const handleStart = useCallback(() => {
    setCompany(generateCompany());
    setPhase("intro");
  }, []);

  const handleIntroContinue = useCallback(() => {
    setPhase("steps");
    setStepIndex(0);
  }, []);

  const handleChoose = useCallback((stepKey, option) => {
    setDecisions(prev => ({ ...prev, [stepKey]: option }));
    setMetrics(prev => {
      const next = { ...prev };
      Object.keys(option.effect).forEach(k => {
        next[k] = clamp(next[k] + option.effect[k]);
      });
      return next;
    });
  }, []);

  const currentStepKey = STEP_ORDER[stepIndex];
  const currentDecision = DECISIONS[currentStepKey];
  const currentChoice = decisions[currentStepKey];

  const goNext = () => {
    if (stepIndex < STEP_ORDER.length - 1) {
      setStepIndex(stepIndex + 1);
    } else {
      setPhase("dashboard");
    }
  };
  const goBack = () => {
    if (stepIndex > 0) setStepIndex(stepIndex - 1);
  };

  const handleRestart = useCallback(() => {
    setCompany(generateCompany());
    setDecisions({});
    setMetrics(BASE_METRICS);
    setStepIndex(0);
    setPhase("intro");
  }, []);

  return (
    <div className="app">
      <Header
        step={phase === "steps" ? stepIndex : phase === "dashboard" ? STEP_ORDER.length : -1}
        totalSteps={STEP_ORDER.length}
      />

      {phase === "welcome" && <Welcome onStart={handleStart} />}

      {phase === "intro" && company && (
        <CompanyIntro company={company} onContinue={handleIntroContinue} />
      )}

      {phase === "steps" && (
        <div>
          <div className="card" style={{padding:"16px 22px"}}>
            <h3 style={{margin:0, color:"var(--muted)", fontWeight:600, fontSize:13}}>
              LIVE METRICS — {company.name}
            </h3>
            <div style={{marginTop:12}}>
              <MetricsBar metrics={metrics} />
            </div>
          </div>

          <DecisionStep
            stepKey={currentStepKey}
            decision={currentDecision}
            onChoose={handleChoose}
            choice={currentChoice}
          />

          <div className="footer-nav">
            <button className="btn secondary" onClick={goBack} disabled={stepIndex === 0}>← Back</button>
            <button className="btn" onClick={goNext} disabled={!currentChoice}>
              {stepIndex === STEP_ORDER.length - 1 ? "View Final Dashboard →" : "Next Decision →"}
            </button>
          </div>
        </div>
      )}

      {phase === "dashboard" && company && (
        <Dashboard company={company} decisions={decisions} metrics={metrics} onRestart={handleRestart} />
      )}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
