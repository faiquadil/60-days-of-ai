      {step >= 0 && step <= totalSteps && (
        <div className="step-indicator">
          {Array.from({length: totalSteps + 1}).map((_, i) => (
            <div key={i} className={"step-dot " + (i === step ? "active" : i < step ? "done" : "")}></div>
          ))}
        </div>
      )}
    </div>
  );
}

function MetricsBar({ metrics }) {
  return (
    <div className="metrics-bar">
      {Object.keys(metrics).map(key => {
        const meta = METRIC_META[key];
        const val = clamp(metrics[key]);
        return (
          <div className="metric-card" key={key}>
            <div className="metric-top">
              <span className="metric-name">{meta.icon} {meta.label}</span>
              <span className="metric-value" style={{color: metricColor(val)}}>{val}</span>
            </div>
            <div className="progress-track">
              <div className="progress-fill" style={{ width: val + "%", background: metricColor(val) }}></div>
            </div>
          </div>
        );
      })}
    </div>
  );
}

function Welcome({ onStart }) {
  return (
    <div className="card center">
      <div className="pill">Learn by Doing</div>
      <h1>Welcome to Supply Chain Builder</h1>
      <p style={{maxWidth: 640, margin: "0 auto 14px"}}>
        A supply chain is simply the journey a product takes — from raw materials,
        to factories, to warehouses, to trucks and ships, and finally into a customer's
        hands. Every choice along that journey changes how much it costs, how fast it
        arrives, and how happy your customers are.
      </p>
      <div className="welcome-icons">
        <span>🏭</span><span>➡️</span><span>🏬</span><span>➡️</span><span>🚚</span><span>➡️</span><span>🛍️</span>
      </div>
      <div className="intro-points">
        <div className="intro-point">
          <div className="num">1</div>
          <h3>You'll run a real company</h3>
          <p style={{marginBottom:0}}>We'll randomly generate a business — its industry, products, and markets.</p>
        </div>
        <div className="intro-point">
          <div className="num">2</div>
          <h3>You'll make 5 key decisions</h3>
          <p style={{marginBottom:0}}>Suppliers, factory location, warehousing, transport, and inventory.</p>
        </div>
        <div className="intro-point">
          <div className="num">3</div>
          <h3>Every choice has trade-offs</h3>
          <p style={{marginBottom:0}}>We'll explain the "why" in plain English before and after every decision.</p>
        </div>
        <div className="intro-point">
          <div className="num">4</div>
          <h3>You'll get a final score</h3>
          <p style={{marginBottom:0}}>See your overall supply chain health, strengths, weaknesses, and risks.</p>
        </div>
      </div>
      <div style={{marginTop:26}}>
        <button className="btn" onClick={onStart}>Generate My Company →</button>
      </div>
    </div>
  );
}

function CompanyIntro({ company, onContinue }) {
  return (
    <div className="card">
      <div className="pill">Your Company</div>
      <h1>{company.industry.icon} {company.name}</h1>
      <p>
        Congratulations — you're now running the supply chain for <strong style={{color:"var(--text)"}}>{company.name}</strong>,
        a company in the <strong style={{color:"var(--text)"}}>{company.industry.name}</strong> industry that makes{" "}
        <strong style={{color:"var(--text)"}}>{company.industry.products}</strong>. Understanding your company's
        situation matters because the "best" supply chain decision always depends on context — what works for a
        food company won't work for an electronics company.
      </p>
      <div className="company-grid">
        <div className="company-stat">
          <div className="label">Industry</div>
          <div className="value">{company.industry.icon} {company.industry.name}</div>
        </div>
        <div className="company-stat">
          <div className="label">Core Products</div>
          <div className="value">{company.industry.products}</div>
        </div>
        <div className="company-stat">
          <div className="label">Markets Served</div>
          <div className="value">{company.countries.join(", ")}</div>
        </div>
        <div className="company-stat">
          <div className="label">Demand Pattern</div>
          <div className="value">{company.demand.level}</div>
        </div>
      </div>
      <p style={{marginTop:14, fontSize:13}}>
        <strong style={{color:"var(--accent)"}}>Demand insight:</strong> Your demand is described as "{company.demand.level}" — meaning {company.demand.desc}. Keep this in mind: businesses with volatile demand usually need more flexibility built into their supply chain.
      </p>
      <div className="footer-nav">
        <div></div>
