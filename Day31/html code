<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Supply Chain Control Tower</title>
<style>
  :root{
    --bg-0:#050a12;
    --bg-1:#0a1220;
    --bg-2:#0f1b2e;
    --panel:#101c30;
    --panel-border:#1c2e4a;
    --cyan:#3fd8ff;
    --blue:#3b82f6;
    --green:#2ee6a8;
    --orange:#ffab3f;
    --red:#ff4d5e;
    --text-hi:#eaf2ff;
    --text-mid:#9fb3cf;
    --text-lo:#5f7896;
    --mono:'JetBrains Mono','SFMono-Regular',Consolas,monospace;
    --sans:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;height:100%;}
  body{
    background:
      radial-gradient(ellipse at 20% -10%, rgba(59,130,246,0.18), transparent 55%),
      radial-gradient(ellipse at 90% 0%, rgba(63,216,255,0.10), transparent 50%),
      linear-gradient(180deg, var(--bg-0), var(--bg-1) 40%, var(--bg-0));
    color:var(--text-hi);
    font-family:var(--sans);
    min-height:100vh;
    overflow-x:hidden;
  }
  /* subtle scanning grid backdrop */
  body::before{
    content:"";
    position:fixed; inset:0;
    background-image:
      linear-gradient(rgba(63,216,255,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(63,216,255,0.035) 1px, transparent 1px);
    background-size:38px 38px;
    pointer-events:none;
    z-index:0;
  }
  #app{position:relative; z-index:1; max-width:1400px; margin:0 auto; padding:18px 20px 60px;}

  /* ===== TOP BAR ===== */
  .topbar{
    display:flex; align-items:center; justify-content:space-between;
    padding:14px 20px; margin-bottom:18px;
    background:linear-gradient(180deg, rgba(16,28,48,0.9), rgba(10,18,32,0.9));
    border:1px solid var(--panel-border);
    border-radius:14px;
    backdrop-filter:blur(6px);
  }
  .brand{display:flex; align-items:center; gap:12px;}
  .brand-mark{
    width:38px; height:38px; border-radius:10px;
    background:conic-gradient(from 220deg, var(--cyan), var(--blue), var(--cyan));
    display:flex; align-items:center; justify-content:center;
    font-weight:800; color:#04101c; font-size:16px;
    box-shadow:0 0 22px rgba(63,216,255,0.45);
  }
  .brand h1{font-size:17px; margin:0; letter-spacing:0.3px;}
  .brand span.sub{display:block; font-size:11px; color:var(--text-mid); font-weight:500; letter-spacing:1.5px; text-transform:uppercase; margin-top:1px;}
  .top-controls{display:flex; gap:10px; align-items:center;}
  .icon-btn{
    background:var(--bg-2); border:1px solid var(--panel-border); color:var(--text-hi);
    width:38px; height:38px; border-radius:10px; cursor:pointer;
    display:flex; align-items:center; justify-content:center; font-size:16px;
    transition:all .15s ease;
  }
  .icon-btn:hover{border-color:var(--cyan); box-shadow:0 0 12px rgba(63,216,255,0.35); transform:translateY(-1px);}
  .icon-btn.active{color:var(--cyan); border-color:var(--cyan);}
  .timer-pill{
    display:flex; align-items:center; gap:8px;
    padding:8px 16px; border-radius:999px;
    background:var(--bg-2); border:1px solid var(--panel-border);
    font-family:var(--mono); font-size:18px; font-weight:700; color:var(--cyan);
    min-width:110px; justify-content:center;
  }
  .timer-pill.low{color:var(--red); border-color:var(--red); animation:pulseRed 1s infinite;}

  /* ===== KPI GRID ===== */
  .kpi-grid{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:12px;
    margin-bottom:18px;
  }
  @media (max-width:900px){ .kpi-grid{grid-template-columns:repeat(2,1fr);} }
  .kpi-card{
    position:relative;
    background:linear-gradient(160deg, var(--panel), var(--bg-2));
    border:1px solid var(--panel-border);
    border-radius:14px;
    padding:14px 16px;
    overflow:hidden;
    transition:transform .2s ease, box-shadow .2s ease;
  }
  .kpi-card::after{
    content:""; position:absolute; inset:0;
    background:radial-gradient(circle at 100% 0%, rgba(63,216,255,0.10), transparent 60%);
    pointer-events:none;
  }
  .kpi-card:hover{transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,0.35);}
  .kpi-label{font-size:11px; text-transform:uppercase; letter-spacing:1.2px; color:var(--text-mid); font-weight:600;}
  .kpi-value{font-family:var(--mono); font-size:26px; font-weight:700; margin-top:6px; color:var(--text-hi); transition:color .3s ease;}
  .kpi-bar-track{height:5px; border-radius:3px; background:rgba(255,255,255,0.06); margin-top:10px; overflow:hidden;}
  .kpi-bar-fill{height:100%; border-radius:3px; transition:width .5s ease, background .5s ease;}
  .kpi-flash{animation:flashCard .6s ease;}
  @keyframes flashCard{
    0%{box-shadow:0 0 0 0 rgba(63,216,255,0.6);}
    100%{box-shadow:0 0 0 14px rgba(63,216,255,0);}
  }
  .kpi-flash-bad{animation:flashCardBad .6s ease;}
  @keyframes flashCardBad{
    0%{box-shadow:0 0 0 0 rgba(255,77,94,0.6);}
    100%{box-shadow:0 0 0 14px rgba(255,77,94,0);}
  }

  /* ===== MAIN LAYOUT ===== */
  .main-grid{
    display:grid;
    grid-template-columns:1.7fr 1fr;
    gap:18px;
    align-items:start;
  }
  @media (max-width:980px){ .main-grid{grid-template-columns:1fr;} }

  .panel-title{
    display:flex; align-items:center; justify-content:space-between;
    margin:0 0 12px 2px;
  }
  .panel-title h2{font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:var(--text-mid); margin:0; font-weight:700;}
  .badge-count{
    font-family:var(--mono); font-size:12px; color:var(--cyan);
    background:rgba(63,216,255,0.08); border:1px solid rgba(63,216,255,0.3);
    padding:2px 10px; border-radius:999px;
  }

  /* ===== ALERT CARDS ===== */
  #alertFeed{display:flex; flex-direction:column; gap:14px; min-height:200px;}
  .alert-card{
    position:relative;
    background:linear-gradient(160deg, var(--panel), var(--bg-2));
    border:1px solid var(--panel-border);
    border-left:4px solid var(--blue);
    border-radius:12px;
    padding:16px 18px;
    animation:slideIn .35s ease;
  }
  @keyframes slideIn{ from{opacity:0; transform:translateY(-10px);} to{opacity:1; transform:translateY(0);} }
  .alert-card.priority-critical{border-left-color:var(--red);}
  .alert-card.priority-high{border-left-color:var(--orange);}
  .alert-card.priority-medium{border-left-color:var(--cyan);}
  .alert-card.resolving{opacity:0; transform:scale(0.97) translateX(20px); transition:all .35s ease;}
  .alert-card.pulse-critical{animation:slideIn .35s ease, pulseCritical 1.4s infinite;}
  @keyframes pulseCritical{
    0%,100%{box-shadow:0 0 0 0 rgba(255,77,94,0.0);}
    50%{box-shadow:0 0 22px 2px rgba(255,77,94,0.35);}
  }
  .alert-head{display:flex; justify-content:space-between; align-items:flex-start; gap:10px; margin-bottom:8px;}
  .alert-title-row{display:flex; align-items:center; gap:8px;}
  .alert-icon{font-size:20px;}
  .alert-title{font-size:15.5px; font-weight:700; color:var(--text-hi);}
  .priority-chip{
    font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.8px;
    padding:3px 9px; border-radius:999px; white-space:nowrap;
  }
  .priority-chip.critical{background:rgba(255,77,94,0.15); color:var(--red); border:1px solid rgba(255,77,94,0.4);}
  .priority-chip.high{background:rgba(255,171,63,0.15); color:var(--orange); border:1px solid rgba(255,171,63,0.4);}
  .priority-chip.medium{background:rgba(63,216,255,0.15); color:var(--cyan); border:1px solid rgba(63,216,255,0.4);}
  .alert-desc{font-size:13px; color:var(--text-mid); line-height:1.5; margin-bottom:8px;}
  .alert-meta{display:flex; gap:16px; flex-wrap:wrap; font-size:11.5px; color:var(--text-lo); margin-bottom:12px; font-family:var(--mono);}
  .alert-meta b{color:var(--text-mid);}
  .alert-timer-track{height:4px; border-radius:3px; background:rgba(255,255,255,0.06); margin-bottom:12px; overflow:hidden;}
  .alert-timer-fill{height:100%; background:linear-gradient(90deg, var(--cyan), var(--blue)); transition:width 1s linear;}
  .alert-timer-fill.urgent{background:linear-gradient(90deg, var(--red), var(--orange));}
  .action-row{display:flex; flex-wrap:wrap; gap:8px;}
  .action-btn{
    background:var(--bg-2);
    border:1px solid var(--panel-border);
    color:var(--text-hi);
    font-size:12.5px; font-weight:600;
    padding:8px 13px; border-radius:9px;
    cursor:pointer;
    transition:all .15s ease;
    font-family:var(--sans);
  }
  .action-btn:hover{border-color:var(--cyan); background:rgba(63,216,255,0.08); transform:translateY(-1px);}
  .action-btn.best{border-color:rgba(46,230,168,0.5);}
  .action-btn.ignore{color:var(--text-lo);}
  .action-btn.ignore:hover{border-color:var(--red); color:var(--red);}
  .empty-feed{
    text-align:center; padding:50px 20px; color:var(--text-lo);
    border:1px dashed var(--panel-border); border-radius:12px; font-size:13px;
  }

  /* ===== EVENT LOG ===== */
  .log-panel{
    background:linear-gradient(160deg, var(--panel), var(--bg-2));
    border:1px solid var(--panel-border);
    border-radius:14px;
    padding:14px 16px;
    height:520px;
    display:flex; flex-direction:column;
  }
  #logList{
    flex:1; overflow-y:auto; display:flex; flex-direction:column-reverse; gap:8px;
    font-family:var(--mono); font-size:12px; padding-right:4px;
  }
  #logList::-webkit-scrollbar{width:6px;}
  #logList::-webkit-scrollbar-thumb{background:var(--panel-border); border-radius:3px;}
  .log-entry{
    display:flex; gap:8px; padding:8px 10px; border-radius:8px;
    background:rgba(255,255,255,0.02); border-left:3px solid var(--text-lo);
    animation:slideIn .25s ease; line-height:1.4;
  }
  .log-entry.good{border-left-color:var(--green);}
  .log-entry.bad{border-left-color:var(--red);}
  .log-entry.neutral{border-left-color:var(--orange);}
  .log-entry .t{color:var(--text-lo); flex-shrink:0;}

  /* ===== BUTTONS / MODALS ===== */
  .btn{
    font-family:var(--sans); font-weight:700; font-size:14px;
    padding:12px 26px; border-radius:10px; cursor:pointer; border:none;
    transition:all .15s ease;
  }
  .btn-primary{background:linear-gradient(135deg, var(--cyan), var(--blue)); color:#04101c; box-shadow:0 6px 20px rgba(63,216,255,0.35);}
  .btn-primary:hover{transform:translateY(-2px); box-shadow:0 10px 26px rgba(63,216,255,0.45);}
  .btn-ghost{background:transparent; border:1px solid var(--panel-border); color:var(--text-hi);}
  .btn-ghost:hover{border-color:var(--cyan);}

  .modal-overlay{
    position:fixed; inset:0; background:rgba(3,7,14,0.75); backdrop-filter:blur(4px);
    display:none; align-items:center; justify-content:center; z-index:100; padding:20px;
  }
  .modal-overlay.show{display:flex;}
  .modal-box{
    background:linear-gradient(160deg, var(--panel), var(--bg-1));
    border:1px solid var(--panel-border); border-radius:16px;
    padding:30px 34px; max-width:560px; width:100%;
    max-height:85vh; overflow-y:auto;
    box-shadow:0 30px 80px rgba(0,0,0,0.6);
  }
  .modal-box h2{margin-top:0; font-size:20px; color:var(--cyan);}
  .modal-box h3{font-size:14px; color:var(--text-hi); margin-bottom:4px;}
  .modal-box p, .modal-box li{color:var(--text-mid); font-size:13.5px; line-height:1.6;}
  .modal-box ul{padding-left:18px;}
  .modal-close-row{display:flex; justify-content:flex-end; margin-top:20px;}

  /* ===== START SCREEN ===== */
  #startScreen{
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center; min-height:78vh; gap:22px; padding:20px;
  }
  #startScreen .mark{
    width:84px; height:84px; border-radius:22px;
    background:conic-gradient(from 220deg, var(--cyan), var(--blue), var(--cyan));
    display:flex; align-items:center; justify-content:center;
    font-size:38px; box-shadow:0 0 50px rgba(63,216,255,0.45);
  }
  #startScreen h1{font-size:34px; margin:0; letter-spacing:0.3px;}
  #startScreen p.tag{color:var(--text-mid); font-size:15px; max-width:520px; margin:0;}
  .start-stats{display:flex; gap:26px; margin-top:8px; flex-wrap:wrap; justify-content:center;}
  .start-stat{color:var(--text-lo); font-size:12px; font-family:var(--mono);}
  .start-stat b{display:block; color:var(--cyan); font-size:20px;}

  /* ===== END SCREEN ===== */
  #endScreen{display:none; flex-direction:column; align-items:center; padding:30px 10px; gap:20px;}
  #endScreen.show{display:flex;}
  .grade-circle{
    width:130px; height:130px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-size:52px; font-weight:800; font-family:var(--mono);
    background:radial-gradient(circle, rgba(63,216,255,0.15), transparent 70%);
    border:3px solid var(--cyan); color:var(--cyan);
    box-shadow:0 0 40px rgba(63,216,255,0.35);
  }
  .end-score{font-family:var(--mono); font-size:16px; color:var(--text-mid);}
  .end-score b{color:var(--text-hi); font-size:22px;}
  .end-kpi-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:10px; width:100%; max-width:700px;}
  @media (max-width:640px){ .end-kpi-grid{grid-template-columns:repeat(2,1fr);} }
  .end-kpi{background:var(--bg-2); border:1px solid var(--panel-border); border-radius:10px; padding:10px; text-align:center;}
  .end-kpi .l{font-size:10px; color:var(--text-mid); text-transform:uppercase; letter-spacing:1px;}
  .end-kpi .v{font-family:var(--mono); font-size:18px; font-weight:700; margin-top:4px;}
  .end-summary{max-width:560px; text-align:center; color:var(--text-mid); font-size:14px; line-height:1.6; background:var(--bg-2); border:1px solid var(--panel-border); padding:16px 20px; border-radius:12px;}
  .end-tallies{display:flex; gap:24px;}
  .end-tally{text-align:center; font-family:var(--mono);}
  .end-tally b{display:block; font-size:22px;}

  #gameScreen{display:none;}
  #gameScreen.show{display:block;}

  #pauseOverlay{
    position:fixed; inset:0; background:rgba(3,7,14,0.8); backdrop-filter:blur(3px);
    display:none; align-items:center; justify-content:center; z-index:90; flex-direction:column; gap:14px;
  }
  #pauseOverlay.show{display:flex;}
  #pauseOverlay h2{color:var(--cyan); font-size:26px; letter-spacing:2px;}

  @keyframes pulseRed{ 0%,100%{opacity:1;} 50%{opacity:0.55;} }

  .toast-msg{
    position:fixed; bottom:24px; left:50%; transform:translateX(-50%);
    background:var(--panel); border:1px solid var(--cyan); color:var(--text-hi);
    padding:10px 20px; border-radius:10px; font-size:13px; z-index:200;
    animation:toastIn .3s ease, toastOut .3s ease 2.2s forwards;
  }
  @keyframes toastIn{ from{opacity:0; transform:translate(-50%,10px);} to{opacity:1; transform:translate(-50%,0);} }
  @keyframes toastOut{ to{opacity:0; transform:translate(-50%,10px);} }
</style>
</head>
<body>

<div id="app">

  <!-- ============ START SCREEN ============ -->
  <div id="startScreen">
    <div class="mark">🛰️</div>
    <h1>AI Supply Chain Control Tower</h1>
    <p class="tag">You're the new Head of Operations. Disruptions are already stacking up across ports, factories, and last-mile delivery. Every decision moves the numbers — keep the network alive for three minutes.</p>
    <div class="start-stats">
      <div class="start-stat"><b>3:00</b>Time Limit</div>
      <div class="start-stat"><b>10</b>Alert Types</div>
      <div class="start-stat"><b>7</b>Live KPIs</div>
    </div>
    <div style="display:flex; gap:12px; margin-top:6px;">
      <button class="btn btn-primary" id="startBtn">Start Shift</button>
      <button class="btn btn-ghost" id="howToPlayBtn">How to Play</button>
    </div>
  </div>

  <!-- ============ GAME SCREEN ============ -->
  <div id="gameScreen">

    <div class="topbar">
      <div class="brand">
        <div class="brand-mark">CT</div>
        <div>
          <h1>Control Tower</h1>
          <span class="sub">Live Operations Feed</span>
        </div>
      </div>
      <div class="top-controls">
        <button class="icon-btn active" id="soundBtn" title="Toggle sound">🔊</button>
        <button class="icon-btn" id="helpBtn" title="Help">?</button>
        <button class="icon-btn" id="pauseBtn" title="Pause">⏸</button>
        <div class="timer-pill" id="timerPill">03:00</div>
      </div>
    </div>

    <div class="kpi-grid" id="kpiGrid"><!-- KPI cards injected --></div>

    <div class="main-grid">
      <div>
        <div class="panel-title">
          <h2>Active Alerts</h2>
          <span class="badge-count" id="alertCount">0 open</span>
        </div>
        <div id="alertFeed"></div>
      </div>

      <div>
        <div class="panel-title">
          <h2>Event Log</h2>
          <span class="badge-count" id="scoreBadge">Score 0</span>
        </div>
        <div class="log-panel">
          <div id="logList"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============ END SCREEN ============ -->
  <div id="endScreen">
    <h1 style="margin-bottom:0;">Shift Complete</h1>
    <div class="grade-circle" id="gradeCircle">A</div>
    <div class="end-score">Final Score: <b id="finalScore">0</b></div>
    <div class="end-tallies">
      <div class="end-tally"><b id="resolvedCount" style="color:var(--cyan);">0</b>Resolved</div>
      <div class="end-tally"><b id="correctCount" style="color:var(--green);">0</b>Good Calls</div>
      <div class="end-tally"><b id="wrongCount" style="color:var(--red);">0</b>Bad Calls</div>
    </div>
    <div class="end-kpi-grid" id="endKpiGrid"></div>
    <div class="end-summary" id="endSummary"></div>
    <button class="btn btn-primary" id="playAgainBtn">Play Again</button>
  </div>

</div>

<!-- ============ HELP MODAL ============ -->
<div class="modal-overlay" id="helpModal">
  <div class="modal-box">
    <h2>How to Play</h2>
    <h3>Your role</h3>
    <p>You are the Head of Operations for a global supply chain. Disruptions arrive as alerts — ports, suppliers, trucks, warehouses, customs, and more.</p>
    <h3>Your job</h3>
    <ul>
      <li>Read each alert: priority, description, and business impact.</li>
      <li>Pick an action before its timer runs out. Each action costs differently and affects KPIs differently.</li>
      <li>Some effects are immediate. Some, like "Delay Decision," ripple in a few seconds later — often worse.</li>
      <li>Critical alerts pulse red — they hurt the most if ignored.</li>
    </ul>
    <h3>Scoring</h3>
    <p>Smart, well-matched actions raise your Score and protect KPIs. Ignoring alerts or picking a weak fix costs KPIs and Operating Cost. Survive to 0:00 with the healthiest network you can.</p>
    <div class="modal-close-row"><button class="btn btn-primary" id="closeHelpBtn">Got it</button></div>
  </div>
</div>

<!-- ============ PAUSE OVERLAY ============ -->
<div id="pauseOverlay">
  <h2>⏸ PAUSED</h2>
  <button class="btn btn-primary" id="resumeBtn">Resume Shift</button>
</div>

<script>
/* =========================================================================
   AI SUPPLY CHAIN CONTROL TOWER — GAME LOGIC
   Organized into modular functions: state, KPI engine, alert engine,
   action resolution, timers, rendering, and end-game scoring.
   ========================================================================= */

/* ---------------------------- STATE ---------------------------- */
const GAME_DURATION = 180; // seconds
const state = {
  running:false,
  paused:false,
  soundOn:true,
  timeLeft:GAME_DURATION,
  score:0,
  kpi:{
    service:92,
    csat:90,
    inventory:88,
    transport:85,
    cost:40,        // lower is better (0-100 scale, displayed as index)
    revenueProtected:100,
  },
  activeAlerts:[],      // {id, def, priority, timeLeft, maxTime, elementNeedsRender}
  resolvedCount:0,
  correctCount:0,
  wrongCount:0,
  alertIdCounter:0,
  spawnTimerId:null,
  tickTimerId:null,
  delayedEffects:[],    // {fireAt, fn}
};

/* ---------------------------- ALERT DEFINITIONS ---------------------------- */
const ALERT_DEFS = [
  {
    key:'port', icon:'🚢', title:'Port Congestion',
    desc:'Containers are stacking up at the origin port; vessel unload is running far behind schedule.',
    impact:'Inbound stock delayed 3-5 days across multiple SKUs.',
    actions:[
      {label:'Approve Air Freight', best:true, cost:-14, effects:{service:+6, csat:+4, transport:+2, revenueProtected:+5}, delayed:null,
        log:'Air freight approved — inbound delay contained.'},
      {label:'Reroute to Alt Port', best:false, cost:-6, effects:{service:+2, transport:-3, csat:+1}, delayed:null,
        log:'Trucks rerouted to an alternate port — partial relief.'},
      {label:'Ignore', best:false, cost:0, effects:{service:-10, csat:-8, revenueProtected:-9}, delayed:{after:5, effects:{cost:-6, service:-4}, log:'Delay compounded — backorders spiking.'},
        log:'Port congestion ignored.'},
    ]
  },
  {
    key:'supplier', icon:'🏭', title:'Supplier Delay',
    desc:'A key raw-material supplier reports a 2-week slip due to a production issue on their line.',
    impact:'Risk of stockout on a high-velocity finished good in 10 days.',
    actions:[
      {label:'Use Backup Supplier', best:true, cost:-10, effects:{inventory:+7, service:+4, csat:+2}, delayed:null,
        log:'Backup supplier activated — supply gap closed.'},
