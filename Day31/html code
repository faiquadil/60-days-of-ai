const PRIORITIES = [
  {key:'critical', label:'Critical', weight:1, baseTime:16},
  {key:'high', label:'High', weight:2, baseTime:20},
  {key:'medium', label:'Medium', weight:2, baseTime:26},
];

/* ---------------------------- UTILITIES ---------------------------- */
function clamp(v, lo=0, hi=100){ return Math.max(lo, Math.min(hi, v)); }
function pick(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
function fmtTime(sec){
  const m = Math.floor(sec/60).toString().padStart(2,'0');
  const s = Math.floor(sec%60).toString().padStart(2,'0');
  return `${m}:${s}`;
}
function weightedPriority(){
  // as time passes, difficulty ramps -> more critical/high alerts
  const elapsedRatio = 1 - (state.timeLeft/GAME_DURATION);
  const roll = Math.random();
  if (elapsedRatio > 0.66){
    if (roll < 0.45) return PRIORITIES[0];
    if (roll < 0.8) return PRIORITIES[1];
    return PRIORITIES[2];
  } else if (elapsedRatio > 0.33){
    if (roll < 0.3) return PRIORITIES[0];
    if (roll < 0.7) return PRIORITIES[1];
    return PRIORITIES[2];
  } else {
    if (roll < 0.15) return PRIORITIES[0];
    if (roll < 0.55) return PRIORITIES[1];
    return PRIORITIES[2];
  }
}

/* ---------------------------- KPI ENGINE ---------------------------- */
const KPI_META = [
  {key:'service', label:'Service Level', suffix:'%', good:'high'},
  {key:'csat', label:'Customer Satisfaction', suffix:'%', good:'high'},
  {key:'inventory', label:'Inventory Health', suffix:'%', good:'high'},
  {key:'transport', label:'Transport Efficiency', suffix:'%', good:'high'},
  {key:'cost', label:'Operating Cost Index', suffix:'', good:'low'},
  {key:'revenueProtected', label:'Revenue Protected', suffix:'%', good:'high'},
];

function applyEffects(effects){
  if(!effects) return;
  Object.keys(effects).forEach(k=>{
    if(state.kpi[k] === undefined) return;
    state.kpi[k] = clamp(state.kpi[k] + effects[k]);
  });
}

function kpiColor(meta){
  const v = state.kpi[meta.key];
  const good = meta.good === 'high' ? v >= 70 : v <= 35;
  const warn = meta.good === 'high' ? (v >= 45 && v < 70) : (v > 35 && v <= 60);
  if (good) return 'var(--green)';
  if (warn) return 'var(--orange)';
  return 'var(--red)';
}

function renderKPIs(flashKey, isBad){
  const grid = document.getElementById('kpiGrid');
  grid.innerHTML = '';
  KPI_META.forEach(meta=>{
    const v = state.kpi[meta.key];
    const card = document.createElement('div');
    card.className = 'kpi-card';
    if (flashKey === meta.key) card.className += isBad ? ' kpi-flash-bad' : ' kpi-flash';
    const color = kpiColor(meta);
    const barPct = meta.good === 'low' ? clamp(100 - v) : v;
    card.innerHTML = `
      <div class="kpi-label">${meta.label}</div>
      <div class="kpi-value" style="color:${color}">${Math.round(v)}${meta.suffix}</div>
      <div class="kpi-bar-track"><div class="kpi-bar-fill" style="width:${barPct}%; background:${color};"></div></div>
    `;
    grid.appendChild(card);
  });
  // score + extra pills injected in place of an 8th slot row via topbar badge
  document.getElementById('scoreBadge').textContent = `Score ${Math.round(state.score)}`;
}

/* ---------------------------- LOGGING ---------------------------- */
function addLog(text, type='neutral'){
  const list = document.getElementById('logList');
  const entry = document.createElement('div');
  entry.className = `log-entry ${type}`;
  const time = fmtTime(state.timeLeft);
  entry.innerHTML = `<span class="t">[${time}]</span><span>${text}</span>`;
  list.appendChild(entry);
  // cap log length
  while(list.children.length > 60){ list.removeChild(list.firstChild); }
}

/* ---------------------------- ALERT ENGINE ---------------------------- */
function spawnAlert(){
  if (!state.running || state.paused) return;
  const def = pick(ALERT_DEFS);
  const priority = weightedPriority();
  const maxTime = priority.baseTime;
  const alert = {
    id: ++state.alertIdCounter,
    def, priority,
    timeLeft: maxTime,
    maxTime,
  };
  state.activeAlerts.push(alert);
  addLog(`New alert — ${def.title} (${priority.label})`, 'neutral');
  renderAlerts();
}

function scheduleNextSpawn(){
  if (!state.running) return;
  const elapsedRatio = 1 - (state.timeLeft/GAME_DURATION);
  // frequency ramps: starts ~4.5s between alerts, drops to ~1.6s near the end
  const minGap = 4500 - elapsedRatio*2900;
  const jitter = Math.random()*1500;
  state.spawnTimerId = setTimeout(()=>{
    if (state.running && !state.paused){
      spawnAlert();
    }
    scheduleNextSpawn();
  }, Math.max(1000, minGap + jitter));
}

function resolveAlert(alertId, action){
  const idx = state.activeAlerts.findIndex(a=>a.id === alertId);
  if (idx === -1) return;
  const alert = state.activeAlerts[idx];

  // visual: mark card resolving
  const cardEl = document.getElementById(`alert-${alertId}`);
  if (cardEl) cardEl.classList.add('resolving');

  // apply immediate effects
  applyEffects(action.effects);
  state.kpi.cost = clamp(state.kpi.cost - (action.cost||0)); // cost negative param reduces index... see below
  // Note: action.cost is defined as negative-good (spend) -> we invert properly:
  if (action.cost){
    state.kpi.cost = clamp(state.kpi.cost + Math.abs(action.cost)*0 ); // no-op safeguard
  }

  let scoreDelta = 0;
  let logType = 'neutral';
  if (action.best){
    scoreDelta = 120 + Math.round(alert.timeLeft*2);
    state.correctCount++;
    logType = 'good';
  } else if (action.label === 'Ignore' || action.label === 'Delay Decision'){
    scoreDelta = -40;
    state.wrongCount++;
    logType = 'bad';
  } else {
    scoreDelta = 35;
    logType = 'neutral';
  }
  state.score += scoreDelta;
  state.resolvedCount++;

  addLog(`${alert.def.title}: ${action.log} (${scoreDelta>=0?'+':''}${scoreDelta} pts)`, logType);

  // schedule delayed consequence if any
  if (action.delayed){
    const fireAt = Date.now() + action.delayed.after*1000;
    state.delayedEffects.push({
      fireAt,
      fn:()=>{
        applyEffects(action.delayed.effects);
        addLog(`${alert.def.title}: ${action.delayed.log}`, 'bad');
        const worstKey = Object.keys(action.delayed.effects)[0];
        renderKPIs(worstKey, true);
      }
    });
  }

  // remove after animation
  setTimeout(()=>{
    state.activeAlerts = state.activeAlerts.filter(a=>a.id !== alertId);
    renderAlerts();
  }, 320);

  const bestKey = Object.keys(action.effects||{})[0];
  renderKPIs(bestKey, scoreDelta < 0);
}

function timeOutAlert(alertId){
  const idx = state.activeAlerts.findIndex(a=>a.id === alertId);
  if (idx === -1) return;
  const alert = state.activeAlerts[idx];
  // treat as worst outcome: apply the "Ignore" action if present, else flat penalty
  const ignoreAction = alert.def.actions.find(a=>a.label==='Ignore');
  if (ignoreAction){
    applyEffects(ignoreAction.effects);
  } else {
    applyEffects({service:-8, csat:-6});
  }
  state.score -= 50;
  state.wrongCount++;
  addLog(`${alert.def.title}: went unresolved — impact realized. (-50 pts)`, 'bad');
  state.activeAlerts = state.activeAlerts.filter(a=>a.id !== alertId);
  renderKPIs('service', true);
  renderAlerts();
}

/* ---------------------------- RENDERING ---------------------------- */
function renderAlerts(){
  const feed = document.getElementById('alertFeed');
  document.getElementById('alertCount').textContent = `${state.activeAlerts.length} open`;

  if (state.activeAlerts.length === 0){
    feed.innerHTML = `<div class="empty-feed">All clear. Monitoring the network for new disruptions…</div>`;
    return;
  }

  // preserve existing DOM where possible to avoid button flicker; simplest: full re-render each tick is fine at this scale
  feed.innerHTML = '';
  state.activeAlerts
    .slice()
    .sort((a,b)=> a.timeLeft - b.timeLeft)
    .forEach(alert=>{
      const pctLeft = clamp((alert.timeLeft/alert.maxTime)*100);
      const urgent = pctLeft < 35;
      const card = document.createElement('div');
      card.className = `alert-card priority-${alert.priority.key}` + (alert.priority.key==='critical' ? ' pulse-critical':'');
      card.id = `alert-${alert.id}`;
      card.innerHTML = `
        <div class="alert-head">
          <div class="alert-title-row">
            <span class="alert-icon">${alert.def.icon}</span>
            <span class="alert-title">${alert.def.title}</span>
          </div>
          <span class="priority-chip ${alert.priority.key}">${alert.priority.label}</span>
        </div>
        <div class="alert-desc">${alert.def.desc}</div>
        <div class="alert-meta">
          <span><b>Impact:</b> ${alert.def.impact}</span>
          <span><b>Time left:</b> ${Math.ceil(alert.timeLeft)}s</span>
        </div>
        <div class="alert-timer-track"><div class="alert-timer-fill ${urgent?'urgent':''}" style="width:${pctLeft}%"></div></div>
        <div class="action-row"></div>
      `;
      const actionRow = card.querySelector('.action-row');
      alert.def.actions.forEach(action=>{
        const btn = document.createElement('button');
        btn.className = 'action-btn' + (action.label==='Ignore' || action.label==='Delay Decision' ? ' ignore' : '');
        btn.textContent = action.label;
        btn.onclick = ()=> resolveAlert(alert.id, action);
        actionRow.appendChild(btn);
      });
      feed.appendChild(card);
    });
}

/* ---------------------------- MAIN TICK ---------------------------- */
function tick(){
  if (!state.running || state.paused) return;

  state.timeLeft -= 1;

  // update alert timers
  state.activeAlerts.forEach(a=> a.timeLeft -= 1);
  const expired = state.activeAlerts.filter(a=>a.timeLeft <= 0).map(a=>a.id);
  expired.forEach(id=>timeOutAlert(id));

  // fire delayed effects due
  const now = Date.now();
  const due = state.delayedEffects.filter(d=>d.fireAt <= now);
  if (due.length){
    due.forEach(d=>d.fn());
    state.delayedEffects = state.delayedEffects.filter(d=>d.fireAt > now);
  }

  renderAlerts();
  updateTimerPill();

  if (state.timeLeft <= 0){
    endGame();
    return;
  }
  state.tickTimerId = setTimeout(tick, 1000);
}

function updateTimerPill(){
  const pill = document.getElementById('timerPill');
  pill.textContent = fmtTime(state.timeLeft);
  pill.classList.toggle('low', state.timeLeft <= 20);
}

/* ---------------------------- GAME FLOW ---------------------------- */
function startGame(){
  Object.assign(state, {
    running:true, paused:false, timeLeft:GAME_DURATION, score:0,
    kpi:{ service:92, csat:90, inventory:88, transport:85, cost:40, revenueProtected:100 },
    activeAlerts:[], resolvedCount:0, correctCount:0, wrongCount:0,
    alertIdCounter:0, delayedEffects:[],
  });
  document.getElementById('startScreen').style.display = 'none';
  document.getElementById('endScreen').classList.remove('show');
  document.getElementById('gameScreen').classList.add('show');
  document.getElementById('logList').innerHTML = '';
  addLog('Shift started. Network nominal.', 'good');
  renderKPIs();
  renderAlerts();
  updateTimerPill();
  spawnAlert();
  scheduleNextSpawn();
  state.tickTimerId = setTimeout(tick, 1000);
}

function togglePause(){
  if (!state.running) return;
  state.paused = !state.paused;
  document.getElementById('pauseOverlay').classList.toggle('show', state.paused);
  document.getElementById('pauseBtn').textContent = state.paused ? '▶' : '⏸';
  if (!state.paused){
    state.tickTimerId = setTimeout(tick, 1000);
    scheduleNextSpawn();
  } else {
    clearTimeout(state.tickTimerId);
    clearTimeout(state.spawnTimerId);
  }
}

function endGame(){
  state.running = false;
  clearTimeout(state.tickTimerId);
  clearTimeout(state.spawnTimerId);

  document.getElementById('gameScreen').classList.remove('show');
  const endScreen = document.getElementById('endScreen');
  endScreen.classList.add('show');

  const finalScore = Math.max(0, Math.round(state.score));
  document.getElementById('finalScore').textContent = finalScore;
  document.getElementById('resolvedCount').textContent = state.resolvedCount;
  document.getElementById('correctCount').textContent = state.correctCount;
  document.getElementById('wrongCount').textContent = state.wrongCount;

  // grade calc: blend score + KPI average
  const kpiAvg = (state.kpi.service + state.kpi.csat + state.kpi.inventory + state.kpi.transport + (100-state.kpi.cost) + state.kpi.revenueProtected) / 6;
  const composite = clamp((finalScore/24) * 0.5 + kpiAvg * 0.5);
  let grade, gradeColor, summary;
  if (composite >= 88){ grade='A+'; gradeColor='var(--green)'; }
  else if (composite >= 78){ grade='A'; gradeColor='var(--green)'; }
  else if (composite >= 64){ grade='B'; gradeColor='var(--cyan)'; }
  else if (composite >= 48){ grade='C'; gradeColor='var(--orange)'; }
  else { grade='D'; gradeColor='var(--red)'; }

  const circle = document.getElementById('gradeCircle');
  circle.textContent = grade;
  circle.style.color = gradeColor;
  circle.style.borderColor = gradeColor;

  if (grade === 'A+' || grade === 'A'){
    summary = 'Exceptional shift. The network stayed resilient under real pressure — service levels held, costs stayed controlled, and customers barely noticed the chaos behind the scenes.';
  } else if (grade === 'B'){
    summary = 'A solid shift. Most disruptions were handled well, though a few decisions cost more than they should have. The network is stable but has room to tighten.';
  } else if (grade === 'C'){
    summary = 'A rough shift. Reactive decisions and a few ignored alerts left visible cracks in service and cost. The network survived, but customers felt it.';
  } else {
    summary = 'A difficult shift. Alerts piled up faster than they were resolved, and the network absorbed serious damage. Time to rebuild trust with the network — and the customers.';
  }
  document.getElementById('endSummary').textContent = summary;

  const endGrid = document.getElementById('endKpiGrid');
  endGrid.innerHTML = '';
  KPI_META.forEach(meta=>{
    const v = Math.round(state.kpi[meta.key]);
    const color = kpiColor(meta);
    const div = document.createElement('div');
    div.className = 'end-kpi';
    div.innerHTML = `<div class="l">${meta.label}</div><div class="v" style="color:${color}">${v}${meta.suffix}</div>`;
    endGrid.appendChild(div);
  });
}

function resetToStart(){
  document.getElementById('endScreen').classList.remove('show');
  document.getElementById('startScreen').style.display = 'flex';
}

/* ---------------------------- EVENT WIRING ---------------------------- */
document.getElementById('startBtn').onclick = startGame;
document.getElementById('playAgainBtn').onclick = resetToStart;
document.getElementById('pauseBtn').onclick = togglePause;
document.getElementById('resumeBtn').onclick = togglePause;

document.getElementById('soundBtn').onclick = function(){
  state.soundOn = !state.soundOn;
  this.classList.toggle('active', state.soundOn);
  this.textContent = state.soundOn ? '🔊' : '🔇';
};

const helpModal = document.getElementById('helpModal');
document.getElementById('helpBtn').onclick = ()=> helpModal.classList.add('show');
document.getElementById('howToPlayBtn').onclick = ()=> helpModal.classList.add('show');
document.getElementById('closeHelpBtn').onclick = ()=> helpModal.classList.remove('show');
helpModal.addEventListener('click', (e)=>{ if(e.target === helpModal) helpModal.classList.remove('show'); });

/* initial paint so KPI grid isn't empty before first start */
renderKPIs();
