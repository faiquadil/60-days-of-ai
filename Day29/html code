    setStage("company");
  }

  function replay(){
    setStage("welcome");
  }

  return (
    <div className="app-shell">
      {stage === "welcome" && <Welcome onStart={startSimulation} />}
      {stage === "company" && company && (
        <CompanyReveal company={company} onNext={() => setStage("crisis")} />
      )}
      {stage === "crisis" && crisis && (
        <CrisisReveal crisis={crisis} company={company} onNext={() => setStage("warroom")} />
      )}
      {stage === "warroom" && (
        <WarRoom onComplete={(result) => { setWarRoomResult(result); setStage("negotiation"); }} />
      )}
      {stage === "negotiation" && (
        <Negotiation onComplete={(result) => { setNegotiationResult(result); setStage("boardroom"); }} />
      )}
      {stage === "boardroom" && (
        <Boardroom onComplete={(result) => { setBoardroomResult(result); setStage("aistrategy"); }} />
      )}
      {stage === "aistrategy" && (
        <AIStrategy onComplete={(result) => { setAiStrategyResult(result); setStage("dashboard"); }} />
      )}
      {stage === "dashboard" && warRoomResult && negotiationResult && boardroomResult && aiStrategyResult && (
        <FinalDashboard
          company={company}
          crisis={crisis}
          warRoom={warRoomResult}
          negotiation={negotiationResult}
          boardroom={boardroomResult}
          aiStrategy={aiStrategyResult}
          onReplay={replay}
        />
      )}
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(<App />);
</script>
</body>
</html>
