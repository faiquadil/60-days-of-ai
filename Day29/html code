--------------------------------------------------------- */
function Negotiation({ onComplete }){
  const [roundIndex, setRoundIndex] = useState(0);
  const [stats, setStats] = useState({ trust: 50, price: 50, leadTime: 50 });
  const [history, setHistory] = useState([]);
  const [lastPick, setLastPick] = useState(null);

  const round = NEGOTIATION_ROUNDS[roundIndex];
  const isLastRound = roundIndex === NEGOTIATION_ROUNDS.length - 1;

  function choose(opt){
    if (lastPick) return;
    const newStats = {
      trust: clamp(stats.trust + opt.effects.trust),
      price: clamp(stats.price + opt.effects.price),
      leadTime: clamp(stats.leadTime + opt.effects.leadTime)
    };
    setStats(newStats);
    setLastPick(opt);
    setHistory(prev => [...prev, { round: round.id, choiceLabel: opt.label, why: opt.why }]);
  }

  function nextRound(){
    if (isLastRound){
      const score = Math.round((stats.trust + stats.price + stats.leadTime) / 3);
      onComplete({ stats, history, score });
    } else {
      setRoundIndex(roundIndex + 1);
      setLastPick(null);
    }
  }

  return (
    <div className="fade-in">
      <TopBar stageLabel="Step 4 of 7 — Supplier Negotiation" />
      <ProgressSteps current={3} total={7} />
      <div className="section-title"><span className="step-num">NEGOTIATION</span></div>
      <span className="round-tag">Round {round.id} of {NEGOTIATION_ROUNDS.length}</span>
      <h2>{round.prompt}</h2>

      <div className="grid grid-2" style={{marginTop:10}}>
        {round.options.map(opt => {
          const isSel = lastPick && lastPick.id === opt.id;
          const dimmed = lastPick && lastPick.id !== opt.id;
          return (
            <div key={opt.id}
              className={"option-card " + (isSel ? "selected" : "") + (dimmed ? " disabled-look" : "")}
              onClick={() => choose(opt)}>
              <div className="option-title">{opt.label}</div>
              {isSel && <div className="why-box" style={{marginTop:10}}><b>Why this matters:</b> {opt.why}</div>}
            </div>
          );
        })}
      </div>

      <div className="card" style={{marginTop:20}}>
        <h4>Live Negotiation Standing</h4>
        <StatBar label="Trust" value={stats.trust} colorClass={stats.trust >= 50 ? "green" : "red"} suffix="%" />
        <StatBar label="Price Favorability" value={stats.price} colorClass={stats.price >= 50 ? "green" : "red"} suffix="%" />
        <StatBar label="Lead Time Improvement" value={stats.leadTime} colorClass={stats.leadTime >= 50 ? "green" : "red"} suffix="%" />
      </div>

      <div className="footer-actions">
        <div></div>
        <button className="btn" disabled={!lastPick} onClick={nextRound}>
          {isLastRound ? "Finish Negotiation →" : "Next Round →"}
        </button>
      </div>
    </div>
  );
}

