/* ---------------------------------------------------------
   8. FINAL DASHBOARD
--------------------------------------------------------- */
function FinalDashboard({ company, crisis, warRoom, negotiation, boardroom, aiStrategy, onReplay }){

  const scores = useMemo(() => {
    const leadership = boardroom.score; // 0-100
    const negotiationScore = negotiation.score; // 0-100
    const resilienceRaw = 50 + aiStrategy.resilience + (warRoom.metrics.inventory - 50) * 0.3;
    const resilience = clamp(Math.round(resilienceRaw));
    const costControlRaw = warRoom.metrics.cost + (negotiation.stats.price - 50) * 0.3 + aiStrategy.cost;
    const costControl = clamp(Math.round(costControlRaw));
    const riskMgmtRaw = 50 + aiStrategy.resilience * 0.6 + (negotiation.stats.trust - 50) * 0.2 + (warRoom.metrics.inventory - 50) * 0.2;
    const riskManagement = clamp(Math.round(riskMgmtRaw));
    const satisfactionRaw = warRoom.metrics.satisfaction + (aiStrategy.satisfaction) + (negotiation.stats.leadTime - 50) * 0.15;
    const customerSatisfaction = clamp(Math.round(satisfactionRaw));

    const overall = Math.round(
      leadership * 0.22 +
      negotiationScore * 0.18 +
      resilience * 0.18 +
      costControl * 0.16 +
      riskManagement * 0.14 +
      customerSatisfaction * 0.12
    );

    return { leadership, negotiationScore, resilience, costControl, riskManagement, customerSatisfaction, overall: clamp(overall) };
  }, []);

  const tier = scores.overall >= 85 ? { label: "Crisis Master", color: "var(--green)" }
    : scores.overall >= 70 ? { label: "Steady Operator", color: "var(--accent)" }
    : scores.overall >= 50 ? { label: "Survived, But Shaken", color: "var(--yellow)" }
    : { label: "Crisis Casualty", color: "var(--red)" };

  // Determine biggest mistake and best decision from histories
  const boardroomWorst = boardroom.history.reduce((worst, h) => (!worst || h.score < worst.score) ? h : worst, null);
  const boardroomBest = boardroom.history.reduce((best, h) => (!best || h.score > best.score) ? h : best, null);

  const negWorst = negotiation.history.reduce((worst, h) => {
    if (!worst) return h;
    return h; // fallback, we compare via trust deltas below in text instead
  }, null);

  const feedbackLines = [];
  if (scores.leadership < 60) feedbackLines.push("Your boardroom decisions leaned reactive rather than decisive — executives are watched closely during a crisis, and hesitation reads as weakness.");
  if (scores.leadership >= 85) feedbackLines.push("Your leadership responses were consistently transparent and decisive — exactly what boards want to see under pressure.");
  if (scores.negotiationScore < 50) feedbackLines.push("Supplier trust took a hit during negotiations, which will likely raise costs on your next contract cycle.");
  if (scores.negotiationScore >= 75) feedbackLines.push("You built strong supplier trust, which should translate into better terms in future dealings.");
  if (scores.resilience < 55) feedbackLines.push("Your resilience score suggests the business is still vulnerable to a similar shock happening again soon.");
  if (scores.resilience >= 80) feedbackLines.push("Your AI and inventory choices meaningfully reduced the company's exposure to future disruptions.");
  if (scores.customerSatisfaction < 50) feedbackLines.push("Customers were left frustrated by the response — expect churn risk in the next quarter if this pattern repeats.");
  if (scores.costControl < 50) feedbackLines.push("The crisis response came at a steep financial cost — consider cheaper contingency options next time.");
  if (feedbackLines.length === 0) feedbackLines.push("You navigated the crisis with a well-balanced mix of speed, cost discipline, and stakeholder trust.");

  const biggestMistake = scores.leadership < scores.negotiationScore && scores.leadership < scores.resilience
    ? (boardroomWorst ? `In the boardroom, choosing "${boardroomWorst.choice}" undercut executive credibility at a critical moment.` : "A leadership decision under pressure cost you credibility.")
    : scores.negotiationScore <= scores.resilience
      ? "Aggressive or inconsistent negotiation tactics eroded supplier trust, likely raising future costs."
      : "Underinvesting in resilience left the business exposed to repeat disruption.";

  const bestDecision = scores.resilience >= scores.negotiationScore && scores.resilience >= scores.leadership
    ? `Investing in ${aiStrategy.chosen.map(c => c.title).join(" and ")} was your strongest long-term move — it directly boosts future resilience.`
    : scores.leadership >= scores.negotiationScore
      ? (boardroomBest ? `Choosing "${boardroomBest.choice}" in the boardroom was a strong display of executive judgment.` : "A confident leadership call stabilized stakeholder confidence.")
      : "Your supplier negotiation strategy preserved trust while still improving terms.";

  const expertRecommendation = scores.overall >= 75
    ? "Keep formalizing what worked here into a repeatable crisis playbook — consistency is what separates resilient companies from lucky ones."
    : scores.overall >= 50
      ? "Invest further in supplier diversification and predictive risk monitoring — you handled the crisis, but with more margin for error next time."
      : "Prioritize a full supply chain risk audit immediately — multiple weak points were exposed and left unaddressed during this simulation.";

  const lessons = [
    "Inventory buffers and lead time flexibility are the first line of defense in any disruption.",
    "Transparent, fast communication with customers and boards preserves trust even when outcomes are imperfect.",
    "Supplier relationships built on fairness — not just leverage — pay off most during a crisis, not before it.",
    "AI investments in forecasting and risk monitoring reduce the odds of being blindsided by the next disruption.",
    `A ${crisis.type.toLowerCase()} can happen to any company — the winners are the ones with a rehearsed response, not a perfect one.`
  ];

  return (
    <div className="fade-in">
      <TopBar stageLabel="Step 7 of 7 — Final Dashboard" />
      <ProgressSteps current={6} total={7} />
      <div className="section-title"><span className="step-num">RESULTS</span></div>
      <h2>Crisis Debrief: {company.name}</h2>

      <div className="card" style={{textAlign:"center", marginTop:10}}>
        <div style={{fontSize:12, letterSpacing:"0.1em", color:"var(--text-2)", textTransform:"uppercase"}}>Overall Crisis Score</div>
        <div className="score-big">{scores.overall}</div>
        <span className="badge" style={{background:"transparent", border:`1px solid ${tier.color}`, color: tier.color}}>{tier.label}</span>
      </div>

      <div className="grid grid-3" style={{marginTop:20}}>
        <ScoreCard label="Leadership" value={scores.leadership} />
        <ScoreCard label="Negotiation" value={scores.negotiationScore} />
        <ScoreCard label="Resilience" value={scores.resilience} />
        <ScoreCard label="Cost Control" value={scores.costControl} />
        <ScoreCard label="Risk Management" value={scores.riskManagement} />
        <ScoreCard label="Customer Satisfaction" value={scores.customerSatisfaction} />
      </div>

      <div className="card" style={{marginTop:20}}>
        <h3>Personalized Feedback</h3>
        <ul className="list-clean">
          {feedbackLines.map((l, i) => <li key={i}>{l}</li>)}
        </ul>
      </div>

      <div className="grid grid-2" style={{marginTop:16}}>
        <div className="card">
          <h4 style={{color:"var(--red)"}}>⚠️ Biggest Mistake</h4>
          <p>{biggestMistake}</p>
        </div>
        <div className="card">
          <h4 style={{color:"var(--green)"}}>⭐ Best Decision</h4>
          <p>{bestDecision}</p>
        </div>
      </div>

      <div className="card" style={{marginTop:16}}>
        <h4>🧠 Expert Recommendation</h4>
        <p>{expertRecommendation}</p>
      </div>

      <div className="card" style={{marginTop:16}}>
        <h4>📘 Lessons Learned</h4>
        <ul className="list-clean">
          {lessons.map((l, i) => <li key={i}>{l}</li>)}
        </ul>
      </div>

      <div className="footer-actions">
        <div></div>
        <button className="btn" onClick={onReplay}>🔁 Run a New Simulation</button>
      </div>
    </div>
  );
}

function ScoreCard({ label, value }){
  const color = value >= 70 ? "var(--green)" : value >= 45 ? "var(--yellow)" : "var(--red)";
  return (
    <div className="stat-card">
      <div className="stat-label">{label}</div>
      <div className="stat-value" style={{color}}>{value}</div>
      <div className="bar-track" style={{marginTop:8}}>
        <div className="bar-fill" style={{width: value + "%", background: color}}></div>
      </div>
    </div>
  );
}

