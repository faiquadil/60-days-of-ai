function TopBar({ stageLabel }){
  return (
    <div className="topbar">
      <div className="brand"><span className="brand-dot"></span> OPERATION LIFELINE</div>
      <div className="stage-pill">{stageLabel}</div>
    </div>
  );
}

function ProgressSteps({ current, total }){
  return (
    <div className="progress-steps">
      {Array.from({length: total}).map((_, i) => (
        <div key={i} className={"dotstep " + (i < current ? "done" : (i === current ? "active" : ""))}></div>
      ))}
    </div>
  );
}

function StatBar({ label, value, colorClass, suffix }){
  const [display, setDisplay] = useState(0);
  useEffect(() => {
    const t = setTimeout(() => setDisplay(value), 80);
    return () => clearTimeout(t);
  }, [value]);
  return (
    <div className="bar-row">
      <div className="bar-top">
        <span>{label}</span>
        <span>{Math.round(value)}{suffix || ""}</span>
      </div>
      <div className="bar-track">
        <div className={"bar-fill " + (colorClass || "")} style={{width: clamp(display, 0, 100) + "%"}}></div>
      </div>
    </div>
  );
}

function WhyBox({ children }){
