--------------------------------------------------------- */
function WarRoom({ onComplete }){
  const [selected, setSelected] = useState([]);
  const [confirmed, setConfirmed] = useState(false);
  const [metrics, setMetrics] = useState({ cost: 50, inventory: 50, profit: 50, deliverySpeed: 50, satisfaction: 50 });

  function toggle(id){
    if (confirmed) return;
    setSelected(prev => {
      if (prev.includes(id)) return prev.filter(x => x !== id);
      if (prev.length >= 3) return prev;
      return [...prev, id];
    });
  }

  function confirmActions(){
    if (selected.length !== 3) return;
    let m = { cost: 50, inventory: 50, profit: 50, deliverySpeed: 50, satisfaction: 50 };
    selected.forEach(id => {
      const action = WAR_ROOM_ACTIONS.find(a => a.id === id);
      m.cost = clamp(m.cost + action.effects.cost);
      m.inventory = clamp(m.inventory + action.effects.inventory);
      m.profit = clamp(m.profit + action.effects.profit);
      m.deliverySpeed = clamp(m.deliverySpeed + action.effects.deliverySpeed);
      m.satisfaction = clamp(m.satisfaction + action.effects.satisfaction);
    });
    setMetrics(m);
    setConfirmed(true);
  }

  function proceed(){
    onComplete({ selectedActions: selected, metrics });
  }

  return (
    <div className="fade-in">
      <TopBar stageLabel="Step 3 of 7 — War Room" />
      <ProgressSteps current={2} total={7} />
      <div className="section-title"><span className="step-num">DECISION</span></div>
      <h2>Choose Your Three Response Actions</h2>
      <p>Select exactly 3 actions. Each choice trades off cost, inventory, profit, delivery speed, and customer satisfaction — there is no perfect combination, only strategic tradeoffs.</p>

      <div className="grid grid-2" style={{marginTop:14}}>
        {WAR_ROOM_ACTIONS.map(action => {
          const isSelected = selected.includes(action.id);
          const disabledLook = !isSelected && selected.length >= 3 && !confirmed;
          return (
            <div
              key={action.id}
              className={"option-card " + (isSelected ? "selected" : "") + (disabledLook ? " disabled-look" : "")}
              onClick={() => toggle(action.id)}
            >
              <div className="option-title">{isSelected ? "✅ " : ""}{action.title}</div>
              <p className="option-desc">{action.desc}</p>
              {isSelected && <div className="why-box" style={{marginTop:10}}><b>Why this matters:</b> {action.why}</div>}
            </div>
          );
        })}
      </div>

      {!confirmed && (
        <div className="footer-actions">
          <div style={{color:"var(--text-2)", fontSize:13, alignSelf:"center"}}>{selected.length} / 3 selected</div>
          <button className="btn" disabled={selected.length !== 3} onClick={confirmActions}>Confirm & Simulate Impact →</button>
        </div>
      )}

      {confirmed && (
        <div className="card fade-in" style={{marginTop:22}}>
          <h3>Simulated Outcome</h3>
          <p>Here's how your combined actions affected the business in the days following the crisis:</p>
          <div style={{marginTop:16}}>
            <StatBar label="Cost Efficiency" value={metrics.cost} colorClass={metrics.cost >= 50 ? "green" : "red"} suffix="%" />
            <StatBar label="Inventory Health" value={metrics.inventory} colorClass={metrics.inventory >= 50 ? "green" : "red"} suffix="%" />
            <StatBar label="Profit Margin" value={metrics.profit} colorClass={metrics.profit >= 50 ? "green" : "red"} suffix="%" />
            <StatBar label="Delivery Speed" value={metrics.deliverySpeed} colorClass={metrics.deliverySpeed >= 50 ? "green" : "red"} suffix="%" />
            <StatBar label="Customer Satisfaction" value={metrics.satisfaction} colorClass={metrics.satisfaction >= 50 ? "green" : "red"} suffix="%" />
          </div>
          <div className="footer-actions">
            <div></div>
            <button className="btn" onClick={proceed}>Continue to Supplier Negotiation →</button>
          </div>
        </div>
      )}
    </div>
  );
}

