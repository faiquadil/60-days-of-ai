--------------------------------------------------------- */
function Boardroom({ onComplete }){
  const [qIndex, setQIndex] = useState(0);
  const [totalScore, setTotalScore] = useState(0);
  const [picked, setPicked] = useState(null);
  const [history, setHistory] = useState([]);

  const question = BOARDROOM_QUESTIONS[qIndex];
  const isLast = qIndex === BOARDROOM_QUESTIONS.length - 1;

  function choose(opt){
    if (picked) return;
    setPicked(opt);
    setHistory(prev => [...prev, { q: question.q, choice: opt.label, why: opt.why, score: opt.score }]);
  }

  function next(){
    const newTotal = totalScore + picked.score;
    if (isLast){
      const maxScore = BOARDROOM_QUESTIONS.length * 10;
      const pct = Math.round((newTotal / maxScore) * 100);
      onComplete({ score: pct, history: [...history] });
    } else {
      setTotalScore(newTotal);
      setQIndex(qIndex + 1);
      setPicked(null);
    }
  }

  return (
    <div className="fade-in">
      <TopBar stageLabel="Step 5 of 7 — CEO Boardroom" />
      <ProgressSteps current={4} total={7} />
      <div className="section-title"><span className="step-num">LEADERSHIP TEST</span></div>
      <span className="round-tag">Question {qIndex + 1} of {BOARDROOM_QUESTIONS.length}</span>
      <h2>{question.q}</h2>

      <div className="grid" style={{gridTemplateColumns:"1fr", gap:12, marginTop:10}}>
        {question.options.map((opt, i) => {
          const isSel = picked && picked.label === opt.label;
          const dimmed = picked && picked.label !== opt.label;
          return (
            <div key={i}
              className={"option-card " + (isSel ? "selected" : "") + (dimmed ? " disabled-look" : "")}
              onClick={() => choose(opt)}>
              <div className="option-title">{opt.label}</div>
              {isSel && <div className="why-box" style={{marginTop:10}}><b>Why this matters:</b> {opt.why}</div>}
            </div>
          );
        })}
      </div>

      <div className="footer-actions">
        <div style={{color:"var(--text-2)", fontSize:13, alignSelf:"center"}}>Executive Score So Far: {totalScore} pts</div>
        <button className="btn" disabled={!picked} onClick={next}>
          {isLast ? "Finish Boardroom →" : "Next Question →"}
        </button>
      </div>
    </div>
  );
}

