const COUNTRIES = [
  ["Vietnam", "Germany", "USA"], ["China", "Mexico", "Poland"], ["India", "Brazil", "Netherlands"],
  ["Bangladesh", "Turkey", "Spain"], ["Malaysia", "South Korea", "Canada"], ["Indonesia", "Italy", "USA"]
];

function randInt(min, max){ return Math.floor(Math.random() * (max - min + 1)) + min; }
function randFloat(min, max, dp=1){ return Number((Math.random() * (max - min) + min).toFixed(dp)); }
function pick(arr){ return arr[randInt(0, arr.length - 1)]; }
function clamp(v, min=0, max=100){ return Math.max(min, Math.min(max, v)); }

function generateCompany(){
  const name = `${pick(COMPANY_PREFIXES)} ${pick(COMPANY_SUFFIXES)}`;
  const industry = pick(INDUSTRIES);
  const revenue = randInt(80, 950); // millions
  const factories = randInt(2, 9);
  const warehouses = randInt(3, 14);
  const suppliers = randInt(8, 40);
  const inventoryDays = randInt(12, 60);
  const leadTime = randInt(7, 45);
  const countries = pick(COUNTRIES);
  return { name, industry, revenue, factories, warehouses, suppliers, inventoryDays, leadTime, countries };
}

