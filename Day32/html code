function App(){
  const [step, setStep] = useState(0);
  const [mode, setMode] = useState(null); // 'business' | 'personal' | 'client'
  const [brand, setBrand] = useState(null);
  const [customName, setCustomName] = useState("");
  const [customNiche, setCustomNiche] = useState("");
  const [selectedPlatforms, setSelectedPlatforms] = useState([]);
  const [selectedPillars, setSelectedPillars] = useState([]);
  const [event, setEvent] = useState(null);
  const [chosenResponse, setChosenResponse] = useState(null);
  const [runSeed, setRunSeed] = useState(0);

  const isPersonal = mode === "personal";
  const platformLib = isPersonal ? PLATFORM_LIBRARY.personal : PLATFORM_LIBRARY.business;
  const pillarLib = isPersonal ? PILLARS_PERSONAL : PILLARS_BUSINESS;
  const eventLib = isPersonal ? EVENTS_PERSONAL : EVENTS_BUSINESS;
  const responseLib = isPersonal ? RESPONSES_PERSONAL : RESPONSES_BUSINESS;

  const goTo = (n) => { window.scrollTo({top:0, behavior:"smooth"}); setStep(n); };

  const startFlow = (chosenMode) => {
    setMode(chosenMode);
    if(chosenMode === "client"){
      setBrand(pick(INDUSTRIES));
    } else if(chosenMode === "personal"){
      setBrand(pick(PERSONAL_NICHES));
    } else {
      setBrand(null); // user will fill custom form
    }
    goTo(1);
  };

  const confirmCustomBusiness = () => {
    setBrand({
      name: customName.trim() || "Your Business",
      audience: customNiche.trim() || "Your target audience",
      budget: "Your budget",
      challenge: "The challenge you're currently facing",
      custom: true,
    });
  };

  const togglePlatform = (key) => {
    setSelectedPlatforms(prev => prev.includes(key) ? prev.filter(k=>k!==key) : [...prev, key]);
  };

  const togglePillar = (key) => {
    setSelectedPillars(prev => {
      if(prev.includes(key)) return prev.filter(k=>k!==key);
      if(prev.length >= 3) return prev;
      return [...prev, key];
    });
  };

  const rollEvent = () => {
    const e = pick(eventLib);
    setEvent(e);
    setChosenResponse(null);
  };

  const restart = () => {
    setMode(null); setBrand(null); setCustomName(""); setCustomNiche("");
    setSelectedPlatforms([]); setSelectedPillars([]); setEvent(null); setChosenResponse(null);
    setRunSeed(s=>s+1);
    goTo(0);
  };

  const brandLabel = brand ? brand.name : "your brand";
  const chosenPillarObjs = pillarLib.filter(p => selectedPillars.includes(p.key));
  const chosenPlatformObjs = platformLib.filter(p => selectedPlatforms.includes(p.key));
  const roadmap = useMemo(()=> buildRoadmap(isPersonal, chosenPillarObjs), [isPersonal, selectedPillars.join(",")]);

  return (
    <div className="app-shell" key={runSeed}>
      <div className="topbar">
        <div className="brandmark"><div className="dot"></div><span>Marketing Strategist Sim</span></div>
        <div style={{fontSize:"12px", color:"var(--ink-dim)"}}>Step {step+1} / {STEP_NAMES.length}</div>
      </div>

      {step > 0 && <GrowthTrack step={step} />}

      {step === 0 && (
        <WelcomeScreen onStart={startFlow} />
      )}

      {step === 1 && (
        <BrandScreen
          mode={mode}
          brand={brand}
          isPersonal={isPersonal}
          customName={customName} setCustomName={setCustomName}
          customNiche={customNiche} setCustomNiche={setCustomNiche}
          confirmCustomBusiness={confirmCustomBusiness}
          onNext={()=>goTo(2)}
        />
      )}

      {step === 2 && (
        <PlatformScreen
          isPersonal={isPersonal}
          brandLabel={brandLabel}
          platformLib={platformLib}
          selected={selectedPlatforms}
          toggle={togglePlatform}
          onNext={()=>goTo(3)}
        />
      )}

      {step === 3 && (
        <PillarScreen
          isPersonal={isPersonal}
          brandLabel={brandLabel}
          pillarLib={pillarLib}
          selected={selectedPillars}
          toggle={togglePillar}
          onNext={()=>goTo(4)}
        />
      )}

      {step === 4 && (
        <RoadmapScreen
          isPersonal={isPersonal}
          brandLabel={brandLabel}
          roadmap={roadmap}
          pillars={chosenPillarObjs}
          onNext={()=>{ rollEvent(); goTo(5); }}
        />
      )}

      {step === 5 && (
        <EventScreen
          isPersonal={isPersonal}
          brandLabel={brandLabel}
          event={event}
          responseLib={responseLib}
          chosenResponse={chosenResponse}
          setChosenResponse={setChosenResponse}
          onNext={()=>goTo(6)}
        />
      )}

      {step === 6 && (
        <ReportScreen
          isPersonal={isPersonal}
          brandLabel={brandLabel}
          brand={brand}
          platforms={chosenPlatformObjs}
          pillars={chosenPillarObjs}
          event={event}
          chosenResponse={chosenResponse}
          onRestart={restart}
        />
      )}

      <div className="footer-note">Runs fully offline · No data leaves your browser · Built to teach marketing strategy, not just generate content</div>
    </div>
  );
}

