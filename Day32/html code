/* ---------------- HELPERS ---------------- */

function pick(arr){ return arr[Math.floor(Math.random()*arr.length)]; }

function buildRoadmap(isPersonal, pillars){
  const p = pillars.map(x=>x.name);
  if(isPersonal){
    return [
      { week:"Week 1", goal:"Define your point of view & optimize your profile", detail:`Nail down your niche statement and rewrite your bio/headline so it's instantly clear who you help and how. Post 2-3 pieces introducing your ${p[0] || "core"} angle.` },
      { week:"Week 2", goal:"Establish a consistent posting rhythm", detail:`Publish across your top pillars (${p.join(", ") || "your chosen pillars"}) on a fixed schedule. Consistency matters more than volume right now.` },
      { week:"Week 3", goal:"Deepen engagement with your early audience", detail:"Reply to every comment, start conversations in others' posts, and ask your audience direct questions to learn what resonates." },
      { week:"Week 4", goal:"Convert attention into a durable asset", detail:"Push engaged followers toward your newsletter or a simple lead magnet so your audience isn't fully dependent on any single platform." },
    ];
  }
  return [
    { week:"Week 1", goal:"Establish brand presence & baseline content", detail:`Set up or refresh profiles and publish an initial content wave across your top pillars (${p.join(", ") || "your chosen pillars"}) to establish a consistent voice.` },
    { week:"Week 2", goal:"Test messaging and formats", detail:"Try a few different hooks, formats, and calls-to-action to see what your audience responds to before committing to a system." },
    { week:"Week 3", goal:"Double down on what's working", detail:"Analyze early engagement and shift more effort toward the pillar and format performing best." },
    { week:"Week 4", goal:"Convert attention into measurable results", detail:"Introduce a clear conversion moment — an offer, sign-up, or purchase path — for the audience you've been warming up." },
  ];
}

/* ---------------- SMALL COMPONENTS ---------------- */

function GrowthTrack({ step }){
  const total = STEP_NAMES.length - 1;
  const pct = step / total;
  const width = 1000;
  const points = [];
  const n = 24;
  for(let i=0;i<=n;i++){
    const x = (i/n)*width;
    const wobble = Math.sin(i*0.9)*6;
    const y = 40 - (x/width)*30 + wobble*(1-x/width);
    points.push([x,y]);
  }
  const d = "M " + points.map(p=>p.join(",")).join(" L ");
  const dashLen = 1000;
  const offset = dashLen - dashLen*pct;

  return (
    <div className="growth-track">
      <svg viewBox={`0 0 ${width} 46`} preserveAspectRatio="none">
        <path className="growth-path" d={d} />
        <path className="growth-path-fill" d={d} style={{strokeDashoffset: offset}} />
      </svg>
      <div className="growth-labels">
        {STEP_NAMES.map((s,i)=>(
          <span key={s} className={i<=step ? "active":""}>{s}</span>
        ))}
      </div>
    </div>
  );
}

function AskClaudeCard({ label, prompt }){
  const [copied,setCopied] = useState(false);
  const doCopy = () => {
    const ta = document.createElement("textarea");
    ta.value = prompt;
    document.body.appendChild(ta);
    ta.select();
    try{ document.execCommand("copy"); }catch(e){}
    document.body.removeChild(ta);
    setCopied(true);
    setTimeout(()=>setCopied(false), 1600);
  };
  return (
    <div className="prompt-card">
      <div className="lbl"><span>🤖 How to ask Claude</span></div>
      <p style={{fontSize:"12.5px", color:"var(--ink-dim)", marginBottom:"8px"}}>{label}</p>
      <div className="prompt-text">{prompt}</div>
      <button className="copy-btn" onClick={doCopy}>{copied ? "Copied!" : "Copy prompt"}</button>
    </div>
  );
}

