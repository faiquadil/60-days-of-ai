<style>
  :root{
    --bg: #0b0f14;
    --bg-2: #10161d;
    --panel: #141b23;
    --panel-2: #1b232c;
    --line: #26313b;
    --teal: #3ddcb0;
    --teal-dim: #1f6f5c;
    --amber: #ffb347;
    --ink: #e9eef2;
    --ink-dim: #9fb0bd;
    --danger: #ff6b6b;
    --font-display: 'Space Grotesk', 'Arial Narrow', sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
  }
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap');
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background: radial-gradient(1200px 800px at 80% -10%, #12222016 0%, transparent 60%), var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    line-height:1.5;
    min-height:100vh;
  }
  #root{min-height:100vh;}
  h1,h2,h3,h4{font-family:var(--font-display); margin:0; letter-spacing:-0.01em;}
  p{margin:0;}
  button{font-family:var(--font-body); cursor:pointer;}
  ::selection{background:var(--teal); color:#04140f;}

  .app-shell{max-width:920px; margin:0 auto; padding:28px 20px 80px;}
  .topbar{
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom: 28px;
  }
  .brandmark{display:flex; align-items:center; gap:10px;}
  .brandmark .dot{width:10px;height:10px;border-radius:50%;background:var(--teal); box-shadow:0 0 12px var(--teal);}
  .brandmark span{font-family:var(--font-display); font-weight:600; font-size:15px; color:var(--ink-dim); letter-spacing:0.02em;}

  /* growth line progress */
  .growth-track{
    position:relative; height:46px; margin: 4px 0 34px;
  }
  .growth-track svg{width:100%; height:100%; overflow:visible;}
  .growth-path{
    fill:none; stroke: var(--line); stroke-width:2;
  }
  .growth-path-fill{
    fill:none; stroke: var(--teal); stroke-width:2.5;
    stroke-dasharray: 1000; stroke-dashoffset: 1000;
    transition: stroke-dashoffset 900ms cubic-bezier(.2,.8,.2,1);
    filter: drop-shadow(0 0 6px rgba(61,220,176,0.5));
  }
  .growth-labels{display:flex; justify-content:space-between; margin-top:6px;}
  .growth-labels span{font-size:11px; color:var(--ink-dim); font-family:var(--font-display); text-transform:uppercase; letter-spacing:0.06em; width:60px; text-align:center;}
  .growth-labels span.active{color:var(--teal);}

  .card{
    background: linear-gradient(180deg, var(--panel) 0%, var(--panel-2) 100%);
    border:1px solid var(--line);
    border-radius:14px;
    padding:24px;
    margin-bottom:18px;
    animation: rise 420ms ease both;
  }
  @keyframes rise{ from{opacity:0; transform:translateY(10px);} to{opacity:1; transform:translateY(0);} }

  .eyebrow{
    font-family:var(--font-display); text-transform:uppercase; letter-spacing:0.12em;
    font-size:11px; color:var(--teal); margin-bottom:8px; font-weight:600;
  }
  .h-title{font-size:22px; font-weight:700; margin-bottom:6px;}
  .h-sub{color:var(--ink-dim); font-size:14.5px; margin-bottom:18px;}

  .why-box{
    background: rgba(61,220,176,0.06);
    border:1px dashed var(--teal-dim);
    border-radius:10px;
    padding:14px 16px;
    margin: 14px 0;
    font-size:13.5px;
    color: #cfe9df;
  }
  .why-box b{color:var(--teal);}

  .choice-grid{display:grid; grid-template-columns:1fr; gap:12px; margin-top:6px;}
  @media(min-width:640px){ .choice-grid{grid-template-columns:1fr 1fr 1fr;} }
  .choice-card{
    background: var(--bg-2);
    border:1px solid var(--line);
    border-radius:12px;
    padding:18px 16px;
    text-align:left;
    transition: all 160ms ease;
    color:var(--ink);
  }
  .choice-card:hover{border-color:var(--teal); transform:translateY(-2px); box-shadow:0 6px 20px rgba(61,220,176,0.08);}
  .choice-card .icon{font-size:26px; display:block; margin-bottom:10px;}
  .choice-card h4{font-size:15.5px; margin-bottom:4px;}
  .choice-card p{font-size:12.5px; color:var(--ink-dim);}

  .btn{
    background: var(--teal);
    color:#04140f;
    border:none;
    padding:12px 20px;
    border-radius:9px;
    font-weight:700;
    font-size:14px;
    transition: all 150ms ease;
  }
  .btn:hover{filter:brightness(1.08); transform:translateY(-1px);}
  .btn:disabled{background:#334049; color:#77848d; cursor:not-allowed; transform:none;}
  .btn-ghost{
    background:transparent; color:var(--ink-dim); border:1px solid var(--line);
    padding:11px 18px; border-radius:9px; font-size:13.5px;
  }
  .btn-ghost:hover{border-color:var(--ink-dim); color:var(--ink);}
  .btn-row{display:flex; gap:10px; margin-top:20px; flex-wrap:wrap;}

  .tag{
    display:inline-block; font-size:11.5px; padding:4px 10px; border-radius:999px;
    background:var(--bg-2); border:1px solid var(--line); color:var(--ink-dim); margin:2px 4px 2px 0;
  }

  .platform-row{
    display:flex; align-items:flex-start; gap:14px; padding:14px; border-radius:10px;
    border:1px solid var(--line); background:var(--bg-2); margin-bottom:10px; cursor:pointer;
    transition: all 150ms ease;
  }
  .platform-row:hover{border-color: var(--teal-dim);}
  .platform-row.selected{border-color:var(--teal); background:rgba(61,220,176,0.07);}
  .platform-row .pf-icon{font-size:22px; width:34px; text-align:center;}
  .platform-row .pf-body h4{font-size:14.5px; margin-bottom:4px;}
  .platform-row .pf-body p{font-size:12.5px; color:var(--ink-dim);}
  .check{
    width:20px;height:20px;border-radius:6px;border:1.5px solid var(--line);
    flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:2px;
  }
  .check.on{background:var(--teal); border-color:var(--teal); color:#04140f; font-weight:800; font-size:13px;}

  .pillar-card{
    border:1px solid var(--line); background:var(--bg-2); border-radius:12px; padding:16px;
    margin-bottom:10px; cursor:pointer; transition: all 150ms ease; position:relative;
  }
  .pillar-card:hover{border-color:var(--teal-dim);}
  .pillar-card.selected{border-color:var(--teal); background:rgba(61,220,176,0.07);}
  .pillar-card .num{
    position:absolute; top:14px; right:14px; font-family:var(--font-display); font-size:12px; color:var(--teal); font-weight:700;
  }
  .pillar-card h4{font-size:15px; margin-bottom:6px; padding-right:26px;}
  .pillar-card p{font-size:12.5px; color:var(--ink-dim);}

  .week-block{
    border-left:2px solid var(--teal-dim); padding-left:16px; margin-bottom:18px; position:relative;
  }
  .week-block::before{
    content:''; position:absolute; left:-6px; top:2px; width:10px; height:10px; border-radius:50%; background:var(--teal);
  }
  .week-block h4{font-size:14.5px; color:var(--teal); margin-bottom:4px; font-family:var(--font-display);}
  .week-block p{font-size:13.5px; color:var(--ink-dim);}

  .event-banner{
    background: linear-gradient(120deg, rgba(255,179,71,0.13), rgba(255,179,71,0.02));
    border:1px solid #6b4d1f; border-radius:12px; padding:18px; margin-bottom:16px;
  }
  .event-banner .icon{font-size:28px; margin-bottom:8px; display:block;}

  .response-option{
    display:block; width:100%; text-align:left; border:1px solid var(--line); background:var(--bg-2);
    border-radius:10px; padding:14px; margin-bottom:10px; color:var(--ink); font-size:13.5px;
    transition: all 150ms ease;
  }
  .response-option:hover{border-color:var(--amber);}
  .response-option.chosen{border-color:var(--amber); background:rgba(255,179,71,0.08);}

  .consequence{
    background:var(--bg-2); border:1px solid var(--line); border-radius:10px; padding:16px; margin-top:14px; font-size:13.5px;
  }

  .prompt-card{
    background:#0d1319; border:1px solid #223038; border-radius:10px; padding:14px 16px; margin-top:16px;
  }
  .prompt-card .lbl{display:flex; align-items:center; gap:8px; margin-bottom:8px;}
  .prompt-card .lbl span{font-family:var(--font-display); font-size:12px; text-transform:uppercase; letter-spacing:0.08em; color:var(--amber); font-weight:700;}
  .prompt-text{
    font-family: 'SFMono-Regular', Consolas, monospace; font-size:12.5px; color:#c9d6de;
    background:#080c10; border-radius:8px; padding:12px; white-space:pre-wrap; line-height:1.6;
  }
  .copy-btn{
    margin-top:10px; font-size:12px; background:transparent; color:var(--amber); border:1px solid #6b4d1f;
    padding:6px 12px; border-radius:7px;
  }
  .copy-btn:hover{background:rgba(255,179,71,0.1);}

  .report-grid{display:grid; grid-template-columns:1fr; gap:12px;}
  @media(min-width:640px){ .report-grid{grid-template-columns:1fr 1fr;} }
  .report-item{border:1px solid var(--line); background:var(--bg-2); border-radius:10px; padding:14px 16px;}
  .report-item h4{font-size:12.5px; text-transform:uppercase; letter-spacing:0.06em; color:var(--teal); margin-bottom:6px; font-family:var(--font-display);}
  .report-item p{font-size:13.5px; color:var(--ink-dim);}

  .lesson{display:flex; gap:12px; margin-bottom:12px; align-items:flex-start;}
  .lesson .n{
    font-family:var(--font-display); font-weight:700; color:var(--teal); font-size:18px; width:26px; flex-shrink:0;
  }

  .footer-note{text-align:center; color:var(--ink-dim); font-size:12px; margin-top:30px;}
  .replay-wrap{text-align:center; margin-top:20px;}

  input[type=text], textarea{
    width:100%; background:var(--bg-2); border:1px solid var(--line); color:var(--ink);
    border-radius:9px; padding:11px 13px; font-size:14px; font-family:var(--font-body);
    margin-bottom:10px;
  }
  input[type=text]:focus, textarea:focus, button:focus-visible, .platform-row:focus-visible, .pillar-card:focus-visible{
    outline:2px solid var(--teal); outline-offset:2px;
  }
  label.field-label{font-size:12.5px; color:var(--ink-dim); display:block; margin-bottom:6px; font-family:var(--font-display); text-transform:uppercase; letter-spacing:0.05em;}
</style>
</head>
