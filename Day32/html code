          <div className="report-item">
            <h4>Best Decision</h4>
            <p>{chosenResponse ? `Choosing to "${chosenResponse.label.toLowerCase()}" in response to the ${event ? event.title.toLowerCase() : "event"} showed real strategic thinking.` : "Completing the full strategy process itself was the strongest decision."}</p>
          </div>
          <div className="report-item">
            <h4>Biggest Mistake</h4>
            <p>{platforms.length > 3 ? "Spreading focus across too many platforms at once dilutes consistency." : "Watch for the temptation to react to trends instead of sticking with your core pillars."}</p>
          </div>
        </div>

        <h3 className="h-title" style={{fontSize:"16px", margin:"22px 0 12px"}}>Three Marketing Lessons</h3>
        {lessons.map((l,i) => (
          <div className="lesson" key={i}>
            <div className="n">{i+1}</div>
            <p>{l}</p>
          </div>
        ))}

        <div className="why-box">
          <b>Why does this matter?</b> The goal was never to memorize these exact choices — it's to practice
          the thinking: understand first, choose deliberately, stay focused, and adapt when reality doesn't
          follow the plan.
        </div>
      </div>

      <AskClaudeCard
        label="Use this prompt to get Claude to review a real strategy for you:"
        prompt={isPersonal
          ? `Review my personal brand strategy. Niche: "${brandLabel}". Platforms: ${platformNames}. Content pillars: ${pillarNames}. Point out gaps, blind spots, and one thing I should focus on improving first.`
          : `Review my marketing strategy. Business: "${brandLabel}". Platforms: ${platformNames}. Content pillars: ${pillarNames}. Point out gaps, blind spots, and one thing I should focus on improving first.`}
      />

      <div className="replay-wrap">
        <button className="btn-ghost" onClick={onRestart}>🔁 Start a new brand</button>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
